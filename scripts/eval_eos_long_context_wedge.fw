func getenv(name string, fallback string) string {
	value := strings.TrimSpace(os.Getenv(name))
	if value != "" {
		return value
	}
	return fallback
}

func hasRepoRoot(dir string) bool {
	if dir == "" {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, "go.mod")); err != nil {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, ".git")); err != nil {
		return false
	}
	return true
}

func findRoot() (string, error) {
	if explicit := os.Getenv("EOS_REPO_ROOT"); hasRepoRoot(explicit) {
		return filepath.Abs(explicit)
	}
	cwd, err := os.Getwd()
	if err != nil {
		return "", err
	}
	if hasRepoRoot(cwd) {
		return filepath.Abs(cwd)
	}
	return "", fmt.Errorf("could not find repo root; set EOS_REPO_ROOT")
}

func parseIntEnv(name string, fallback int) (int, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.Atoi(value)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseInt64Env(name string, fallback int64) (int64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseInt(value, 10, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseFloatEnv(name string, fallback float64) (float64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseFloat(value, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be a float: %w", name, err)
	}
	return parsed, nil
}

func parseBoolEnv(name string) bool {
	value := strings.ToLower(strings.TrimSpace(os.Getenv(name)))
	switch value {
	case "1", "true", "yes", "on":
		return true
	default:
		return false
	}
}

func enabledByDefaultEnv(name string) bool {
	value := strings.ToLower(strings.TrimSpace(os.Getenv(name)))
	switch value {
	case "", "1", "true", "yes", "on":
		return true
	case "0", "false", "no", "off":
		return false
	default:
		return true
	}
}

func sparseEncoderEnabled() bool {
	mode := strings.ToLower(strings.TrimSpace(os.Getenv("EOS_LC_WEDGE_SPARSE_ENCODER_MODE")))
	if mode == "off" || mode == "0" || mode == "false" || mode == "no" {
		return false
	}
	return enabledByDefaultEnv("EOS_LC_WEDGE_SPARSE_ENCODER")
}

func perQueryEnabled() bool {
	return parseBoolEnv("EOS_LC_WEDGE_PER_QUERY") || parseBoolEnv("EOS_LC_WEDGE_PER_QUERY_JSONL")
}

func parentSpanFusionEnabled() bool {
	mode := strings.ToLower(strings.TrimSpace(os.Getenv("EOS_LC_WEDGE_PARENT_SPAN_FUSION")))
	switch mode {
	case "0", "false", "no", "off":
		return false
	default:
		return true
	}
}

func parseParentAggregationEnv() (string, error) {
	value := getenv("EOS_LC_WEDGE_PARENT_AGGREGATION", "max")
	switch value {
	case "max", "top2-mean", "top3-mean", "top5-mean":
		return value, nil
	default:
		return "", fmt.Errorf("EOS_LC_WEDGE_PARENT_AGGREGATION must be one of max, top2-mean, top3-mean, top5-mean; got %q", value)
	}
}

func fileExists(path string) bool {
	info, err := os.Stat(path)
	return err == nil && !info.IsDir()
}

func absUnder(root string, path string) string {
	if filepath.IsAbs(path) {
		return path
	}
	return filepath.Join(root, path)
}

func runCmd(root string, label string, logPath string, name string, args []string) (commandRecord, error) {
	cmd := exec.Command(name, args...)
	cmd.Dir = root
	out, err := cmd.CombinedOutput()
	_ = os.WriteFile(logPath, out, 0o644)
	record := commandRecord{Label: label, Args: append([]string{name}, args...), Log: logPath}
	if err != nil {
		return record, fmt.Errorf("%s failed: %w; see %s", label, err, logPath)
	}
	return record, nil
}

func readJSON(path string, out interface{}) error {
	data, err := os.ReadFile(path)
	if err != nil {
		return err
	}
	return json.Unmarshal(data, out)
}

func defaultArtifact(root string) string {
	candidate := filepath.Join(root, "runs", "current-release-qwen3-nf005-continuation-20260616T224102Z", "candidate", "eos-embed-v1.mll")
	if fileExists(candidate) && fileExists(siblingWeightPath(candidate)) {
		return candidate
	}
	return filepath.Join(root, "assets", "corkscrewdb-default-embedder", "corkscrewdb-default-embedder.mll")
}

func siblingWeightPath(artifact string) string {
	base := strings.TrimSuffix(artifact, ".sealed.mll")
	if base == artifact {
		base = strings.TrimSuffix(artifact, ".mll")
	}
	return base + ".weights.mll"
}

func writeComparisonTSV(path string, rows []comparisonRow) error {
	var b strings.Builder
	b.WriteString("baseline\tmodel\tmethod\tdim\tbits\tndcg_at_10\trecall_at_100\tchild_count\tstorage_multiple\tcompression_ratio\tmetrics_path\tartifact\tmodel_id\tquality_claim\tcaveats\n")
	for _, row := range rows {
		b.WriteString(fmt.Sprintf("%s\t%s\t%s\t%d\t%d\t%.9f\t%.9f\t%d\t%.9f\t%.9f\t%s\t%s\t%s\t%t\t%s\n",
			row.Baseline, row.Model, row.Method, row.Dim, row.Bits, row.NDCGAt10, row.RecallAt100,
			row.ChildCount, row.StorageMultiple, row.CompressionRatio, row.MetricsPath, row.Artifact,
			row.ModelID, row.QualityClaim, strings.ReplaceAll(row.Caveats, "\t", " ")))
	}
	return os.WriteFile(path, []byte(b.String()), 0o644)
}

func writeJSON(path string, value interface{}) error {
	data, err := json.MarshalIndent(value, "", "  ")
	if err != nil {
		return err
	}
	return os.WriteFile(path, append(data, '\n'), 0o644)
}

func splitCSV(value string) []string {
	parts := strings.Split(value, ",")
	out := []string{}
	for _, part := range parts {
		item := strings.TrimSpace(part)
		if item != "" {
			out = append(out, item)
		}
	}
	return out
}

func bitsIncludeQ4(bits string) bool {
	for _, part := range splitCSV(bits) {
		if part == "4" {
			return true
		}
	}
	return false
}

func multiVectorStorageMultipleForBits(mv mvMetrics, bits int) (float64, bool) {
	for _, row := range mv.Rows {
		if row.Bits == bits && row.StorageMultipleOfDenseBaseline > 0 {
			return row.StorageMultipleOfDenseBaseline, true
		}
	}
	return 0, false
}

func directParentDenseStorageMultiple(directDim int, baselineDim int) float64 {
	if directDim <= 0 || baselineDim <= 0 {
		return 0
	}
	return float64(directDim) / float64(baselineDim)
}

func readQrels(path string) (map[string]map[string]float64, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		return nil, err
	}
	lines := strings.Split(string(data), "\n")
	if len(lines) == 0 {
		return nil, fmt.Errorf("empty qrels file: %s", path)
	}
	header := strings.Split(strings.TrimSpace(lines[0]), "\t")
	queryIdx, corpusIdx, scoreIdx := -1, -1, -1
	for i, name := range header {
		switch name {
		case "query-id":
			queryIdx = i
		case "corpus-id":
			corpusIdx = i
		case "score":
			scoreIdx = i
		}
	}
	if queryIdx < 0 || corpusIdx < 0 || scoreIdx < 0 {
		return nil, fmt.Errorf("qrels header must contain query-id, corpus-id, and score: %s", path)
	}
	qrels := map[string]map[string]float64{}
	for _, line := range lines[1:] {
		line = strings.TrimSpace(line)
		if line == "" {
			continue
		}
		parts := strings.Split(line, "\t")
		if len(parts) <= queryIdx || len(parts) <= corpusIdx || len(parts) <= scoreIdx {
			continue
		}
		score, err := strconv.ParseFloat(parts[scoreIdx], 64)
		if err != nil || score <= 0 {
			continue
		}
		if qrels[parts[queryIdx]] == nil {
			qrels[parts[queryIdx]] = map[string]float64{}
		}
		qrels[parts[queryIdx]][parts[corpusIdx]] = score
	}
	return qrels, nil
}

func readDirectPerQuery(path string) (map[string][]perQueryTopDoc, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		return nil, err
	}
	out := map[string][]perQueryTopDoc{}
	for lineNo, line := range strings.Split(string(data), "\n") {
		line = strings.TrimSpace(line)
		if line == "" {
			continue
		}
		var row directPerQueryRow
		if err := json.Unmarshal([]byte(line), &row); err != nil {
			return nil, fmt.Errorf("%s:%d: %w", path, lineNo+1, err)
		}
		if row.QueryID == "" {
			return nil, fmt.Errorf("%s:%d: missing query_id", path, lineNo+1)
		}
		out[row.QueryID] = dedupeRanking(row.TopK)
	}
	return out, nil
}

func readTokenSpanPerQuery(path string, method string) (map[string][]perQueryTopDoc, error) {
	data, err := os.ReadFile(path)
	if err != nil {
		return nil, err
	}
	out := map[string][]perQueryTopDoc{}
	for lineNo, line := range strings.Split(string(data), "\n") {
		line = strings.TrimSpace(line)
		if line == "" {
			continue
		}
		var row tokenSpanPerQueryRow
		if err := json.Unmarshal([]byte(line), &row); err != nil {
			return nil, fmt.Errorf("%s:%d: %w", path, lineNo+1, err)
		}
		if row.Method != method {
			continue
		}
		if row.QueryID == "" {
			return nil, fmt.Errorf("%s:%d: missing query_id", path, lineNo+1)
		}
		out[row.QueryID] = dedupeRanking(row.TopK)
	}
	return out, nil
}

func dedupeRanking(items []perQueryTopDoc) []perQueryTopDoc {
	seen := map[string]bool{}
	out := make([]perQueryTopDoc, 0, len(items))
	for _, item := range items {
		if item.DocID == "" || seen[item.DocID] {
			continue
		}
		seen[item.DocID] = true
		if item.Rank == 0 {
			item.Rank = len(out) + 1
		}
		out = append(out, item)
	}
	return out
}

func topKWithRelevance(ranking []perQueryTopDoc, rels map[string]float64, limit int) []perQueryTopDoc {
	if limit <= 0 || limit > len(ranking) {
		limit = len(ranking)
	}
	out := make([]perQueryTopDoc, 0, limit)
	for i := 0; i < limit; i++ {
		item := ranking[i]
		item.Rank = i + 1
		item.Relevance = rels[item.DocID]
		out = append(out, item)
	}
	return out
}

func dcgAt(ranking []perQueryTopDoc, rels map[string]float64, k int) float64 {
	total := 0.0
	for i, item := range ranking {
		if i >= k {
			break
		}
		rel := rels[item.DocID]
		if rel > 0 {
			total += (math.Pow(2, rel) - 1) / math.Log2(float64(i+2))
		}
	}
	return total
}

func idcgAt(rels map[string]float64, k int) float64 {
	values := []float64{}
	for _, rel := range rels {
		if rel > 0 {
			values = append(values, rel)
		}
	}
	for i := 0; i < len(values); i++ {
		for j := i + 1; j < len(values); j++ {
			if values[j] > values[i] {
				values[i], values[j] = values[j], values[i]
			}
		}
	}
	total := 0.0
	for i, rel := range values {
		if i >= k {
			break
		}
		total += (math.Pow(2, rel) - 1) / math.Log2(float64(i+2))
	}
	return total
}

func rankingQuality(ranking []perQueryTopDoc, rels map[string]float64) fusionQuality {
	relCount := 0
	for _, rel := range rels {
		if rel > 0 {
			relCount++
		}
	}
	idcg10 := idcgAt(rels, 10)
	firstRelevantRank := 0
	hits100 := 0
	for i, item := range ranking {
		if i >= 100 {
			break
		}
		if rels[item.DocID] > 0 {
			hits100++
			if firstRelevantRank == 0 {
				firstRelevantRank = i + 1
			}
		}
	}
	q := fusionQuality{}
	if idcg10 > 0 {
		q.NDCGAt10 = dcgAt(ranking, rels, 10) / idcg10
	}
	if relCount > 0 {
		q.RecallAt100 = float64(hits100) / float64(relCount)
	}
	if firstRelevantRank > 0 && firstRelevantRank <= 10 {
		q.MRRAt10 = 1.0 / float64(firstRelevantRank)
	}
	if len(ranking) > 0 && rels[ranking[0].DocID] > 0 {
		q.HitAt1 = 1
	}
	return q
}

func aggregateFusionQuality(rankings map[string][]perQueryTopDoc, qrels map[string]map[string]float64) (fusionQuality, int, error) {
	total := fusionQuality{}
	count := 0
	for queryID, rels := range qrels {
		ranking, ok := rankings[queryID]
		if !ok {
			return total, count, fmt.Errorf("missing per-query ranking for query %s", queryID)
		}
		q := rankingQuality(ranking, rels)
		total.NDCGAt10 += q.NDCGAt10
		total.RecallAt100 += q.RecallAt100
		total.MRRAt10 += q.MRRAt10
		total.HitAt1 += q.HitAt1
		count++
	}
	if count > 0 {
		denom := float64(count)
		total.NDCGAt10 /= denom
		total.RecallAt100 /= denom
		total.MRRAt10 /= denom
		total.HitAt1 /= denom
	}
	return total, count, nil
}

func addFusionQuality(a fusionQuality, b fusionQuality) fusionQuality {
	a.NDCGAt10 += b.NDCGAt10
	a.RecallAt100 += b.RecallAt100
	a.MRRAt10 += b.MRRAt10
	a.HitAt1 += b.HitAt1
	return a
}

func divideFusionQuality(q fusionQuality, denom float64) fusionQuality {
	if denom <= 0 {
		return q
	}
	q.NDCGAt10 /= denom
	q.RecallAt100 /= denom
	q.MRRAt10 /= denom
	q.HitAt1 /= denom
	return q
}

func firstRelevantRank(ranking []perQueryTopDoc, rels map[string]float64) int {
	if len(ranking) == 0 {
		return -1
	}
	for i, item := range ranking {
		if rels[item.DocID] > 0 {
			return i + 1
		}
	}
	return 0
}

func topDocID(ranking []perQueryTopDoc) string {
	if len(ranking) == 0 {
		return ""
	}
	return ranking[0].DocID
}

func top1Agree(a string, b string) bool {
	return a != "" && a == b
}

func overlapAtK(a []perQueryTopDoc, b []perQueryTopDoc, k int) int {
	if k <= 0 {
		return 0
	}
	seen := map[string]bool{}
	for i, item := range a {
		if i >= k {
			break
		}
		if item.DocID != "" {
			seen[item.DocID] = true
		}
	}
	overlap := 0
	used := map[string]bool{}
	for i, item := range b {
		if i >= k {
			break
		}
		if item.DocID != "" && seen[item.DocID] && !used[item.DocID] {
			used[item.DocID] = true
			overlap++
		}
	}
	return overlap
}

func sortedQueryIDs(qrels map[string]map[string]float64) []string {
	ids := []string{}
	for queryID := range qrels {
		ids = append(ids, queryID)
	}
	for i := 0; i < len(ids); i++ {
		for j := i + 1; j < len(ids); j++ {
			if ids[j] < ids[i] {
				ids[i], ids[j] = ids[j], ids[i]
			}
		}
	}
	return ids
}

func betterQualityByNDCG(candidate fusionQuality, current fusionQuality, haveCurrent bool) (fusionQuality, bool) {
	if !haveCurrent || candidate.NDCGAt10 > current.NDCGAt10 {
		return candidate, true
	}
	return current, haveCurrent
}

func summarizeFusionCalibration(perQuery []fusionPerQueryRow) fusionCalibrationSummary {
	summary := fusionCalibrationSummary{QueryCount: len(perQuery)}
	if len(perQuery) == 0 {
		return summary
	}
	totalDelta := 0.0
	summary.NDCGAt10MinDeltaVsDirect = perQuery[0].NDCGAt10DeltaVsDirect
	summary.NDCGAt10MaxDeltaVsDirect = perQuery[0].NDCGAt10DeltaVsDirect
	oracleDirectFusionTotal := fusionQuality{}
	oracleDirectTokenFusionTotal := fusionQuality{}
	for _, row := range perQuery {
		delta := row.NDCGAt10DeltaVsDirect
		totalDelta += delta
		if delta > 0 {
			summary.NDCGAt10ImprovedVsDirect++
		} else if delta < 0 {
			summary.NDCGAt10RegressedVsDirect++
		} else {
			summary.NDCGAt10TiedVsDirect++
		}
		if delta < summary.NDCGAt10MinDeltaVsDirect {
			summary.NDCGAt10MinDeltaVsDirect = delta
		}
		if delta > summary.NDCGAt10MaxDeltaVsDirect {
			summary.NDCGAt10MaxDeltaVsDirect = delta
		}
		bestDirectFusion := row.DirectQuality
		bestDirectFusion, _ = betterQualityByNDCG(row.FusionQuality, bestDirectFusion, true)
		oracleDirectFusionTotal = addFusionQuality(oracleDirectFusionTotal, bestDirectFusion)

		bestDirectTokenFusion := row.DirectQuality
		bestDirectTokenFusion, _ = betterQualityByNDCG(row.FusionQuality, bestDirectTokenFusion, true)
		bestDirectTokenFusion, _ = betterQualityByNDCG(row.TokenSpanQuality, bestDirectTokenFusion, true)
		oracleDirectTokenFusionTotal = addFusionQuality(oracleDirectTokenFusionTotal, bestDirectTokenFusion)

		if row.DirectTokenSpanTop1Agree {
			summary.DirectTokenSpanTop1AgreeCount++
		} else {
			summary.DirectTokenSpanTop1DisagreeCount++
		}
		if row.DirectFusionTop1Agree {
			summary.DirectFusionTop1AgreeCount++
		} else {
			summary.DirectFusionTop1DisagreeCount++
		}
	}
	denom := float64(len(perQuery))
	summary.NDCGAt10MeanDeltaVsDirect = totalDelta / denom
	summary.OracleBestDirectOrFusion = divideFusionQuality(oracleDirectFusionTotal, denom)
	summary.OracleBestDirectTokenOrFusion = divideFusionQuality(oracleDirectTokenFusionTotal, denom)
	return summary
}

func writeFusionPerQueryJSONL(path string, rows []fusionPerQueryRow) error {
	var b strings.Builder
	for _, row := range rows {
		data, err := json.Marshal(row)
		if err != nil {
			return err
		}
		b.Write(data)
		b.WriteByte('\n')
	}
	return os.WriteFile(path, []byte(b.String()), 0o644)
}

func rrfFuse(direct []perQueryTopDoc, tokenSpan []perQueryTopDoc, k float64, lambda float64) []perQueryTopDoc {
	scores := map[string]float64{}
	directRank := map[string]int{}
	tokenRank := map[string]int{}
	add := func(ranking []perQueryTopDoc, weight float64, ranks map[string]int) {
		for i, item := range ranking {
			if _, ok := ranks[item.DocID]; ok {
				continue
			}
			rank := i + 1
			ranks[item.DocID] = rank
			scores[item.DocID] += weight / (k + float64(rank))
		}
	}
	add(direct, 1, directRank)
	add(tokenSpan, lambda, tokenRank)
	docs := []string{}
	for docID := range scores {
		docs = append(docs, docID)
	}
	const missingRank = int(^uint(0)>>1) / 4
	for i := 0; i < len(docs); i++ {
		for j := i + 1; j < len(docs); j++ {
			a, b := docs[i], docs[j]
			if fusionLess(b, a, scores, directRank, tokenRank, missingRank) {
				docs[i], docs[j] = docs[j], docs[i]
			}
		}
	}
	out := make([]perQueryTopDoc, 0, len(docs))
	for i, docID := range docs {
		out = append(out, perQueryTopDoc{Rank: i + 1, DocID: docID, Score: scores[docID]})
	}
	return out
}

func fusionLess(a string, b string, scores map[string]float64, directRank map[string]int, tokenRank map[string]int, missingRank int) bool {
	if scores[a] != scores[b] {
		return scores[a] > scores[b]
	}
	ar := rankOrDefault(directRank, a, missingRank)
	br := rankOrDefault(directRank, b, missingRank)
	if ar != br {
		return ar < br
	}
	ar = rankOrDefault(tokenRank, a, missingRank)
	br = rankOrDefault(tokenRank, b, missingRank)
	if ar != br {
		return ar < br
	}
	return a < b
}

func rankOrDefault(ranks map[string]int, id string, fallback int) int {
	if rank, ok := ranks[id]; ok {
		return rank
	}
	return fallback
}

func protectDirectPrefix(direct []perQueryTopDoc, fused []perQueryTopDoc, protectTopK int) []perQueryTopDoc {
	if protectTopK <= 0 {
		return fused
	}
	scoreByDoc := map[string]float64{}
	for _, item := range fused {
		scoreByDoc[item.DocID] = item.Score
	}
	seen := map[string]bool{}
	out := []perQueryTopDoc{}
	for _, item := range direct {
		if len(out) >= protectTopK {
			break
		}
		if seen[item.DocID] {
			continue
		}
		seen[item.DocID] = true
		out = append(out, perQueryTopDoc{Rank: len(out) + 1, DocID: item.DocID, Score: scoreByDoc[item.DocID]})
	}
	for _, item := range fused {
		if seen[item.DocID] {
			continue
		}
		seen[item.DocID] = true
		item.Rank = len(out) + 1
		out = append(out, item)
	}
	return out
}

func classifyDatasetFraming(datasetManifestPath string) datasetFraming {
	repoDocs := datasetFraming{
		ThisLane:        "local repo-docs heuristic-qrels wedge proxy; no official LongEmbed dataset acquisition",
		DirectRowCaveat: "Direct Eos single-vector row over local repo-docs heuristic qrels; not LongEmbed proof.",
		TopLevelCaveats: []string{
			"repo-docs uses deterministic local path/heading qrels and is not an official LongEmbed task.",
			"Official LongEmbed framing includes synthetic needle/passkey tasks across 0.25x-32x1024 token ranges and real NarrativeQA, 2WikiMultihopQA, QMSum, and SummScreenFD tasks; this harness records that framing but does not acquire those datasets.",
		},
	}
	if !fileExists(datasetManifestPath) {
		return repoDocs
	}
	var summary datasetManifestSummary
	if err := readJSON(datasetManifestPath, &summary); err != nil {
		return repoDocs
	}
	if summary.Schema == "eos.longembed.beir.v1" {
		return datasetFraming{
			ThisLane:        "official LongEmbed dataset converted to the repo's BEIR-compatible layout",
			DirectRowCaveat: "Direct Eos single-vector row over official converted LongEmbed dataset; capped smoke/quality_claim=false, not a product-quality claim.",
			TopLevelCaveats: []string{
				"Dataset manifest schema eos.longembed.beir.v1 identifies this lane as an official LongEmbed dataset converted to the repo's BEIR-compatible layout.",
				"quality_claim=false for every row; a capped LongEmbed smoke is acquisition/harness evidence, not a product-quality claim.",
			},
		}
	}
	return repoDocs
}

func multiVectorAggregationLabel(aggregation string, childCountPenalty float64) string {
	label := aggregation
	if childCountPenalty != 0 {
		label += fmt.Sprintf("_penalty_%g", childCountPenalty)
	}
	return label
}

func denseMultiVectorMethod(aggregation string, childCountPenalty float64) string {
	if aggregation == "max" && childCountPenalty == 0 {
		return "dense_child_max"
	}
	return "dense_child_" + multiVectorAggregationLabel(aggregation, childCountPenalty)
}

func appendMultiVectorRows(rows []comparisonRow, baseline string, model string, modelID string, methodPrefix string, artifact string, metricsPath string, mv mvMetrics, dim int, caveat string, aggregation string, childCountPenalty float64) []comparisonRow {
	rows = append(rows, comparisonRow{
		Baseline:        baseline,
		Model:           model,
		Method:          methodPrefix + "_" + denseMultiVectorMethod(aggregation, childCountPenalty),
		Dim:             dim,
		Bits:            0,
		NDCGAt10:        mv.Dense.Quality.NDCGAt10,
		RecallAt100:     mv.Dense.Quality.RecallAt100,
		ChildCount:      mv.Inputs.ChildCount,
		StorageMultiple: mv.Dense.StorageMultipleOfDenseBaseline,
		MetricsPath:     metricsPath,
		Artifact:        artifact,
		ModelID:         modelID,
		QualityClaim:    false,
		Caveats:         caveat,
	})
	for _, bitRow := range mv.Rows {
		compression := 0.0
		if bitRow.StorageMultipleOfDenseBaseline > 0 {
			compression = 1.0 / bitRow.StorageMultipleOfDenseBaseline
		}
		rows = append(rows, comparisonRow{
			Baseline:         baseline,
			Model:            model,
			Method:           methodPrefix + "_" + bitRow.Method,
			Dim:              dim,
			Bits:             bitRow.Bits,
			NDCGAt10:         bitRow.Quality.NDCGAt10,
			RecallAt100:      bitRow.Quality.RecallAt100,
			ChildCount:       mv.Inputs.ChildCount,
			StorageMultiple:  bitRow.StorageMultipleOfDenseBaseline,
			CompressionRatio: compression,
			MetricsPath:      metricsPath,
			Artifact:         artifact,
			ModelID:          modelID,
			QualityClaim:     false,
			Caveats:          caveat,
		})
	}
	return rows
}

func appendSparseEncoderRows(rows []comparisonRow, modelID string, artifact string, denseMetricsPath string, dense retrievalMetrics, tqMetricsPath string, tq tqVectorMetrics, dim int, baselineDim int, caveat string) []comparisonRow {
	baselineBytes := int64(dense.Inputs.Documents * baselineDim * 4)
	denseStorageMultiple := 0.0
	if baselineBytes > 0 {
		denseStorageMultiple = float64(tq.Dense.VectorBytes) / float64(baselineBytes)
	}
	rows = append(rows, comparisonRow{
		Baseline:        "eos",
		Model:           "eos",
		Method:          "sparse_encoder_parent_dense",
		Dim:             dim,
		Bits:            0,
		NDCGAt10:        dense.Quality.NDCGAt10,
		RecallAt100:     dense.Quality.RecallAt100,
		ChildCount:      dense.Inputs.Documents,
		StorageMultiple: denseStorageMultiple,
		MetricsPath:     denseMetricsPath,
		Artifact:        artifact,
		ModelID:         modelID,
		QualityClaim:    false,
		Caveats:         caveat,
	})
	for _, bitRow := range tq.Rows {
		storageMultiple := 0.0
		if baselineBytes > 0 {
			storageMultiple = float64(bitRow.VectorBytes) / float64(baselineBytes)
		}
		rows = append(rows, comparisonRow{
			Baseline:         "eos",
			Model:            "eos",
			Method:           "sparse_encoder_parent_" + bitRow.Method,
			Dim:              dim,
			Bits:             bitRow.Bits,
			NDCGAt10:         bitRow.Quality.NDCGAt10,
			RecallAt100:      bitRow.Quality.RecallAt100,
			ChildCount:       tq.Inputs.Documents,
			StorageMultiple:  storageMultiple,
			CompressionRatio: bitRow.CompressionRatio,
			MetricsPath:      tqMetricsPath,
			Artifact:         artifact,
			ModelID:          modelID,
			QualityClaim:     false,
			Caveats:          caveat,
		})
	}
	return rows
}

func defaultParentSpanFusionRecipes() []parentSpanFusionRecipe {
	return []parentSpanFusionRecipe{
		{Method: "direct_token_span_fusion_rrf_k10_lambda025", RRFK: 10, RRFLambda: 0.25, DenseProtectTopK: 0},
		{Method: "direct_token_span_fusion_dense_protect_n1_rrf_k10_lambda05", RRFK: 10, RRFLambda: 0.5, DenseProtectTopK: 1},
	}
}

func sameParentSpanFusionRecipe(a parentSpanFusionRecipe, b parentSpanFusionRecipe) bool {
	return a.Method == b.Method && a.RRFK == b.RRFK && a.RRFLambda == b.RRFLambda && a.DenseProtectTopK == b.DenseProtectTopK
}

func parentSpanFusionRecipes() ([]parentSpanFusionRecipe, error) {
	recipes := defaultParentSpanFusionRecipes()
	seen := map[string]parentSpanFusionRecipe{}
	for _, recipe := range recipes {
		if recipe.Method == "" {
			return nil, fmt.Errorf("default parent-span fusion recipe has empty method")
		}
		if _, ok := seen[recipe.Method]; ok {
			return nil, fmt.Errorf("duplicate default parent-span fusion method %q", recipe.Method)
		}
		seen[recipe.Method] = recipe
	}

	value := strings.TrimSpace(os.Getenv(parentSpanFusionExtraRecipesEnv))
	if value == "" {
		return recipes, nil
	}
	for index, raw := range strings.Split(value, ";") {
		raw = strings.TrimSpace(raw)
		if raw == "" {
			return nil, fmt.Errorf("%s recipe %d is empty; expected %s", parentSpanFusionExtraRecipesEnv, index+1, parentSpanFusionExtraRecipesFormat)
		}
		recipe, err := parseParentSpanFusionRecipe(raw)
		if err != nil {
			return nil, fmt.Errorf("%s recipe %d invalid: %w; expected %s", parentSpanFusionExtraRecipesEnv, index+1, err, parentSpanFusionExtraRecipesFormat)
		}
		if previous, ok := seen[recipe.Method]; ok {
			// Exact duplicates are idempotent, so rerunning with a repeated
			// default recipe cannot fail after expensive artifacts are built.
			if sameParentSpanFusionRecipe(previous, recipe) {
				continue
			}
			return nil, fmt.Errorf("%s conflicting duplicate method name %q; expected %s", parentSpanFusionExtraRecipesEnv, recipe.Method, parentSpanFusionExtraRecipesFormat)
		}
		seen[recipe.Method] = recipe
		recipes = append(recipes, recipe)
	}
	return recipes, nil
}

func runRecipeSelfTest() error {
	originalValue, hadOriginalValue := os.LookupEnv(parentSpanFusionExtraRecipesEnv)
	defer func() {
		if hadOriginalValue {
			os.Setenv(parentSpanFusionExtraRecipesEnv, originalValue)
		} else {
			os.Unsetenv(parentSpanFusionExtraRecipesEnv)
		}
	}()

	duplicateDefault := "direct_token_span_fusion_dense_protect_n1_rrf_k10_lambda05:10:0.5:1"
	os.Setenv(parentSpanFusionExtraRecipesEnv, duplicateDefault)
	recipes, err := parentSpanFusionRecipes()
	if err != nil {
		return fmt.Errorf("exact duplicate default recipe should be ignored: %w", err)
	}
	if len(recipes) != len(defaultParentSpanFusionRecipes()) {
		return fmt.Errorf("exact duplicate default recipe changed recipe count: got %d want %d", len(recipes), len(defaultParentSpanFusionRecipes()))
	}

	conflictingDefault := "direct_token_span_fusion_dense_protect_n1_rrf_k10_lambda05:10:0.25:1"
	os.Setenv(parentSpanFusionExtraRecipesEnv, conflictingDefault)
	if _, err := parentSpanFusionRecipes(); err == nil {
		return fmt.Errorf("conflicting duplicate default recipe should fail")
	}

	extra := "diagnostic_fusion_rrf:60:0.1:0"
	os.Setenv(parentSpanFusionExtraRecipesEnv, extra+";"+extra)
	recipes, err = parentSpanFusionRecipes()
	if err != nil {
		return fmt.Errorf("exact duplicate extra recipe should be ignored: %w", err)
	}
	if len(recipes) != len(defaultParentSpanFusionRecipes())+1 {
		return fmt.Errorf("exact duplicate extra recipe changed recipe count: got %d want %d", len(recipes), len(defaultParentSpanFusionRecipes())+1)
	}

	os.Setenv(parentSpanFusionExtraRecipesEnv, "diagnostic_fusion_rrf:60:0.1:0;diagnostic_fusion_rrf:60:0.2:0")
	if _, err := parentSpanFusionRecipes(); err == nil {
		return fmt.Errorf("conflicting duplicate extra recipe should fail")
	}

	return nil
}

func parseParentSpanFusionRecipe(value string) (parentSpanFusionRecipe, error) {
	parts := strings.Split(value, ":")
	if len(parts) != 4 {
		return parentSpanFusionRecipe{}, fmt.Errorf("got %d fields", len(parts))
	}
	method := strings.TrimSpace(parts[0])
	if method == "" {
		return parentSpanFusionRecipe{}, fmt.Errorf("method/name must be non-empty")
	}
	rrfK, err := strconv.ParseFloat(strings.TrimSpace(parts[1]), 64)
	if err != nil {
		return parentSpanFusionRecipe{}, fmt.Errorf("k must be a finite float > 0")
	}
	if math.IsNaN(rrfK) || math.IsInf(rrfK, 0) || rrfK <= 0 {
		return parentSpanFusionRecipe{}, fmt.Errorf("k must be finite and > 0")
	}
	rrfLambda, err := strconv.ParseFloat(strings.TrimSpace(parts[2]), 64)
	if err != nil {
		return parentSpanFusionRecipe{}, fmt.Errorf("lambda must be a finite float >= 0")
	}
	if math.IsNaN(rrfLambda) || math.IsInf(rrfLambda, 0) || rrfLambda < 0 {
		return parentSpanFusionRecipe{}, fmt.Errorf("lambda must be finite and >= 0")
	}
	protect, err := strconv.Atoi(strings.TrimSpace(parts[3]))
	if err != nil {
		return parentSpanFusionRecipe{}, fmt.Errorf("protect must be an integer >= 0")
	}
	if protect < 0 {
		return parentSpanFusionRecipe{}, fmt.Errorf("protect must be >= 0")
	}
	return parentSpanFusionRecipe{
		Method:           method,
		RRFK:             rrfK,
		RRFLambda:        rrfLambda,
		DenseProtectTopK: protect,
	}, nil
}

func appendParentSpanFusionRows(rows []comparisonRow, skipped []string, perQueryPaths map[string]string, datasetName string, datasetDir string, runDir string, directPerQueryPath string, tokenSpanPerQueryPath string, tokenSpanMethod string, dim int, artifact string, modelID string, tokenSpanChildCount int, directParentCount int, tokenSpanQ4StorageMultiple float64, directParentDenseStorageMultiple float64, bits string, fusionEnabled bool) ([]comparisonRow, []string, error) {
	if !fusionEnabled {
		skipped = append(skipped, "direct+token-span diagnostic fusion disabled by EOS_LC_WEDGE_PARENT_SPAN_FUSION=0")
		return rows, skipped, nil
	}
	if !bitsIncludeQ4(bits) {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: EOS_LC_WEDGE_BITS does not include q4")
		return rows, skipped, nil
	}
	if tokenSpanQ4StorageMultiple <= 0 {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: token-span q4 storage_multiple_of_dense_baseline missing")
		return rows, skipped, nil
	}
	if directParentDenseStorageMultiple <= 0 || directParentCount <= 0 {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: direct parent dense storage context missing")
		return rows, skipped, nil
	}
	if !fileExists(directPerQueryPath) {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: direct Eos per-query JSONL missing")
		return rows, skipped, nil
	}
	if !fileExists(tokenSpanPerQueryPath) {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: token-span q4 per-query JSONL missing")
		return rows, skipped, nil
	}
	qrels, err := readQrels(filepath.Join(datasetDir, "qrels", "test.tsv"))
	if err != nil {
		return rows, skipped, err
	}
	directRows, err := readDirectPerQuery(directPerQueryPath)
	if err != nil {
		return rows, skipped, err
	}
	tokenSpanRows, err := readTokenSpanPerQuery(tokenSpanPerQueryPath, tokenSpanMethod)
	if err != nil {
		return rows, skipped, err
	}
	if len(tokenSpanRows) == 0 {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: token-span q4 method "+tokenSpanMethod+" not found in per-query JSONL")
		return rows, skipped, nil
	}
	fusionQrels := map[string]map[string]float64{}
	for queryID, rels := range qrels {
		if _, ok := directRows[queryID]; !ok {
			continue
		}
		if _, ok := tokenSpanRows[queryID]; !ok {
			continue
		}
		fusionQrels[queryID] = rels
	}
	if len(fusionQrels) == 0 {
		skipped = append(skipped, "direct+token-span diagnostic fusion skipped: no overlapping qrels/direct/token-span per-query rows")
		return rows, skipped, nil
	}
	fusionDefs, err := parentSpanFusionRecipes()
	if err != nil {
		return rows, skipped, err
	}
	metricsRows := []fusionMetricsRow{}
	caveats := []string{
		"Diagnostic fusion only; not product default.",
		"Fuses direct Eos single-vector per-query top-k with Eos token-span q4 multivector per-query top-k.",
		"Storage estimates q4 token-span child cache plus one dense direct parent vector per parent against baseline_dim; excludes live encoder/runtime cost.",
		"quality_claim=false; row is harness evidence only.",
	}
	storageMultiple := tokenSpanQ4StorageMultiple + directParentDenseStorageMultiple
	compressionRatio := 0.0
	if storageMultiple > 0 {
		compressionRatio = 1.0 / storageMultiple
	}
	fusionChildCount := tokenSpanChildCount + directParentCount
	queryIDs := sortedQueryIDs(fusionQrels)
	perQueryRows := []fusionPerQueryRow{}
	for _, def := range fusionDefs {
		fusedByQuery := map[string][]perQueryTopDoc{}
		defPerQueryRows := []fusionPerQueryRow{}
		for _, queryID := range queryIDs {
			rels := fusionQrels[queryID]
			directRanking := directRows[queryID]
			tokenRanking := tokenSpanRows[queryID]
			fused := rrfFuse(directRanking, tokenRanking, def.RRFK, def.RRFLambda)
			if def.DenseProtectTopK > 0 {
				fused = protectDirectPrefix(directRanking, fused, def.DenseProtectTopK)
			}
			fusedByQuery[queryID] = fused
			directQuality := rankingQuality(directRanking, rels)
			tokenSpanQuality := rankingQuality(tokenRanking, rels)
			fusionQuality := rankingQuality(fused, rels)
			directTopDocID := topDocID(directRanking)
			tokenSpanTopDocID := topDocID(tokenRanking)
			fusionTopDocID := topDocID(fused)
			defPerQueryRows = append(defPerQueryRows, fusionPerQueryRow{
				Schema:                     "eos.long_context_wedge_parent_span_fusion_per_query.v1",
				Dataset:                    datasetName,
				QueryID:                    queryID,
				Method:                     def.Method,
				DirectMethod:               "direct_single_vector",
				TokenSpanMethod:            tokenSpanMethod,
				RRFK:                       def.RRFK,
				RRFLambda:                  def.RRFLambda,
				DenseProtectTopK:           def.DenseProtectTopK,
				DirectQuality:              directQuality,
				TokenSpanQuality:           tokenSpanQuality,
				FusionQuality:              fusionQuality,
				NDCGAt10DeltaVsDirect:      fusionQuality.NDCGAt10 - directQuality.NDCGAt10,
				NDCGAt10DeltaVsTokenSpan:   fusionQuality.NDCGAt10 - tokenSpanQuality.NDCGAt10,
				HitAt1DeltaVsDirect:        fusionQuality.HitAt1 - directQuality.HitAt1,
				HitAt1DeltaVsTokenSpan:     fusionQuality.HitAt1 - tokenSpanQuality.HitAt1,
				DirectFirstRelevantRank:    firstRelevantRank(directRanking, rels),
				TokenSpanFirstRelevantRank: firstRelevantRank(tokenRanking, rels),
				FusionFirstRelevantRank:    firstRelevantRank(fused, rels),
				DirectTopDocID:             directTopDocID,
				TokenSpanTopDocID:          tokenSpanTopDocID,
				FusionTopDocID:             fusionTopDocID,
				TopK:                       topKWithRelevance(fused, rels, len(fused)),
				DirectTokenSpanTop1Agree:   top1Agree(directTopDocID, tokenSpanTopDocID),
				DirectFusionTop1Agree:      top1Agree(directTopDocID, fusionTopDocID),
				DirectTokenSpanOverlapAt10: overlapAtK(directRanking, tokenRanking, 10),
				QualityClaim:               false,
				Caveats:                    caveats,
			})
		}
		perQueryRows = append(perQueryRows, defPerQueryRows...)
		quality, queryCount, err := aggregateFusionQuality(fusedByQuery, fusionQrels)
		if err != nil {
			return rows, skipped, err
		}
		rows = append(rows, comparisonRow{
			Baseline:        "eos",
			Model:           "eos",
			Method:          def.Method,
			Dim:             dim,
			Bits:            4,
			NDCGAt10:        quality.NDCGAt10,
			RecallAt100:     quality.RecallAt100,
			ChildCount:      fusionChildCount,
			StorageMultiple: storageMultiple,
			CompressionRatio: compressionRatio,
			MetricsPath:     filepath.Join(runDir, "direct-token-span-fusion.metrics.json"),
			Artifact:        artifact,
			ModelID:         modelID,
			QualityClaim:    false,
			Caveats:         strings.Join(caveats, " "),
		})
		metricsRows = append(metricsRows, fusionMetricsRow{
			Method:           def.Method,
			DirectMethod:     "direct_single_vector",
			TokenSpanMethod:  tokenSpanMethod,
			RRFK:             def.RRFK,
			RRFLambda:        def.RRFLambda,
			DenseProtectTopK: def.DenseProtectTopK,
			Quality:          quality,
			QueryCount:       queryCount,
			Calibration:      summarizeFusionCalibration(defPerQueryRows),
			Caveats:          caveats,
		})
	}
	metricsPath := filepath.Join(runDir, "direct-token-span-fusion.metrics.json")
	perQueryPath := filepath.Join(runDir, "direct-token-span-fusion.per-query.jsonl")
	if err := writeFusionPerQueryJSONL(perQueryPath, perQueryRows); err != nil {
		return rows, skipped, err
	}
	if err := writeJSON(metricsPath, fusionMetricsFile{
		Schema:            "eos.long_context_wedge_parent_span_fusion_metrics.v1",
		Dataset:           datasetName,
		QualityClaim:      false,
		DirectPerQuery:    directPerQueryPath,
		TokenSpanPerQuery: tokenSpanPerQueryPath,
		TokenSpanMethod:   tokenSpanMethod,
		Rows:              metricsRows,
		Caveats:           caveats,
	}); err != nil {
		return rows, skipped, err
	}
	perQueryPaths["direct-token-span-fusion"] = perQueryPath
	perQueryPaths["direct-token-span-fusion-metrics"] = metricsPath
	return rows, skipped, nil
}

func validateSparseEncoderManifest(path string, m sparseEncoderExportManifest) error {
	if m.Method != "experimental_sparse_encoder_host_reference" {
		return fmt.Errorf("sparse encoder manifest method=%q, want experimental_sparse_encoder_host_reference", m.Method)
	}
	if m.EvidenceLevel != "retrieval_cache_host_reference_sparse_encoder" {
		return fmt.Errorf("sparse encoder manifest evidence_level=%q, want retrieval_cache_host_reference_sparse_encoder", m.EvidenceLevel)
	}
	if m.QualityClaim {
		return fmt.Errorf("sparse encoder manifest quality_claim=true, want false")
	}
	if !m.RequireFullEncoder {
		return fmt.Errorf("sparse encoder manifest require_full_encoder=false, want true")
	}
	if !m.FullEncoderApplied {
		return fmt.Errorf("sparse encoder manifest full_encoder_applied=false, want true")
	}
	if m.DocVectorPath == "" {
		return fmt.Errorf("sparse encoder manifest missing doc_vector_path: %s", path)
	}
	if m.QueryVectorPath == "" {
		return fmt.Errorf("sparse encoder manifest missing query_vector_path: %s", path)
	}
	return nil
}

func sparseEncoderAuditFields(path string, m sparseEncoderExportManifest) map[string]string {
	return map[string]string{
		"manifest":                                  path,
		"sparse_top_k_configured":                   strconv.Itoa(m.SparseTopKConfigured),
		"sparse_top_k":                              strconv.Itoa(m.SparseTopK),
		"sparse_top_k_effective_max_observed_doc":   strconv.Itoa(m.SparseTopKEffectiveMaxObservedDoc),
		"score_fraction_max_observed_doc":           strconv.FormatFloat(m.ScoreFractionMaxObservedDoc, 'g', -1, 64),
		"subquadratic_score_plan_max_observed_doc":  strconv.FormatBool(m.SubquadraticScorePlanMaxObservedDoc),
		"candidate_key_budget_max_observed_doc":     strconv.Itoa(m.CandidateKeyBudgetMaxObservedDoc),
		"source_manifest_carries_sparse_plan_audit": "true",
	}
}

func appendCaps(args []string, maxDocs int, maxQueries int) []string {
	if maxDocs > 0 {
		args = append(args, "--max-docs", strconv.Itoa(maxDocs))
	}
	if maxQueries > 0 {
		args = append(args, "--max-queries", strconv.Itoa(maxQueries))
	}
	return args
}

func directModelDimension(sparseManifest sparseExportManifest, fallback int) int {
	if sparseManifest.ModelDimension > 0 {
		return sparseManifest.ModelDimension
	}
	if fallback > 0 {
		return fallback
	}
	if sparseManifest.OutputDimension > 0 {
		return sparseManifest.OutputDimension
	}
	return sparseManifest.Dimension
}

func evaluateExternal(root string, eosBin string, datasetName string, datasetDir string, runDir string, logDir string, commands []commandRecord, rows []comparisonRow, skipped []string, perQueryPaths map[string]string, preset string, modelID string, cacheRoot string, externalMode string, bits string, baselineDim int, outputDim int, chunkWords int, chunkOverlap int, topK int, python string, maxDocs int, maxQueries int, aggregation string, childCountPenalty float64, emitPerQuery bool) ([]commandRecord, []comparisonRow, []string, error) {
	cacheRoot = absUnder(root, cacheRoot)
	cacheDir := filepath.Join(cacheRoot, datasetName)
	childVectors := filepath.Join(cacheDir, "child-doc-vectors.jsonl")
	queryVectors := filepath.Join(cacheDir, "query-vectors.jsonl")
	manifestPath := filepath.Join(cacheDir, "manifest.json")
	if externalMode == "export" {
		exportArgs := []string{
			filepath.Join(root, "scripts", "export_retrieval_vectors.py"),
			"--preset", preset,
			"--dataset-dir", datasetDir,
			"--dataset-name", datasetName,
			"--output-root", cacheRoot,
			"--output-dim", strconv.Itoa(outputDim),
			"--document-chunk-words", strconv.Itoa(chunkWords),
			"--document-chunk-overlap", strconv.Itoa(chunkOverlap),
			"--document-chunk-min-words", "16",
			"--batch-size", getenv("EOS_LC_WEDGE_EXTERNAL_BATCH_SIZE", "8"),
		}
		exportArgs = appendCaps(exportArgs, maxDocs, maxQueries)
		rec, err := runCmd(root, "Export external "+preset+" child vectors", filepath.Join(logDir, "export-external-"+preset+".log"), python, exportArgs)
		commands = append(commands, rec)
		if err != nil {
			return commands, rows, skipped, err
		}
	}
	if !fileExists(childVectors) || !fileExists(queryVectors) {
		skipped = append(skipped, preset+": cache missing and external export disabled")
		return commands, rows, skipped, nil
	}
	dim := outputDim
	if fileExists(manifestPath) {
		var ext externalExportManifest
		if err := readJSON(manifestPath, &ext); err == nil && ext.OutputDim > 0 {
			dim = ext.OutputDim
		}
	}
	metricsPath := filepath.Join(runDir, "external-"+preset+"-multivector-turboquant.metrics.json")
	metricsTSV := filepath.Join(runDir, "external-"+preset+"-multivector-turboquant.metrics.tsv")
	evalArgs := []string{
		"eval-retrieval-multivector-turboquant",
		"--dataset", datasetName,
		"--backend", preset+"-128d-child",
		"--artifact", modelID,
		"--doc-vectors", childVectors,
		"--query-vectors", queryVectors,
		"--bits", bits,
		"--top-k", strconv.Itoa(topK),
		"--baseline-dim", strconv.Itoa(baselineDim),
		"--aggregation", aggregation,
		"--child-count-penalty", strconv.FormatFloat(childCountPenalty, 'g', -1, 64),
		"--metrics-json", metricsPath,
		"--metrics-tsv", metricsTSV,
	}
	if emitPerQuery {
		perQueryPath := filepath.Join(runDir, "external-"+preset+"-multivector-turboquant.per-query.jsonl")
		evalArgs = append(evalArgs, "--per-query-jsonl", perQueryPath)
		perQueryPaths["external-"+preset+"-multivector-turboquant"] = perQueryPath
	}
	evalArgs = appendCaps(evalArgs, maxDocs, maxQueries)
	evalArgs = append(evalArgs, datasetDir)
	rec, err := runCmd(root, "Evaluate external "+preset+" multivector TurboQuant", filepath.Join(logDir, "eval-external-"+preset+".log"), eosBin, evalArgs)
	commands = append(commands, rec)
	if err != nil {
		return commands, rows, skipped, err
	}
	var mv mvMetrics
	if err := readJSON(metricsPath, &mv); err != nil {
		return commands, rows, skipped, err
	}
	caveat := "External chunked child-vector baseline; opt-in cache/export row, not LongEmbed proof."
	rows = appendMultiVectorRows(rows, "external_chunked", preset, modelID, "chunk96_overlap16", modelID, metricsPath, mv, dim, caveat, aggregation, childCountPenalty)
	return commands, rows, skipped, nil
}

func main() {
	if parseBoolEnv("EOS_LC_WEDGE_RECIPE_SELF_TEST") {
		if err := runRecipeSelfTest(); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		fmt.Println("parent-span fusion recipe self-test passed")
		return
	}

	root, err := findRoot()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	timestamp := time.Now().UTC().Format("20060102T150405Z")
	runDir := absUnder(root, getenv("EOS_LC_WEDGE_RUN_DIR", filepath.Join("runs", "eos-long-context-wedge-harness-v1-"+timestamp)))
	logDir := filepath.Join(runDir, "logs")
	binDir := filepath.Join(runDir, "bin")
	vectorDir := filepath.Join(runDir, "vectors")
	for _, dir := range []string{runDir, logDir, binDir, vectorDir} {
		if err := os.MkdirAll(dir, 0o755); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
	}

	datasetName := getenv("EOS_LC_WEDGE_DATASET_NAME", "repo-docs")
	datasetDir := absUnder(root, getenv("EOS_LC_WEDGE_DATASET_DIR", filepath.Join("datasets", "longembed", datasetName)))
	datasetManifestPath := filepath.Join(datasetDir, "dataset-manifest.json")
	commands := []commandRecord{}
	perQueryPaths := map[string]string{}
	if !fileExists(filepath.Join(datasetDir, "corpus.jsonl")) || !fileExists(filepath.Join(datasetDir, "queries.jsonl")) || !fileExists(filepath.Join(datasetDir, "qrels", "test.tsv")) {
		rec, err := runCmd(root, "Build repo-docs long dataset", filepath.Join(logDir, "build-repo-docs-dataset.log"), "ferrous-wheel", []string{"run", filepath.Join(root, "scripts", "build_repo_docs_longembed_dataset.fw")})
		commands = append(commands, rec)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
	}
	if !fileExists(filepath.Join(datasetDir, "corpus.jsonl")) || !fileExists(filepath.Join(datasetDir, "queries.jsonl")) || !fileExists(filepath.Join(datasetDir, "qrels", "test.tsv")) {
		fmt.Fprintf(os.Stderr, "required BEIR-shaped dataset files missing under %s\n", datasetDir)
		os.Exit(1)
	}
	datasetFraming := classifyDatasetFraming(datasetManifestPath)

	eosBin := filepath.Join(binDir, "eos")
	rec, err := runCmd(root, "Build eos CLI", filepath.Join(logDir, "go-build-eos.log"), "go", []string{"build", "-trimpath", "-o", eosBin, "./cmd/eos"})
	commands = append(commands, rec)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	artifact := absUnder(root, getenv("EOS_LC_WEDGE_ARTIFACT", defaultArtifact(root)))
	if !fileExists(artifact) {
		fmt.Fprintf(os.Stderr, "required Eos artifact missing: %s\n", artifact)
		os.Exit(1)
	}
	evalArtifact := artifact
	retargetMaxSeq, err := parseIntEnv("EOS_LC_WEDGE_RETARGET_MAX_SEQ", 1024)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if retargetMaxSeq > 0 {
		evalArtifact = filepath.Join(runDir, "eos-long-context-wedge-maxseq"+strconv.Itoa(retargetMaxSeq)+".mll")
		rec, err = runCmd(root, "Retarget Eos artifact max-seq", filepath.Join(logDir, "rename-embed.log"), eosBin, []string{
			"rename-embed",
			"--name", "eos-long-context-wedge-maxseq" + strconv.Itoa(retargetMaxSeq),
			"--max-seq", strconv.Itoa(retargetMaxSeq),
			artifact,
			evalArtifact,
		})
		commands = append(commands, rec)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
	}
	if !fileExists(siblingWeightPath(evalArtifact)) {
		fmt.Fprintf(os.Stderr, "required sibling weights for sparse-token-span export are missing: %s\n", siblingWeightPath(evalArtifact))
		os.Exit(1)
	}

	topK, _ := parseIntEnv("EOS_LC_WEDGE_TOP_K", 100)
	maxDocs, _ := parseIntEnv("EOS_LC_WEDGE_MAX_DOCS", 0)
	maxQueries, _ := parseIntEnv("EOS_LC_WEDGE_MAX_QUERIES", 0)
	outputDim, _ := parseIntEnv("EOS_LC_WEDGE_OUTPUT_DIM", 128)
	baselineDim, _ := parseIntEnv("EOS_LC_WEDGE_BASELINE_DIM", 1024)
	tokenSpan, _ := parseIntEnv("EOS_LC_WEDGE_TOKEN_SPAN", 48)
	tokenOverlap, _ := parseIntEnv("EOS_LC_WEDGE_TOKEN_OVERLAP", 12)
	maxTokens, _ := parseIntEnv("EOS_LC_WEDGE_MAX_TOKENS", retargetMaxSeq)
	minObservedTokens, _ := parseIntEnv("EOS_LC_WEDGE_MIN_OBSERVED_DOC_TOKENS", 512)
	sparseTopK, _ := parseIntEnv("EOS_LC_WEDGE_SPARSE_TOP_K", 256)
	tokenSpanResume := enabledByDefaultEnv("EOS_LC_WEDGE_TOKEN_SPAN_RESUME")
	tokenSpanProgressEvery, _ := parseIntEnv("EOS_LC_WEDGE_TOKEN_SPAN_PROGRESS_EVERY", 10)
	quantizerSeed, err := parseInt64Env("EOS_LC_WEDGE_QUANTIZER_SEED", defaultQuantizerSeed)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	bits := getenv("EOS_LC_WEDGE_BITS", "2,4,8")
	fusionEnabled := parentSpanFusionEnabled()
	parentAggregation, err := parseParentAggregationEnv()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	childCountPenalty, err := parseFloatEnv("EOS_LC_WEDGE_CHILD_COUNT_PENALTY", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	emitPerQuery := perQueryEnabled()
	emitFusionPerQuery := fusionEnabled && bitsIncludeQ4(bits)
	if math.IsNaN(childCountPenalty) || math.IsInf(childCountPenalty, 0) || childCountPenalty < 0 {
		fmt.Fprintln(os.Stderr, "EOS_LC_WEDGE_CHILD_COUNT_PENALTY must be a finite non-negative float")
		os.Exit(1)
	}

	directMetrics := filepath.Join(runDir, "direct-eos.metrics.json")
	directPerQueryPath := filepath.Join(runDir, "direct-eos.per-query.jsonl")
	directArgs := []string{
		"eval-retrieval",
		"--dataset", datasetName,
		"--top-k", strconv.Itoa(topK),
		"--metrics-json", directMetrics,
	}
	if emitPerQuery || emitFusionPerQuery {
		directArgs = append(directArgs, "--per-query-jsonl", directPerQueryPath)
		perQueryPaths["direct-eos"] = directPerQueryPath
	}
	directArgs = appendCaps(directArgs, maxDocs, maxQueries)
	directArgs = append(directArgs, evalArtifact, datasetDir)
	rec, err = runCmd(root, "Evaluate direct single-vector Eos", filepath.Join(logDir, "direct-eos.log"), eosBin, directArgs)
	commands = append(commands, rec)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	var direct retrievalMetrics
	if err := readJSON(directMetrics, &direct); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	sparseDir := filepath.Join(vectorDir, "eos-token-span")
	sparseManifestPath := filepath.Join(sparseDir, "manifest.json")
	exportSparseArgs := []string{
		"export-sparse-token-pool-vectors",
		"--dataset", datasetName,
		"--output-dim", strconv.Itoa(outputDim),
		"--token-span-tokens", strconv.Itoa(tokenSpan),
		"--token-span-overlap", strconv.Itoa(tokenOverlap),
		"--token-span-min-tokens", "1",
		"--max-tokens", strconv.Itoa(maxTokens),
		"--min-observed-doc-tokens", strconv.Itoa(minObservedTokens),
		"--top-k", strconv.Itoa(sparseTopK),
		"--bits", "4",
		"--seed", strconv.FormatInt(quantizerSeed, 10),
		"--progress-every", strconv.Itoa(tokenSpanProgressEvery),
		"--manifest-json", sparseManifestPath,
	}
	if tokenSpanResume {
		exportSparseArgs = append(exportSparseArgs, "--resume")
	}
	exportSparseArgs = appendCaps(exportSparseArgs, maxDocs, maxQueries)
	exportSparseArgs = append(exportSparseArgs, evalArtifact, datasetDir, sparseDir)
	rec, err = runCmd(root, "Export Eos sparse-token-span child vectors", filepath.Join(logDir, "export-eos-token-span.log"), eosBin, exportSparseArgs)
	commands = append(commands, rec)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	var sparseManifest sparseExportManifest
	if err := readJSON(sparseManifestPath, &sparseManifest); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if sparseManifest.QualityClaim {
		fmt.Fprintln(os.Stderr, "sparse export manifest unexpectedly has quality_claim=true")
		os.Exit(1)
	}

	sparseMetrics := filepath.Join(runDir, "eos-token-span-multivector-turboquant.metrics.json")
	sparseTSV := filepath.Join(runDir, "eos-token-span-multivector-turboquant.metrics.tsv")
	tokenSpanPerQueryPath := filepath.Join(runDir, "eos-token-span-multivector-turboquant.per-query.jsonl")
	evalSparseArgs := []string{
		"eval-retrieval-multivector-turboquant",
		"--dataset", datasetName,
		"--backend", "eos-sparse-token-span-128d",
		"--artifact", filepath.Base(evalArtifact),
		"--doc-vectors", filepath.Join(sparseDir, "child-doc-vectors.jsonl"),
		"--query-vectors", filepath.Join(sparseDir, "query-vectors.jsonl"),
		"--bits", bits,
		"--quantizer-seed", strconv.FormatInt(quantizerSeed, 10),
		"--top-k", strconv.Itoa(topK),
		"--baseline-dim", strconv.Itoa(baselineDim),
		"--aggregation", parentAggregation,
		"--child-count-penalty", strconv.FormatFloat(childCountPenalty, 'g', -1, 64),
		"--metrics-json", sparseMetrics,
		"--metrics-tsv", sparseTSV,
	}
	if emitPerQuery || emitFusionPerQuery {
		evalSparseArgs = append(evalSparseArgs, "--per-query-jsonl", tokenSpanPerQueryPath)
		perQueryPaths["eos-token-span-multivector-turboquant"] = tokenSpanPerQueryPath
	}
	evalSparseArgs = appendCaps(evalSparseArgs, maxDocs, maxQueries)
	evalSparseArgs = append(evalSparseArgs, datasetDir)
	rec, err = runCmd(root, "Evaluate Eos sparse-token-span multivector TurboQuant", filepath.Join(logDir, "eval-eos-token-span.log"), eosBin, evalSparseArgs)
	commands = append(commands, rec)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	var sparseMV mvMetrics
	if err := readJSON(sparseMetrics, &sparseMV); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	sparseEncoderManifestPath := ""
	sparseEncoderAudit := map[string]string(nil)
	var sparseEncoderDense retrievalMetrics
	var sparseEncoderTQ tqVectorMetrics
	sparseEncoderDenseMetrics := ""
	sparseEncoderTQMetrics := ""
	sparseEncoderDim := 0
	if sparseEncoderEnabled() {
		sparseEncoderDir := filepath.Join(vectorDir, "eos-sparse-encoder-parent")
		sparseEncoderManifestPath = filepath.Join(sparseEncoderDir, "manifest.json")
		exportSparseEncoderArgs := []string{
			"export-sparse-encoder-vectors",
			"--dataset", datasetName,
			"--output-dim", strconv.Itoa(outputDim),
			"--max-tokens", strconv.Itoa(maxTokens),
			"--min-observed-doc-tokens", strconv.Itoa(minObservedTokens),
			"--top-k", strconv.Itoa(sparseTopK),
			"--bits", "4",
			"--seed", strconv.FormatInt(quantizerSeed, 10),
			"--manifest-json", sparseEncoderManifestPath,
		}
		exportSparseEncoderArgs = appendCaps(exportSparseEncoderArgs, maxDocs, maxQueries)
		exportSparseEncoderArgs = append(exportSparseEncoderArgs, evalArtifact, datasetDir, sparseEncoderDir)
		rec, err = runCmd(root, "Export Eos sparse-encoder parent vectors", filepath.Join(logDir, "export-eos-sparse-encoder-parent.log"), eosBin, exportSparseEncoderArgs)
		commands = append(commands, rec)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		var sparseEncoderManifest sparseEncoderExportManifest
		if err := readJSON(sparseEncoderManifestPath, &sparseEncoderManifest); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		if err := validateSparseEncoderManifest(sparseEncoderManifestPath, sparseEncoderManifest); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		sparseEncoderAudit = sparseEncoderAuditFields(sparseEncoderManifestPath, sparseEncoderManifest)
		sparseEncoderDim = sparseEncoderManifest.OutputDimension
		if sparseEncoderDim <= 0 {
			sparseEncoderDim = sparseEncoderManifest.Dimension
		}

		sparseEncoderDenseMetrics = filepath.Join(runDir, "eos-sparse-encoder-parent-dense.metrics.json")
		evalSparseEncoderDenseArgs := []string{
			"eval-retrieval-vectors",
			"--dataset", datasetName,
			"--backend", "eos-sparse-encoder-parent-128d",
			"--artifact", filepath.Base(evalArtifact),
			"--doc-vectors", filepath.Join(sparseEncoderDir, "doc-vectors.jsonl"),
			"--query-vectors", filepath.Join(sparseEncoderDir, "query-vectors.jsonl"),
			"--top-k", strconv.Itoa(topK),
			"--metrics-json", sparseEncoderDenseMetrics,
		}
		if emitPerQuery {
			perQueryPath := filepath.Join(runDir, "eos-sparse-encoder-parent-dense.per-query.jsonl")
			evalSparseEncoderDenseArgs = append(evalSparseEncoderDenseArgs, "--per-query-jsonl", perQueryPath)
			perQueryPaths["eos-sparse-encoder-parent-dense"] = perQueryPath
		}
		evalSparseEncoderDenseArgs = appendCaps(evalSparseEncoderDenseArgs, maxDocs, maxQueries)
		evalSparseEncoderDenseArgs = append(evalSparseEncoderDenseArgs, datasetDir)
		rec, err = runCmd(root, "Evaluate Eos sparse-encoder parent dense vectors", filepath.Join(logDir, "eval-eos-sparse-encoder-parent-dense.log"), eosBin, evalSparseEncoderDenseArgs)
		commands = append(commands, rec)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		if err := readJSON(sparseEncoderDenseMetrics, &sparseEncoderDense); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}

		sparseEncoderTQMetrics = filepath.Join(runDir, "eos-sparse-encoder-parent-turboquant.metrics.json")
		sparseEncoderTQTSV := filepath.Join(runDir, "eos-sparse-encoder-parent-turboquant.metrics.tsv")
		evalSparseEncoderTQArgs := []string{
			"eval-retrieval-vectors-turboquant",
			"--dataset", datasetName,
			"--backend", "eos-sparse-encoder-parent-128d",
			"--artifact", filepath.Base(evalArtifact),
			"--doc-vectors", filepath.Join(sparseEncoderDir, "doc-vectors.jsonl"),
			"--query-vectors", filepath.Join(sparseEncoderDir, "query-vectors.jsonl"),
			"--bits", bits,
			"--quantizer-seed", strconv.FormatInt(quantizerSeed, 10),
			"--top-k", strconv.Itoa(topK),
			"--metrics-json", sparseEncoderTQMetrics,
			"--metrics-tsv", sparseEncoderTQTSV,
		}
		evalSparseEncoderTQArgs = appendCaps(evalSparseEncoderTQArgs, maxDocs, maxQueries)
		evalSparseEncoderTQArgs = append(evalSparseEncoderTQArgs, datasetDir)
		rec, err = runCmd(root, "Evaluate Eos sparse-encoder parent TurboQuant", filepath.Join(logDir, "eval-eos-sparse-encoder-parent-turboquant.log"), eosBin, evalSparseEncoderTQArgs)
		commands = append(commands, rec)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		if err := readJSON(sparseEncoderTQMetrics, &sparseEncoderTQ); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		if sparseEncoderTQ.Config.QuantizerSeed != quantizerSeed {
			fmt.Fprintf(os.Stderr, "sparse encoder TurboQuant quantizer_seed=%d, want %d\n", sparseEncoderTQ.Config.QuantizerSeed, quantizerSeed)
			os.Exit(1)
		}
	}

	rows := []comparisonRow{{
		Baseline:     "eos",
		Model:        "eos",
		Method:       "direct_single_vector",
		Dim:          directModelDimension(sparseManifest, baselineDim),
		Bits:         0,
		NDCGAt10:     direct.Quality.NDCGAt10,
		RecallAt100:  direct.Quality.RecallAt100,
		ChildCount:   direct.Inputs.Documents,
		MetricsPath:  directMetrics,
		Artifact:     evalArtifact,
		ModelID:      filepath.Base(evalArtifact),
		QualityClaim: false,
		Caveats:      datasetFraming.DirectRowCaveat,
	}}
	rows = appendMultiVectorRows(rows, "eos", "eos", filepath.Base(evalArtifact), fmt.Sprintf("sparse_token_span_%d_%d", tokenSpan, tokenOverlap), evalArtifact, sparseMetrics, sparseMV, sparseManifest.OutputDimension, "Experimental sparse-token-pool token-span child vectors; quality_claim=false; not trained long-context encoder evidence.", parentAggregation, childCountPenalty)
	if sparseEncoderEnabled() {
		rows = appendSparseEncoderRows(rows, filepath.Base(evalArtifact), evalArtifact, sparseEncoderDenseMetrics, sparseEncoderDense, sparseEncoderTQMetrics, sparseEncoderTQ, sparseEncoderDim, baselineDim, "Experimental sparse-encoder parent vectors from host-reference retrieval cache; quality_claim=false; not trained LongEmbed proof, sealed sparse runtime inference, or production quality.")
	}

	externalMode := strings.ToLower(getenv("EOS_LC_WEDGE_EXTERNAL_MODE", "off"))
	skipped := []string{}
	tokenSpanQ4Method := "turboquant_ip_b4_child_" + multiVectorAggregationLabel(parentAggregation, childCountPenalty)
	tokenSpanQ4StorageMultiple, _ := multiVectorStorageMultipleForBits(sparseMV, 4)
	directStorageBaselineDim := sparseMV.Config.BaselineDim
	if directStorageBaselineDim <= 0 {
		directStorageBaselineDim = baselineDim
	}
	directStorageMultiple := directParentDenseStorageMultiple(directModelDimension(sparseManifest, baselineDim), directStorageBaselineDim)
	rows, skipped, err = appendParentSpanFusionRows(rows, skipped, perQueryPaths, datasetName, datasetDir, runDir, directPerQueryPath, tokenSpanPerQueryPath, tokenSpanQ4Method, sparseManifest.OutputDimension, evalArtifact, filepath.Base(evalArtifact), sparseMV.Inputs.ChildCount, direct.Inputs.Documents, tokenSpanQ4StorageMultiple, directStorageMultiple, bits, fusionEnabled)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	switch externalMode {
	case "off":
		skipped = append(skipped, "external baselines disabled by EOS_LC_WEDGE_EXTERNAL_MODE=off")
	case "cache", "export":
		python := getenv("EOS_LC_WEDGE_EXTERNAL_PYTHON", "python3")
		chunkWords, _ := parseIntEnv("EOS_LC_WEDGE_EXTERNAL_CHUNK_WORDS", 96)
		chunkOverlap, _ := parseIntEnv("EOS_LC_WEDGE_EXTERNAL_CHUNK_OVERLAP", 16)
		commands, rows, skipped, err = evaluateExternal(root, eosBin, datasetName, datasetDir, runDir, logDir, commands, rows, skipped, perQueryPaths, "qwen3-0.6b", "Qwen/Qwen3-Embedding-0.6B", getenv("EOS_LC_WEDGE_QWEN3_CACHE_ROOT", filepath.Join("runs", "external-vector-caches", "qwen3-0.6b-repo-docs-128d")), externalMode, bits, baselineDim, outputDim, chunkWords, chunkOverlap, topK, python, maxDocs, maxQueries, parentAggregation, childCountPenalty, emitPerQuery)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		commands, rows, skipped, err = evaluateExternal(root, eosBin, datasetName, datasetDir, runDir, logDir, commands, rows, skipped, perQueryPaths, "mxbai-large", "mixedbread-ai/mxbai-embed-large-v1", getenv("EOS_LC_WEDGE_MXBAI_CACHE_ROOT", filepath.Join("runs", "external-vector-caches", "mxbai-large-repo-docs-128d")), externalMode, bits, baselineDim, outputDim, chunkWords, chunkOverlap, topK, python, maxDocs, maxQueries, parentAggregation, childCountPenalty, emitPerQuery)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
	default:
		fmt.Fprintf(os.Stderr, "EOS_LC_WEDGE_EXTERNAL_MODE must be off, cache, or export; got %q\n", externalMode)
		os.Exit(1)
	}

	comparisonTSV := filepath.Join(runDir, "comparison.tsv")
	comparisonJSON := filepath.Join(runDir, "comparison.json")
	if err := writeComparisonTSV(comparisonTSV, rows); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if err := writeJSON(comparisonJSON, rows); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	out := manifest{
		Schema:              "eos.long_context_wedge_comparison.v1",
		GeneratedAt:         time.Now().UTC().Format(time.RFC3339),
		RepoRoot:            root,
		RunDir:              runDir,
		QualityClaim:        false,
		DatasetName:         datasetName,
		DatasetDir:          datasetDir,
		DatasetManifestPath: datasetManifestPath,
		LongEmbedFraming: map[string]string{
			"official_synthetic_tasks": "needle, passkey over 0.25x-32x1024 token ranges",
			"official_real_tasks":      "NarrativeQA, 2WikiMultihopQA, QMSum, SummScreenFD",
			"paper_target_length":      "up to 32768 input tokens with dispersed target information",
			"this_lane":                datasetFraming.ThisLane,
		},
		QuantizerSeed:       quantizerSeed,
		BaselineDim:         baselineDim,
		ParentAggregation:   parentAggregation,
		ChildCountPenalty:   childCountPenalty,
		Artifact:            artifact,
		EvaluationArtifact:  evalArtifact,
		ComparisonTSV:       comparisonTSV,
		ComparisonJSON:      comparisonJSON,
		PerQueryJSONL:       perQueryPaths,
		SparseEncoderExport: sparseEncoderManifestPath,
		SparseEncoderAudit:  sparseEncoderAudit,
		Commands:            commands,
		Rows:                rows,
		SkippedExternalRows: skipped,
		Caveats: append([]string{
			"quality_claim=false for every row; this harness is a reproducible long-context wedge comparison artifact, not a product-quality claim.",
			"Eos sparse-token-span rows use experimental sparse-token-pool child vectors and max-child rollup; they are not trained sparse long-context encoder proof.",
			"Eos sparse-encoder parent rows use host-reference retrieval-cache vectors; they are not trained LongEmbed proof, sealed sparse runtime inference, or production quality.",
			"External Qwen3 0.6B and mxbai-large 128d chunked baselines are explicit but opt-in via EOS_LC_WEDGE_EXTERNAL_MODE=cache or export.",
		}, datasetFraming.TopLevelCaveats...),
	}
	manifestPath := filepath.Join(runDir, "manifest.json")
	if err := writeJSON(manifestPath, out); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	fmt.Printf("run_dir=%s\n", runDir)
	fmt.Printf("comparison_tsv=%s\n", comparisonTSV)
	fmt.Printf("comparison_json=%s\n", comparisonJSON)
	fmt.Printf("manifest=%s\n", manifestPath)
	for _, row := range rows {
		fmt.Printf("%s/%s %s bits=%d ndcg@10=%.6f recall@100=%.6f children=%d storage=%.6f quality_claim=%t\n",
			row.Baseline, row.Model, row.Method, row.Bits, row.NDCGAt10, row.RecallAt100, row.ChildCount, row.StorageMultiple, row.QualityClaim)
	}
	for _, item := range skipped {
		fmt.Printf("skipped: %s\n", item)
	}
}
