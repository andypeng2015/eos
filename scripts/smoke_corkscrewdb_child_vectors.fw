	HarnessCommands     [][]string   `json:"harness_commands"`
	Rows                []summaryRow `json:"rows"`
	Gates               []string     `json:"gates"`
	Caveats             []string     `json:"caveats"`
}

func usage() {
	fmt.Println(`CorkScrewDB child-vector API smoke for Eos multi-vector/TurboQuant paths.

Run:
  EOS_REPO_ROOT=$PWD ferrous-wheel run scripts/smoke_corkscrewdb_child_vectors.fw

Default behavior generates a tiny synthetic time-series child-vector cache with
scripts/smoke_eos_timeseries_window_vectors.fw, then loads it into a local flat
CorkScrewDB collection with PutVector and queries it with SearchVector.

Environment:
  EOS_CORKSCREW_SMOKE_RUN_ROOT=runs
  EOS_CORKSCREW_SMOKE_RUN_DIR=runs/eos-corkscrewdb-child-vector-smoke-<timestamp>
  EOS_CORKSCREW_SMOKE_CORKSCREWDB_REPO=/home/draco/work/corkscrewdb
  EOS_CORKSCREW_SMOKE_CHILD_VECTORS=/path/to/child-doc-vectors.jsonl
  EOS_CORKSCREW_SMOKE_QUERY_VECTORS=/path/to/query-vectors.jsonl
  EOS_CORKSCREW_SMOKE_QRELS=/path/to/qrels.tsv
  EOS_CORKSCREW_SMOKE_BITS=2,4,8
  EOS_CORKSCREW_SMOKE_QUANTIZER_SEED=5581486560434873699
  EOS_CORKSCREW_SMOKE_QUANTIZED_ONLY=1
  EOS_CORKSCREW_SMOKE_LAYOUT=separate_child_vectors # single_parent_vectors|separate_child_vectors|packed_parent_multivectors
  EOS_CORKSCREW_SMOKE_PACKED_METADATA_MODE=full # full|minimal|none
  EOS_CORKSCREW_SMOKE_PACKED_CHILD_ID_MODE=source # source|ordinal
  EOS_CORKSCREW_SMOKE_INDEX_TYPE=flat       # flat|hnsw
  EOS_CORKSCREW_SMOKE_VECTOR_STORAGE=quantized_only # quantized_only|raw
  EOS_CORKSCREW_SMOKE_REBUILD_INDEX=0       # defaults to 1 for hnsw, 0 for flat
  EOS_CORKSCREW_SMOKE_OVERFETCH=100       # comma-separated values sweep overfetch
  EOS_CORKSCREW_SMOKE_TOP_PARENTS=100
  EOS_CORKSCREW_SMOKE_BASELINE_DIM=3072
  EOS_CORKSCREW_SMOKE_COLLECTION=eos_child_vector_smoke
  EOS_CORKSCREW_SMOKE_DATASET=synthetic-timeseries-windows
  EOS_CORKSCREW_SMOKE_Q8_MAX_VECTOR_PAYLOAD_MULTIPLE=0.10
  EOS_CORKSCREW_SMOKE_MIN_NDCG_AT_10=0
  EOS_CORKSCREW_SMOKE_MIN_RECALL_AT_100=0`)
}

func parseLayout(value string) (string, error) {
	layout := strings.ToLower(strings.TrimSpace(value))
	if layout == "" {
		layout = layoutSeparateChildVectors
	}
	switch layout {
	case layoutSeparateChildVectors, layoutPackedParentMultivectors, layoutSingleParentVectors:
		return layout, nil
	default:
		return "", fmt.Errorf("EOS_CORKSCREW_SMOKE_LAYOUT must be %s, %s, or %s, got %q", layoutSingleParentVectors, layoutSeparateChildVectors, layoutPackedParentMultivectors, value)
	}
}

func parsePackedMetadataMode(value string) (string, error) {
	mode := strings.ToLower(strings.TrimSpace(value))
	if mode == "" {
		mode = packedMetadataFull
	}
	switch mode {
	case packedMetadataFull, packedMetadataMinimal, packedMetadataNone:
		return mode, nil
	default:
		return "", fmt.Errorf("EOS_CORKSCREW_SMOKE_PACKED_METADATA_MODE must be %s, %s, or %s, got %q", packedMetadataFull, packedMetadataMinimal, packedMetadataNone, value)
	}
}

func parsePackedChildIDMode(value string) (string, error) {
	mode := strings.ToLower(strings.TrimSpace(value))
	if mode == "" {
		mode = packedChildIDSource
	}
	switch mode {
	case packedChildIDSource, packedChildIDOrdinal:
		return mode, nil
	default:
		return "", fmt.Errorf("EOS_CORKSCREW_SMOKE_PACKED_CHILD_ID_MODE must be %s or %s, got %q", packedChildIDSource, packedChildIDOrdinal, value)
	}
}

func searchModeForLayout(layout string) (string, bool) {
	if layout == layoutPackedParentMultivectors {
		return "search_parents_vector_exact_flat_rollup", true
	}
	if layout == layoutSingleParentVectors {
		return "search_vector_parent_single", true
	}
	return "search_vector_child_overfetch_rollup", false
}

func getenv(name string, fallback string) string {
	value := os.Getenv(name)
	if value != "" {
		return value
	}
	return fallback
}

func envBool(name string, fallback bool) bool {
	value := strings.ToLower(strings.TrimSpace(os.Getenv(name)))
	if value == "" {
		return fallback
	}
	return value == "1" || value == "true" || value == "yes" || value == "on"
}

func envBoolWithPresence(name string, fallback bool) (bool, bool) {
	value := strings.ToLower(strings.TrimSpace(os.Getenv(name)))
	if value == "" {
		return fallback, false
	}
	return value == "1" || value == "true" || value == "yes" || value == "on", true
}

func hasRepoRoot(dir string) bool {
	if dir == "" {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, "go.mod")); err != nil {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, ".git")); err != nil {
		return false
	}
	return true
}

func findRoot() (string, error) {
	if explicit := os.Getenv("EOS_REPO_ROOT"); hasRepoRoot(explicit) {
		return filepath.Abs(explicit)
	}
	if pwd := os.Getenv("PWD"); hasRepoRoot(pwd) {
		return filepath.Abs(pwd)
	}
	cwd, err := os.Getwd()
	if err != nil {
		return "", err
	}
	if hasRepoRoot(cwd) {
		return filepath.Abs(cwd)
	}
	return "", fmt.Errorf("could not find repo root; set EOS_REPO_ROOT")
}

func parseIntEnv(name string, fallback int) (int, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.Atoi(value)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseInt64Env(name string, fallback int64) (int64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseInt(value, 10, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseFloatEnv(name string, fallback float64) (float64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseFloat(value, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be a float: %w", name, err)
	}
	return parsed, nil
}

func parseBits(value string) ([]int, error) {
	parts := strings.Split(value, ",")
	bits := []int{}
	for _, part := range parts {
		part = strings.TrimSpace(part)
		if part == "" {
			continue
		}
		parsed, err := strconv.Atoi(part)
		if err != nil {
			return nil, fmt.Errorf("invalid bit width %q: %w", part, err)
		}
		if parsed <= 0 {
			return nil, fmt.Errorf("bit width must be positive: %d", parsed)
		}
		bits = append(bits, parsed)
	}
	if len(bits) == 0 {
		return nil, fmt.Errorf("no bit widths configured")
	}
	return bits, nil
}

func parsePositiveIntList(name string, value string) ([]int, error) {
	parts := strings.Split(value, ",")
	values := []int{}
	for _, part := range parts {
		part = strings.TrimSpace(part)
		if part == "" {
			continue
		}
		parsed, err := strconv.Atoi(part)
		if err != nil {
			return nil, fmt.Errorf("%s contains invalid integer %q: %w", name, part, err)
		}
		if parsed <= 0 {
			return nil, fmt.Errorf("%s values must be positive: %d", name, parsed)
		}
		values = append(values, parsed)
	}
	if len(values) == 0 {
		return nil, fmt.Errorf("%s must include at least one positive integer", name)
	}
	return values, nil
}

func shellQuote(value string) string {
	if value == "" {
		return "''"
	}
	if strings.ContainsAny(value, " \t\n'\"\\$`!*?[]{}()<>|&;") {
		return "'" + strings.ReplaceAll(value, "'", "'\\''") + "'"
	}
	return value
}

func renderCommand(args []string) string {
	parts := []string{}
	for _, arg := range args {
		parts = append(parts, shellQuote(arg))
	}
	return strings.Join(parts, " ")
}

func runCommand(dir string, logDir string, label string, args []string, env []string) error {
	fmt.Println("\n== " + label + " ==")
	fmt.Println("+ " + renderCommand(args))
	if err := os.WriteFile(filepath.Join(logDir, label+".cmd"), []byte(renderCommand(args)+"\n"), 0o644); err != nil {
		return err
	}
	cmd := exec.Command(args[0], args[1:]...)
	cmd.Dir = dir
	cmd.Env = env
	cmd.Stdout = os.Stdout
	cmd.Stderr = os.Stderr
	if err := cmd.Run(); err != nil {
		return fmt.Errorf("%s failed: %w", label, err)
	}
	return nil
}

func fileExists(path string) bool {
	info, err := os.Stat(path)
	return err == nil && !info.IsDir()
}

func requireCorkScrewDBRepo(path string) error {
	if !hasRepoRoot(path) {
		return fmt.Errorf("local CorkScrewDB repo is required at %s; set EOS_CORKSCREW_SMOKE_CORKSCREWDB_REPO to a checkout of m31labs.dev/corkscrewdb", path)
	}
	if !fileExists(filepath.Join(path, "go.mod")) {
		return fmt.Errorf("CorkScrewDB repo has no go.mod: %s", path)
	}
	return nil
}

func writeHarnessModule(harnessDir string, corkscrewRepo string) error {
	if err := os.MkdirAll(harnessDir, 0o755); err != nil {
		return err
	}
	goMod := "module eos-corkscrewdb-child-vector-smoke\n\ngo 1.23\n\nrequire m31labs.dev/corkscrewdb v0.0.0\n\nreplace m31labs.dev/corkscrewdb => " + corkscrewRepo + "\n"
	if err := os.WriteFile(filepath.Join(harnessDir, "go.mod"), []byte(goMod), 0o644); err != nil {
		return err
	}
	return os.WriteFile(filepath.Join(harnessDir, "main.go"), []byte(harnessSource), 0o644)
}

func readMetrics(path string) (bitMetrics, error) {
	var metrics bitMetrics
	data, err := os.ReadFile(path)
	if err != nil {
		return metrics, err
	}
	return metrics, json.Unmarshal(data, &metrics)
}

func writeSummaryTSV(path string, rows []summaryRow) error {
	var b strings.Builder
	b.WriteString("bits\toverfetch_children\tparent_insert_count\tlayout\tsearch_mode\tparent_search_exact\tpacked_metadata_mode\tpacked_child_id_mode\tindex_type\tvector_storage\tndcg_at_10\trecall_at_100\tvector_payload_storage_multiple\tdb_directory_storage_multiple\tquantized_vector_bytes\tquantized_child_bytes\tdb_bytes_after_close\tload_seconds\trebuild_seconds\tsearch_seconds\tp50_ms\tp95_ms\tp99_ms\tmax_ms\n")
	for _, row := range rows {
		fmt.Fprintf(&b, "%d\t%d\t%d\t%s\t%s\t%t\t%s\t%s\t%s\t%s\t%.6f\t%.6f\t%.6f\t%.6f\t%d\t%d\t%d\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\n",
			row.Bits,
			row.OverfetchChildren,
			row.ParentInsertCount,
			row.Layout,
			row.SearchMode,
			row.ParentSearchExact,
			row.PackedMetadataMode,
			row.PackedChildIDMode,
			row.IndexType,
			row.VectorStorage,
			row.NDCGAt10,
			row.RecallAt100,
			row.VectorPayloadStorageMultiple,
			row.DBDirectoryStorageMultiple,
			row.QuantizedVectorBytes,
			row.QuantizedChildBytes,
			row.DBBytesAfterClose,
			row.LoadSeconds,
			row.RebuildSeconds,
			row.SearchSeconds,
			row.P50MS,
			row.P95MS,
			row.P99MS,
			row.MaxMS)
	}
	return os.WriteFile(path, []byte(b.String()), 0o644)
}

func checkGates(rows []summaryRow, maxQ8PayloadMultiple float64, minNDCG float64, minRecall float64) error {
	for _, row := range rows {
		if minNDCG > 0 && row.NDCGAt10 < minNDCG {
			return fmt.Errorf("q%d overfetch%d ndcg@10 %.6f is below %.6f", row.Bits, row.OverfetchChildren, row.NDCGAt10, minNDCG)
		}
		if minRecall > 0 && row.RecallAt100 < minRecall {
			return fmt.Errorf("q%d overfetch%d recall@100 %.6f is below %.6f", row.Bits, row.OverfetchChildren, row.RecallAt100, minRecall)
		}
		if row.Bits == 8 && maxQ8PayloadMultiple > 0 && row.VectorPayloadStorageMultiple > maxQ8PayloadMultiple {
			return fmt.Errorf("q8 overfetch%d vector payload multiple %.6f exceeds %.6f", row.OverfetchChildren, row.VectorPayloadStorageMultiple, maxQ8PayloadMultiple)
		}
	}
	return nil
}

func main() {
	if len(os.Args) > 1 && (os.Args[1] == "-h" || os.Args[1] == "--help") {
		usage()
		return
	}
	root, err := findRoot()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	runRoot := getenv("EOS_CORKSCREW_SMOKE_RUN_ROOT", filepath.Join(root, "runs"))
	runDir := getenv("EOS_CORKSCREW_SMOKE_RUN_DIR", filepath.Join(runRoot, "eos-corkscrewdb-child-vector-smoke-"+time.Now().UTC().Format("20060102T150405Z")))
	runDir, err = filepath.Abs(runDir)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	logDir := filepath.Join(runDir, "logs")
	harnessDir := filepath.Join(runDir, "harness")
	metricsDir := filepath.Join(runDir, "metrics")
	dbRoot := filepath.Join(runDir, "db")
	for _, dir := range []string{logDir, harnessDir, metricsDir, dbRoot} {
		if err := os.MkdirAll(dir, 0o755); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
	}

	corkscrewRepo := getenv("EOS_CORKSCREW_SMOKE_CORKSCREWDB_REPO", defaultCorkScrewDBRepo)
	corkscrewRepo, err = filepath.Abs(corkscrewRepo)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if err := requireCorkScrewDBRepo(corkscrewRepo); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	childVectors := os.Getenv("EOS_CORKSCREW_SMOKE_CHILD_VECTORS")
	queryVectors := os.Getenv("EOS_CORKSCREW_SMOKE_QUERY_VECTORS")
	qrels := os.Getenv("EOS_CORKSCREW_SMOKE_QRELS")
	generatedInputs := false
	var timeseriesCommand []string
	if childVectors == "" || queryVectors == "" || qrels == "" {
		timeseriesDir := filepath.Join(runDir, "timeseries")
		timeseriesCommand = []string{"ferrous-wheel", "run", "scripts/smoke_eos_timeseries_window_vectors.fw"}
		env := append(os.Environ(), "EOS_REPO_ROOT="+root, "EOS_TS_WINDOW_SMOKE_RUN_DIR="+timeseriesDir)
		if err := runCommand(root, logDir, "generate-timeseries-child-vectors", timeseriesCommand, env); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		childVectors = filepath.Join(timeseriesDir, "window-cache", "child-doc-vectors.jsonl")
		queryVectors = filepath.Join(timeseriesDir, "window-cache", "query-vectors.jsonl")
		qrels = filepath.Join(timeseriesDir, "qrels.tsv")
		generatedInputs = true
	}
	for _, path := range []string{childVectors, queryVectors, qrels} {
		if !fileExists(path) {
			fmt.Fprintf(os.Stderr, "required input does not exist: %s\n", path)
			os.Exit(1)
		}
	}

	bitsValue := getenv("EOS_CORKSCREW_SMOKE_BITS", "2,4,8")
	bits, err := parseBits(bitsValue)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	layout, err := parseLayout(os.Getenv("EOS_CORKSCREW_SMOKE_LAYOUT"))
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	packedMetadataMode, err := parsePackedMetadataMode(os.Getenv("EOS_CORKSCREW_SMOKE_PACKED_METADATA_MODE"))
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	packedChildIDMode, err := parsePackedChildIDMode(os.Getenv("EOS_CORKSCREW_SMOKE_PACKED_CHILD_ID_MODE"))
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	searchMode, parentSearchExact := searchModeForLayout(layout)
	seed, err := parseInt64Env("EOS_CORKSCREW_SMOKE_QUANTIZER_SEED", defaultQuantizerSeed)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	overfetchValue := getenv("EOS_CORKSCREW_SMOKE_OVERFETCH", "100")
	topParents, err := parseIntEnv("EOS_CORKSCREW_SMOKE_TOP_PARENTS", 100)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	var overfetchValues []int
	if layout == layoutPackedParentMultivectors || layout == layoutSingleParentVectors {
		overfetchValue = "0"
		overfetchValues = []int{0}
	} else {
		overfetchValues, err = parsePositiveIntList("EOS_CORKSCREW_SMOKE_OVERFETCH", overfetchValue)
		if err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		for _, overfetch := range overfetchValues {
			if overfetch < topParents {
				fmt.Fprintf(os.Stderr, "EOS_CORKSCREW_SMOKE_OVERFETCH value %d must be >= EOS_CORKSCREW_SMOKE_TOP_PARENTS %d\n", overfetch, topParents)
				os.Exit(1)
			}
		}
	}
	baselineDim, err := parseIntEnv("EOS_CORKSCREW_SMOKE_BASELINE_DIM", 3072)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	maxQ8PayloadMultiple, err := parseFloatEnv("EOS_CORKSCREW_SMOKE_Q8_MAX_VECTOR_PAYLOAD_MULTIPLE", 0.10)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minNDCG, err := parseFloatEnv("EOS_CORKSCREW_SMOKE_MIN_NDCG_AT_10", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minRecall, err := parseFloatEnv("EOS_CORKSCREW_SMOKE_MIN_RECALL_AT_100", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	quantizedOnly := envBool("EOS_CORKSCREW_SMOKE_QUANTIZED_ONLY", true)
	vectorStorage := strings.ToLower(strings.TrimSpace(os.Getenv("EOS_CORKSCREW_SMOKE_VECTOR_STORAGE")))
	if vectorStorage == "" {
		if quantizedOnly {
			vectorStorage = "quantized_only"
		} else {
			vectorStorage = "raw"
		}
	}
	if vectorStorage != "quantized_only" && vectorStorage != "raw" {
		fmt.Fprintf(os.Stderr, "EOS_CORKSCREW_SMOKE_VECTOR_STORAGE must be quantized_only or raw, got %q\n", vectorStorage)
		os.Exit(1)
	}
	quantizedOnly = vectorStorage == "quantized_only"
	indexType := strings.ToLower(strings.TrimSpace(getenv("EOS_CORKSCREW_SMOKE_INDEX_TYPE", "flat")))
	if indexType != "flat" && indexType != "hnsw" {
		fmt.Fprintf(os.Stderr, "EOS_CORKSCREW_SMOKE_INDEX_TYPE must be flat or hnsw, got %q\n", indexType)
		os.Exit(1)
	}
	if indexType == "hnsw" && quantizedOnly {
		fmt.Fprintln(os.Stderr, "EOS_CORKSCREW_SMOKE_INDEX_TYPE=hnsw requires EOS_CORKSCREW_SMOKE_VECTOR_STORAGE=raw because CorkScrewDB rejects HNSW with quantized_only persistence")
		os.Exit(1)
	}
	if layout == layoutPackedParentMultivectors {
		if indexType != "flat" {
			fmt.Fprintln(os.Stderr, "EOS_CORKSCREW_SMOKE_LAYOUT=packed_parent_multivectors requires EOS_CORKSCREW_SMOKE_INDEX_TYPE=flat")
			os.Exit(1)
		}
		if !quantizedOnly || vectorStorage != "quantized_only" {
			fmt.Fprintln(os.Stderr, "EOS_CORKSCREW_SMOKE_LAYOUT=packed_parent_multivectors requires EOS_CORKSCREW_SMOKE_VECTOR_STORAGE=quantized_only")
			os.Exit(1)
		}
	}
	rebuildIndex, rebuildConfigured := envBoolWithPresence("EOS_CORKSCREW_SMOKE_REBUILD_INDEX", indexType == "hnsw")
	if indexType == "hnsw" && !rebuildConfigured {
		rebuildIndex = true
	}
	dataset := getenv("EOS_CORKSCREW_SMOKE_DATASET", "synthetic-timeseries-windows")
	collection := getenv("EOS_CORKSCREW_SMOKE_COLLECTION", "eos_child_vector_smoke")

	if err := writeHarnessModule(harnessDir, corkscrewRepo); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	goModTidyCommand := []string{"go", "mod", "tidy"}
	if err := runCommand(harnessDir, logDir, "harness-go-mod-tidy", goModTidyCommand, os.Environ()); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	rows := []summaryRow{}
	metricFiles := []string{}
	harnessCommands := [][]string{}
	for _, bit := range bits {
		dbPath := filepath.Join(dbRoot, fmt.Sprintf("q%d", bit))
		for overfetchIndex, overfetch := range overfetchValues {
			metricsPath := filepath.Join(metricsDir, fmt.Sprintf("q%d-overfetch%d.metrics.json", bit, overfetch))
			args := []string{
				"go", "run", ".",
				"--child-vectors", childVectors,
				"--query-vectors", queryVectors,
				"--qrels", qrels,
				"--db", dbPath,
				"--bits", strconv.Itoa(bit),
				"--overfetch", strconv.Itoa(overfetch),
				"--top-parents", strconv.Itoa(topParents),
				"--baseline-dim", strconv.Itoa(baselineDim),
				"--collection", collection,
				"--dataset", dataset,
				"--quantizer-seed", strconv.FormatInt(seed, 10),
				"--metrics-json", metricsPath,
				"--index-type", indexType,
				"--vector-storage", vectorStorage,
				"--layout", layout,
				"--packed-metadata-mode", packedMetadataMode,
				"--packed-child-id-mode", packedChildIDMode,
			}
			if quantizedOnly {
				args = append(args, "--quantized-only")
			}
			if rebuildIndex {
				args = append(args, "--rebuild-index")
			}
			if overfetchIndex > 0 {
				args = append(args, "--reuse-db")
			}
			if err := runCommand(harnessDir, logDir, fmt.Sprintf("harness-q%d-overfetch%d", bit, overfetch), args, os.Environ()); err != nil {
				fmt.Fprintln(os.Stderr, err)
				os.Exit(1)
			}
			metrics, err := readMetrics(metricsPath)
			if err != nil {
				fmt.Fprintln(os.Stderr, err)
				os.Exit(1)
			}
			rows = append(rows, summaryRow{
				Bits:                         metrics.Bits,
				OverfetchChildren:            metrics.OverfetchChildren,
				ParentInsertCount:            metrics.ParentInsertCount,
				IndexType:                    metrics.IndexType,
				VectorStorage:                metrics.VectorStorage,
				Layout:                       metrics.Layout,
				SearchMode:                   metrics.SearchMode,
				ParentSearchExact:            metrics.ParentSearchExact,
				PackedMetadataMode:           metrics.PackedMetadataMode,
				PackedChildIDMode:            metrics.PackedChildIDMode,
				NDCGAt10:                     metrics.Quality.NDCGAt10,
				RecallAt100:                  metrics.Quality.RecallAt100,
				VectorPayloadStorageMultiple: metrics.VectorPayloadStorageMultiple,
				DBDirectoryStorageMultiple:   metrics.DBDirectoryStorageMultiple,
				QuantizedVectorBytes:         metrics.QuantizedVectorBytes,
				QuantizedChildBytes:          metrics.QuantizedChildBytes,
				DBBytesAfterClose:            metrics.DBBytesAfterClose,
				LoadSeconds:                  metrics.LoadSeconds,
				RebuildSeconds:               metrics.RebuildSeconds,
				SearchSeconds:                metrics.SearchSeconds,
				P50MS:                        metrics.SearchLatency.P50MS,
				P95MS:                        metrics.SearchLatency.P95MS,
				P99MS:                        metrics.SearchLatency.P99MS,
				MaxMS:                        metrics.SearchLatency.MaxMS,
			})
			metricFiles = append(metricFiles, metricsPath)
			harnessCommands = append(harnessCommands, args)
		}
	}

	if err := checkGates(rows, maxQ8PayloadMultiple, minNDCG, minRecall); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	summaryTSV := filepath.Join(runDir, "summary.tsv")
	if err := writeSummaryTSV(summaryTSV, rows); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	manifestJSON := filepath.Join(runDir, "manifest.json")
	out := manifest{
		Schema:            "eos.corkscrewdb_child_vector_smoke.v1",
		GeneratedAt:       time.Now().UTC().Format(time.RFC3339),
		RunDir:            runDir,
		RepoRoot:          root,
		CorkScrewDBRepo:   corkscrewRepo,
		Dataset:           dataset,
		Collection:        collection,
		ChildVectors:      childVectors,
		QueryVectors:      queryVectors,
		Qrels:             qrels,
		GeneratedInputs:   generatedInputs,
		Bits:              bitsValue,
		QuantizerSeed:     seed,
		QuantizedOnly:     quantizedOnly,
		IndexType:         indexType,
		VectorStorage:     vectorStorage,
		RebuildIndex:      rebuildIndex,
		Layout:            layout,
		SearchMode:        searchMode,
		ParentSearchExact: parentSearchExact,
		PackedMetadataMode: packedMetadataMode,
		PackedChildIDMode:  packedChildIDMode,
		OverfetchChildren: overfetchValue,
		OverfetchValues:   overfetchValues,
		TopKParents:       topParents,
		BaselineDim:       baselineDim,
		HarnessDir:        harnessDir,
		SummaryTSV:        summaryTSV,
		MetricFiles:       metricFiles,
		TimeseriesCommand: timeseriesCommand,
		GoModTidyCommand:  goModTidyCommand,
		HarnessCommands:   harnessCommands,
		Rows:              rows,
		Gates: []string{
			fmt.Sprintf("command success required for every configured bit width (%s)", bitsValue),
			fmt.Sprintf("q8 vector payload multiple <= %.6f when q8 is included and the limit is positive", maxQ8PayloadMultiple),
			fmt.Sprintf("optional ndcg@10 floor %.6f; disabled when 0", minNDCG),
			fmt.Sprintf("optional recall@100 floor %.6f; disabled when 0", minRecall),
		},
		Caveats: []string{
			"Local CorkScrewDB API smoke only: separate layout uses PutVector/SearchVector child overfetch rollup; packed layout uses PutMultiVector/SearchParentsVector exact flat parent rollup; single-parent layout mean-pools children into one normalized PutVector per parent and searches parent IDs directly.",
			"Packed metadata and child-id modes affect only packed_parent_multivectors; separate child-vector layout keeps full per-child metadata and source child IDs.",
			"HNSW runs use raw vector storage and only the separate child-vector layout; packed parent multivectors require local flat quantized_only persistence.",
			"Default generated inputs are tiny synthetic text-rendered time-series windows, not a model-quality benchmark.",
			"Storage gates use quantized vector payload accounting by default; DB directory multiples are recorded but not gated because tiny DB overhead dominates.",
			"The run fails if a local CorkScrewDB checkout is missing instead of pulling an unknown network dependency.",
		},
	}
	data, err := json.MarshalIndent(out, "", "  ")
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if err := os.WriteFile(manifestJSON, append(data, '\n'), 0o644); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	fmt.Printf("\nsummary_tsv: %s\n", summaryTSV)
	fmt.Printf("manifest: %s\n", manifestJSON)
	for _, row := range rows {
		fmt.Printf("q%d overfetch%d %s metadata=%s child_ids=%s %s/%s: ndcg@10=%.6f recall@100=%.6f parent_inserts=%d vector_payload_multiple=%.6fx db_dir_multiple=%.6fx rebuild=%.6fs p95=%.6fms\n",
			row.Bits,
			row.OverfetchChildren,
			row.Layout,
			row.PackedMetadataMode,
			row.PackedChildIDMode,
			row.IndexType,
			row.VectorStorage,
			row.NDCGAt10,
			row.RecallAt100,
			row.ParentInsertCount,
			row.VectorPayloadStorageMultiple,
			row.DBDirectoryStorageMultiple,
			row.RebuildSeconds,
			row.P95MS)
	}
}

const harnessSource = `package main

import (
	"bufio"
	"container/heap"
	"encoding/json"
	"flag"
	"fmt"
	"io"
	"math"
	"os"
	"path/filepath"
	"sort"
	"strconv"
	"strings"
	"time"

	corkscrewdb "m31labs.dev/corkscrewdb"
)

type vectorRow struct {
	ID        string    ` + "`json:\"id\"`" + `
	ParentID  string    ` + "`json:\"parent_id\"`" + `
	ChildID   string    ` + "`json:\"child_id\"`" + `
	Vector    []float32 ` + "`json:\"vector\"`" + `
	Embedding []float32 ` + "`json:\"embedding\"`" + `
	Values    []float32 ` + "`json:\"values\"`" + `
}

type scoredDoc struct {
	ID    string
	Score float32
}

type parentCandidate struct {
	id    string
	score float32
}

type parentHeap []parentCandidate

func (h parentHeap) Len() int           { return len(h) }
func (h parentHeap) Less(i, j int) bool { return h[i].score < h[j].score }
func (h parentHeap) Swap(i, j int)      { h[i], h[j] = h[j], h[i] }
func (h *parentHeap) Push(x any)        { *h = append(*h, x.(parentCandidate)) }
func (h *parentHeap) Pop() any {
	old := *h
	n := len(old)
	x := old[n-1]
	*h = old[:n-1]
	return x
}

type latencyMetrics struct {
	P50MS float64 ` + "`json:\"p50_ms\"`" + `
	P95MS float64 ` + "`json:\"p95_ms\"`" + `
	P99MS float64 ` + "`json:\"p99_ms\"`" + `
	MaxMS float64 ` + "`json:\"max_ms\"`" + `
}

type qualityMetrics struct {
	NDCGAt10    float64 ` + "`json:\"ndcg_at_10\"`" + `
	RecallAt100 float64 ` + "`json:\"recall_at_100\"`" + `
}

type smokeMetrics struct {
	Bits                         int            ` + "`json:\"bits\"`" + `
	Dimension                    int            ` + "`json:\"dimension\"`" + `
	InsertCount                  int            ` + "`json:\"insert_count\"`" + `
	ParentInsertCount            int            ` + "`json:\"parent_insert_count\"`" + `
	ParentCount                  int            ` + "`json:\"parent_count\"`" + `
	QueryCount                   int            ` + "`json:\"query_count\"`" + `
	RelevantPairs                int            ` + "`json:\"relevant_pairs\"`" + `
	OverfetchChildren            int            ` + "`json:\"overfetch_children\"`" + `
	TopKParents                  int            ` + "`json:\"top_k_parents\"`" + `
	Collection                   string         ` + "`json:\"collection\"`" + `
	Dataset                      string         ` + "`json:\"dataset\"`" + `
	LoadSeconds                  float64        ` + "`json:\"load_seconds\"`" + `
	SearchSeconds                float64        ` + "`json:\"search_seconds\"`" + `
	DBBytesAfterClose            int64          ` + "`json:\"db_bytes_after_close\"`" + `
	QuantizedVectorBytes         int64          ` + "`json:\"quantized_vector_bytes\"`" + `
	QuantizedChildBytes          int64          ` + "`json:\"quantized_child_bytes\"`" + `
	DenseParentBaselineBytes     int64          ` + "`json:\"dense_parent_baseline_bytes\"`" + `
	VectorPayloadStorageMultiple float64        ` + "`json:\"vector_payload_storage_multiple\"`" + `
	DBDirectoryStorageMultiple   float64        ` + "`json:\"db_directory_storage_multiple\"`" + `
	SearchLatency                latencyMetrics ` + "`json:\"search_latency\"`" + `
	Quality                      qualityMetrics ` + "`json:\"quality\"`" + `
	QuantizerSeed                int64          ` + "`json:\"quantizer_seed\"`" + `
	QuantizedOnly                bool           ` + "`json:\"quantized_only\"`" + `
	IndexType                    string         ` + "`json:\"index_type\"`" + `
	VectorStorage                string         ` + "`json:\"vector_storage\"`" + `
	RebuildIndex                 bool           ` + "`json:\"rebuild_index\"`" + `
	RebuildSeconds               float64        ` + "`json:\"rebuild_seconds\"`" + `
	Layout                       string         ` + "`json:\"layout\"`" + `
	SearchMode                   string         ` + "`json:\"search_mode\"`" + `
	ParentSearchExact            bool           ` + "`json:\"parent_search_exact\"`" + `
	PackedMetadataMode           string         ` + "`json:\"packed_metadata_mode\"`" + `
	PackedChildIDMode            string         ` + "`json:\"packed_child_id_mode\"`" + `
}

type childVector struct {
	ParentID string
	ChildID  string
	Vector   []float32
}

type queryVector struct {
	ID     string
	Vector []float32
}

func main() {
	var (
		childPath   = flag.String("child-vectors", "", "child vector JSONL")
		queryPath   = flag.String("query-vectors", "", "query vector JSONL")
		qrelsPath   = flag.String("qrels", "", "qrels TSV")
		dbPath      = flag.String("db", "", "CorkScrewDB directory")
		bits        = flag.Int("bits", 8, "CorkScrewDB quantization bit width")
		overfetch   = flag.Int("overfetch", 100, "child hits to fetch before parent rollup")
		topParents  = flag.Int("top-parents", 100, "parent hits retained for metric evaluation")
		baselineDim = flag.Int("baseline-dim", 3072, "dense one-vector-per-parent baseline dimension")
		collection  = flag.String("collection", "eos_child_vector_smoke", "CorkScrewDB collection name")
		dataset     = flag.String("dataset", "synthetic-timeseries-windows", "dataset label")
		outPath     = flag.String("metrics-json", "", "output metrics JSON path")
		seed        = flag.Int64("quantizer-seed", 0, "CorkScrewDB quantizer seed")
		quantOnly   = flag.Bool("quantized-only", false, "store only quantized vector payloads")
		reuseDB     = flag.Bool("reuse-db", false, "reuse an existing DB and skip deletion/inserts")
		indexType   = flag.String("index-type", "flat", "CorkScrewDB index type: flat or hnsw")
		vectorStore = flag.String("vector-storage", "", "CorkScrewDB vector storage: quantized_only or raw")
		rebuildIdx  = flag.Bool("rebuild-index", false, "rebuild the collection index after inserts")
		layout      = flag.String("layout", "separate_child_vectors", "storage/search layout: single_parent_vectors, separate_child_vectors, or packed_parent_multivectors")
		packedMeta = flag.String("packed-metadata-mode", "full", "packed parent metadata mode: full, minimal, or none")
		packedIDs  = flag.String("packed-child-id-mode", "source", "packed child ID mode: source or ordinal")
	)
	flag.Parse()

	if *childPath == "" || *queryPath == "" || *qrelsPath == "" || *dbPath == "" || *outPath == "" {
		fatalf("--child-vectors, --query-vectors, --qrels, --db, and --metrics-json are required")
	}
	*layout = strings.ToLower(strings.TrimSpace(*layout))
	if *layout == "" {
		*layout = "separate_child_vectors"
	}
	if *layout != "separate_child_vectors" && *layout != "packed_parent_multivectors" && *layout != "single_parent_vectors" {
		fatalf("--layout must be single_parent_vectors, separate_child_vectors, or packed_parent_multivectors, got %q", *layout)
	}
	*packedMeta = strings.ToLower(strings.TrimSpace(*packedMeta))
	if *packedMeta == "" {
		*packedMeta = "full"
	}
	if *packedMeta != "full" && *packedMeta != "minimal" && *packedMeta != "none" {
		fatalf("--packed-metadata-mode must be full, minimal, or none, got %q", *packedMeta)
	}
	*packedIDs = strings.ToLower(strings.TrimSpace(*packedIDs))
	if *packedIDs == "" {
		*packedIDs = "source"
	}
	if *packedIDs != "source" && *packedIDs != "ordinal" {
		fatalf("--packed-child-id-mode must be source or ordinal, got %q", *packedIDs)
	}
	if *layout == "separate_child_vectors" && *overfetch < *topParents {
		fatalf("--overfetch must be >= --top-parents")
	}
	*indexType = strings.ToLower(strings.TrimSpace(*indexType))
	if *indexType != "flat" && *indexType != "hnsw" {
		fatalf("--index-type must be flat or hnsw, got %q", *indexType)
	}
	*vectorStore = strings.ToLower(strings.TrimSpace(*vectorStore))
	if *vectorStore == "" {
		if *quantOnly {
			*vectorStore = "quantized_only"
		} else {
			*vectorStore = "raw"
		}
	}
	if *vectorStore != "quantized_only" && *vectorStore != "raw" {
		fatalf("--vector-storage must be quantized_only or raw, got %q", *vectorStore)
	}
	if *vectorStore == "quantized_only" {
		*quantOnly = true
	}
	if *indexType == "hnsw" && *quantOnly {
		fatalf("--index-type=hnsw requires --vector-storage=raw because CorkScrewDB rejects HNSW with quantized_only persistence")
	}
	if *layout == "packed_parent_multivectors" {
		if *indexType != "flat" {
			fatalf("--layout=packed_parent_multivectors requires --index-type=flat")
		}
		if !*quantOnly || *vectorStore != "quantized_only" {
			fatalf("--layout=packed_parent_multivectors requires --vector-storage=quantized_only")
		}
		*overfetch = 0
	}
	if *layout == "single_parent_vectors" {
		*overfetch = 0
	}
	if !*reuseDB {
		if err := os.RemoveAll(*dbPath); err != nil {
			fatalf("remove db dir: %v", err)
		}
	}

	children, dim, parentCount, err := readChildVectors(*childPath)
	if err != nil {
		fatalf("read child vectors: %v", err)
	}
	queries, queryDim, err := readQueryVectors(*queryPath)
	if err != nil {
		fatalf("read query vectors: %v", err)
	}
	if dim != queryDim {
		fatalf("dimension mismatch: child=%d query=%d", dim, queryDim)
	}
	qrels, relevantPairs, err := readQrels(*qrelsPath)
	if err != nil {
		fatalf("read qrels: %v", err)
	}

	db, err := corkscrewdb.Open(*dbPath)
	if err != nil {
		fatalf("open corkscrewdb: %v", err)
	}
	options := []corkscrewdb.CollectionOption{corkscrewdb.WithBitWidth(*bits)}
	if *seed != 0 {
		options = append(options, corkscrewdb.WithQuantizerSeed(*seed))
	}
	if *indexType == "hnsw" && *reuseDB {
		options = append(options, corkscrewdb.WithIndexType(corkscrewdb.IndexHNSW))
	}
	if *quantOnly {
		options = append(options, corkscrewdb.WithQuantizedOnlyPersistence())
	} else if *vectorStore == "raw" {
		options = append(options, corkscrewdb.WithVectorStorage(corkscrewdb.VectorStorageRaw))
	}
	coll := db.Collection(*collection, options...)
	loadStart := time.Now()
	parentInsertCount := 0
	if !*reuseDB {
		switch *layout {
		case "single_parent_vectors":
			parentVectors := meanPooledParentVectors(children)
			for _, parent := range parentVectors {
				meta := map[string]string{
					"parent_id": parent.ParentID,
					"dataset":   *dataset,
				}
				if err := coll.PutVector(parent.ParentID, parent.Vector, corkscrewdb.WithMetadata(meta)); err != nil {
					_ = db.Close()
					fatalf("put parent vector %q: %v", parent.ParentID, err)
				}
				parentInsertCount++
			}
		case "packed_parent_multivectors":
			groups, parentIDs := groupChildrenByParent(children)
			for _, parentID := range parentIDs {
				group := groups[parentID]
				entry := corkscrewdb.MultiVectorEntry{
					Metadata: packedParentMetadata(*packedMeta, parentID, *dataset),
					Children: make([]corkscrewdb.MultiVectorChild, 0, len(group)),
				}
				for childIndex, child := range group {
					ordinal := strconv.Itoa(childIndex)
					entry.Children = append(entry.Children, corkscrewdb.MultiVectorChild{
						ID:       packedChildID(*packedIDs, child.ChildID, ordinal),
						Vector:   child.Vector,
						Metadata: packedChildMetadata(*packedMeta, parentID, child.ChildID, ordinal, *dataset),
					})
				}
				if err := coll.PutMultiVector(parentID, entry); err != nil {
					_ = db.Close()
					fatalf("put multivector parent %q: %v", parentID, err)
				}
				parentInsertCount++
			}
		default:
			for _, child := range children {
				meta := map[string]string{
					"parent_id": child.ParentID,
					"child_id":  child.ChildID,
					"dataset":   *dataset,
				}
				if err := coll.PutVector(child.ChildID, child.Vector, corkscrewdb.WithMetadata(meta)); err != nil {
					_ = db.Close()
					fatalf("put vector %q: %v", child.ChildID, err)
				}
			}
		}
	}
	loadSeconds := time.Since(loadStart).Seconds()
	if *reuseDB {
		loadSeconds = 0
	}
	rebuildSeconds := 0.0
	if *rebuildIdx && !*reuseDB {
		rebuildStart := time.Now()
		switch *indexType {
		case "hnsw":
			if err := coll.RebuildIndex(corkscrewdb.IndexHNSW); err != nil {
				_ = db.Close()
				fatalf("rebuild hnsw index: %v", err)
			}
		case "flat":
			if err := coll.RebuildIndex(corkscrewdb.IndexFlat); err != nil {
				_ = db.Close()
				fatalf("rebuild flat index: %v", err)
			}
		}
		rebuildSeconds = time.Since(rebuildStart).Seconds()
	}

	var totals qualityMetrics
	latencies := make([]time.Duration, 0, len(queries))
	searchStart := time.Now()
	for _, query := range queries {
		start := time.Now()
		var ranked []scoredDoc
		if *layout == "packed_parent_multivectors" {
			hits, err := coll.SearchParentsVector(query.Vector, *topParents)
			latencies = append(latencies, time.Since(start))
			if err != nil {
				_ = db.Close()
				fatalf("search parents query %q: %v", query.ID, err)
			}
			ranked = parentResultsToScoredDocs(hits)
		} else if *layout == "single_parent_vectors" {
			hits, err := coll.SearchVector(query.Vector, *topParents)
			latencies = append(latencies, time.Since(start))
			if err != nil {
				_ = db.Close()
				fatalf("search parent vectors query %q: %v", query.ID, err)
			}
			ranked = searchResultsToScoredDocs(hits)
		} else {
			hits, err := coll.SearchVector(query.Vector, *overfetch)
			latencies = append(latencies, time.Since(start))
			if err != nil {
				_ = db.Close()
				fatalf("search query %q: %v", query.ID, err)
			}
			ranked = rollupParents(hits, *topParents)
		}
		rels := qrels[query.ID]
		totals.NDCGAt10 += ndcgAt(ranked, rels, 10)
		totals.RecallAt100 += recallAt(ranked, rels, 100)
	}
	searchSeconds := time.Since(searchStart).Seconds()
	queryCount := len(queries)
	if queryCount > 0 {
		totals.NDCGAt10 /= float64(queryCount)
		totals.RecallAt100 /= float64(queryCount)
	}

	if err := db.Close(); err != nil {
		fatalf("close corkscrewdb: %v", err)
	}
	dbBytes, err := dirSize(*dbPath)
	if err != nil {
		fatalf("size db dir: %v", err)
	}

	quantizedVectorBytes := int64((dim**bits + 7) / 8)
	quantizedVectorBytes += int64((dim + 7) / 8)
	quantizedVectorBytes += 4
	insertCount := len(children)
	if *layout == "single_parent_vectors" {
		insertCount = parentCount
	}
	quantizedChildBytes := quantizedVectorBytes * int64(insertCount)
	baselineBytes := int64(parentCount * *baselineDim * 4)
	if baselineBytes <= 0 {
		fatalf("baseline bytes must be positive")
	}

	searchMode := "search_vector_child_overfetch_rollup"
	parentSearchExact := false
	if *layout == "packed_parent_multivectors" {
		searchMode = "search_parents_vector_exact_flat_rollup"
		parentSearchExact = true
	} else if *layout == "single_parent_vectors" {
		searchMode = "search_vector_parent_single"
		parentSearchExact = true
	}

	metrics := smokeMetrics{
		Bits:                         *bits,
		Dimension:                    dim,
		InsertCount:                  insertCount,
		ParentInsertCount:            parentInsertCount,
		ParentCount:                  parentCount,
		QueryCount:                   queryCount,
		RelevantPairs:                relevantPairs,
		OverfetchChildren:            *overfetch,
		TopKParents:                  *topParents,
		Collection:                   *collection,
		Dataset:                      *dataset,
		LoadSeconds:                  loadSeconds,
		SearchSeconds:                searchSeconds,
		DBBytesAfterClose:            dbBytes,
		QuantizedVectorBytes:         quantizedVectorBytes,
		QuantizedChildBytes:          quantizedChildBytes,
		DenseParentBaselineBytes:     baselineBytes,
		VectorPayloadStorageMultiple: float64(quantizedChildBytes) / float64(baselineBytes),
		DBDirectoryStorageMultiple:   float64(dbBytes) / float64(baselineBytes),
		SearchLatency:                summarizeLatencies(latencies),
		Quality:                      totals,
		QuantizerSeed:                *seed,
		QuantizedOnly:                *quantOnly,
		IndexType:                    *indexType,
		VectorStorage:                *vectorStore,
		RebuildIndex:                 *rebuildIdx,
		RebuildSeconds:               rebuildSeconds,
		Layout:                       *layout,
		SearchMode:                   searchMode,
		ParentSearchExact:            parentSearchExact,
		PackedMetadataMode:           *packedMeta,
		PackedChildIDMode:            *packedIDs,
	}
	data, err := json.MarshalIndent(metrics, "", "  ")
	if err != nil {
		fatalf("marshal metrics: %v", err)
	}
	if err := os.WriteFile(*outPath, append(data, '\n'), 0o644); err != nil {
		fatalf("write metrics: %v", err)
	}
	fmt.Println(string(data))
}

func readChildVectors(path string) ([]childVector, int, int, error) {
	file, err := os.Open(path)
	if err != nil {
		return nil, 0, 0, err
	}
	defer file.Close()
	scanner := bufio.NewScanner(file)
	scanner.Buffer(make([]byte, 1024), 16*1024*1024)
	children := []childVector{}
	parents := map[string]struct{}{}
	dim := 0
	for scanner.Scan() {
		var row vectorRow
		if err := json.Unmarshal(scanner.Bytes(), &row); err != nil {
			return nil, 0, 0, err
		}
		vec := firstVector(row)
		if len(vec) == 0 {
			return nil, 0, 0, fmt.Errorf("child %q has empty vector", row.ChildID)
		}
		if dim == 0 {
			dim = len(vec)
		}
		if len(vec) != dim {
			return nil, 0, 0, fmt.Errorf("child %q dimension %d, want %d", row.ChildID, len(vec), dim)
		}
		parentID := row.ParentID
		if parentID == "" {
			parentID = row.ID
		}
		childID := row.ChildID
		if childID == "" {
			childID = row.ID
		}
		if parentID == "" || childID == "" {
			return nil, 0, 0, fmt.Errorf("child row missing parent_id/child_id or id")
		}
		children = append(children, childVector{ParentID: parentID, ChildID: childID, Vector: vec})
		parents[parentID] = struct{}{}
	}
	if err := scanner.Err(); err != nil {
		return nil, 0, 0, err
	}
	return children, dim, len(parents), nil
}

func readQueryVectors(path string) ([]queryVector, int, error) {
	file, err := os.Open(path)
	if err != nil {
		return nil, 0, err
	}
	defer file.Close()
	scanner := bufio.NewScanner(file)
	scanner.Buffer(make([]byte, 1024), 16*1024*1024)
	queries := []queryVector{}
	dim := 0
	for scanner.Scan() {
		var row vectorRow
		if err := json.Unmarshal(scanner.Bytes(), &row); err != nil {
			return nil, 0, err
		}
		vec := firstVector(row)
		if len(vec) == 0 {
			return nil, 0, fmt.Errorf("query %q has empty vector", row.ID)
		}
		if dim == 0 {
			dim = len(vec)
		}
		if len(vec) != dim {
			return nil, 0, fmt.Errorf("query %q dimension %d, want %d", row.ID, len(vec), dim)
		}
		if row.ID == "" {
			return nil, 0, fmt.Errorf("query row missing id")
		}
		queries = append(queries, queryVector{ID: row.ID, Vector: vec})
	}
	if err := scanner.Err(); err != nil {
		return nil, 0, err
	}
	return queries, dim, nil
}

func firstVector(row vectorRow) []float32 {
	switch {
	case len(row.Embedding) > 0:
		return row.Embedding
	case len(row.Vector) > 0:
		return row.Vector
	default:
		return row.Values
	}
}

func readQrels(path string) (map[string]map[string]float64, int, error) {
	file, err := os.Open(path)
	if err != nil {
		return nil, 0, err
	}
	defer file.Close()
	qrels := map[string]map[string]float64{}
	relevantPairs := 0
	reader := bufio.NewReader(file)
	for {
		line, err := reader.ReadString('\n')
		if err != nil && err != io.EOF {
			return nil, 0, err
		}
		line = strings.TrimSpace(line)
		if line != "" && !strings.HasPrefix(line, "query-id") {
			fields := strings.Fields(line)
			if len(fields) < 3 {
				return nil, 0, fmt.Errorf("malformed qrels line %q", line)
			}
			score, parseErr := strconv.ParseFloat(fields[2], 64)
			if parseErr != nil {
				return nil, 0, parseErr
			}
			if score > 0 {
				if qrels[fields[0]] == nil {
					qrels[fields[0]] = map[string]float64{}
				}
				qrels[fields[0]][fields[1]] = score
				relevantPairs++
			}
		}
		if err == io.EOF {
			break
		}
	}
	return qrels, relevantPairs, nil
}

func groupChildrenByParent(children []childVector) (map[string][]childVector, []string) {
	groups := make(map[string][]childVector)
	for _, child := range children {
		groups[child.ParentID] = append(groups[child.ParentID], child)
	}
	parentIDs := make([]string, 0, len(groups))
	for parentID := range groups {
		parentIDs = append(parentIDs, parentID)
	}
	sort.Strings(parentIDs)
	for _, parentID := range parentIDs {
		sort.Slice(groups[parentID], func(i, j int) bool {
			return groups[parentID][i].ChildID < groups[parentID][j].ChildID
		})
	}
	return groups, parentIDs
}

func meanPooledParentVectors(children []childVector) []childVector {
	groups, parentIDs := groupChildrenByParent(children)
	out := make([]childVector, 0, len(parentIDs))
	for _, parentID := range parentIDs {
		group := groups[parentID]
		if len(group) == 0 {
			continue
		}
		mean := make([]float32, len(group[0].Vector))
		for _, child := range group {
			for i, value := range child.Vector {
				mean[i] += value
			}
		}
		scale := float32(1.0 / float64(len(group)))
		for i := range mean {
			mean[i] *= scale
		}
		normalizeL2(mean)
		out = append(out, childVector{ParentID: parentID, ChildID: parentID, Vector: mean})
	}
	return out
}

func normalizeL2(v []float32) {
	sum := 0.0
	for _, value := range v {
		f := float64(value)
		sum += f * f
	}
	if sum == 0 {
		return
	}
	inv := float32(1.0 / math.Sqrt(sum))
	for i := range v {
		v[i] *= inv
	}
}

func packedParentMetadata(mode string, parentID string, dataset string) map[string]string {
	switch mode {
	case "full":
		return map[string]string{
			"parent_id": parentID,
			"dataset":   dataset,
		}
	case "minimal":
		return map[string]string{
			"parent_id": parentID,
		}
	default:
		return nil
	}
}

func packedChildID(mode string, sourceID string, ordinal string) string {
	if mode == "ordinal" {
		return ordinal
	}
	return sourceID
}

func packedChildMetadata(mode string, parentID string, childID string, ordinal string, dataset string) map[string]string {
	switch mode {
	case "full":
		return map[string]string{
			"parent_id": parentID,
			"child_id":  childID,
			"dataset":   dataset,
		}
	case "minimal":
		return nil
	default:
		return nil
	}
}

func rollupParents(hits []corkscrewdb.SearchResult, k int) []scoredDoc {
	best := make(map[string]float32, len(hits))
	for _, hit := range hits {
		parentID := hit.Metadata["parent_id"]
		if parentID == "" {
			parentID = hit.ID
		}
		if score, ok := best[parentID]; !ok || hit.Score > score {
			best[parentID] = hit.Score
		}
	}
	h := &parentHeap{}
	for id, score := range best {
		if h.Len() < k {
			heap.Push(h, parentCandidate{id: id, score: score})
			continue
		}
		if score > (*h)[0].score || (score == (*h)[0].score && id < (*h)[0].id) {
			(*h)[0] = parentCandidate{id: id, score: score}
			heap.Fix(h, 0)
		}
	}
	out := make([]scoredDoc, h.Len())
	for i := len(out) - 1; i >= 0; i-- {
		item := heap.Pop(h).(parentCandidate)
		out[i] = scoredDoc{ID: item.id, Score: item.score}
	}
	sort.Slice(out, func(i, j int) bool {
		if out[i].Score != out[j].Score {
			return out[i].Score > out[j].Score
		}
		return out[i].ID < out[j].ID
	})
	return out
}

func parentResultsToScoredDocs(hits []corkscrewdb.ParentSearchResult) []scoredDoc {
	out := make([]scoredDoc, 0, len(hits))
	for _, hit := range hits {
		out = append(out, scoredDoc{ID: hit.ID, Score: hit.Score})
	}
	return out
}

func searchResultsToScoredDocs(hits []corkscrewdb.SearchResult) []scoredDoc {
	out := make([]scoredDoc, 0, len(hits))
	for _, hit := range hits {
		out = append(out, scoredDoc{ID: hit.ID, Score: hit.Score})
	}
	return out
}

func ndcgAt(scores []scoredDoc, rels map[string]float64, k int) float64 {
	if len(rels) == 0 {
		return 0
	}
	dcg := 0.0
	limit := min(k, len(scores))
	for i := 0; i < limit; i++ {
		rel := rels[scores[i].ID]
		if rel <= 0 {
			continue
		}
		dcg += (math.Pow(2, rel) - 1) / math.Log2(float64(i)+2)
	}
	ideal := make([]float64, 0, len(rels))
	for _, rel := range rels {
		if rel > 0 {
			ideal = append(ideal, rel)
		}
	}
	sort.Slice(ideal, func(i, j int) bool { return ideal[i] > ideal[j] })
	idcg := 0.0
	limit = min(k, len(ideal))
	for i := 0; i < limit; i++ {
		idcg += (math.Pow(2, ideal[i]) - 1) / math.Log2(float64(i)+2)
	}
	if idcg == 0 {
		return 0
	}
	return dcg / idcg
}

func recallAt(scores []scoredDoc, rels map[string]float64, k int) float64 {
	if len(rels) == 0 {
		return 0
	}
	hits := 0
	limit := min(k, len(scores))
	for i := 0; i < limit; i++ {
		if rels[scores[i].ID] > 0 {
			hits++
		}
	}
	relevant := 0
	for _, rel := range rels {
		if rel > 0 {
			relevant++
		}
	}
	if relevant == 0 {
		return 0
	}
	return float64(hits) / float64(relevant)
}

func summarizeLatencies(latencies []time.Duration) latencyMetrics {
	if len(latencies) == 0 {
		return latencyMetrics{}
	}
	sort.Slice(latencies, func(i, j int) bool { return latencies[i] < latencies[j] })
	return latencyMetrics{
		P50MS: durationMillis(percentile(latencies, 0.50)),
		P95MS: durationMillis(percentile(latencies, 0.95)),
		P99MS: durationMillis(percentile(latencies, 0.99)),
		MaxMS: durationMillis(latencies[len(latencies)-1]),
	}
}

func percentile(values []time.Duration, p float64) time.Duration {
	if len(values) == 0 {
		return 0
	}
	idx := int(math.Ceil(p*float64(len(values)))) - 1
	if idx < 0 {
		idx = 0
	}
	if idx >= len(values) {
		idx = len(values) - 1
	}
	return values[idx]
}

func durationMillis(d time.Duration) float64 {
	return float64(d.Nanoseconds()) / 1_000_000
}

func dirSize(root string) (int64, error) {
	var total int64
	err := filepath.WalkDir(root, func(_ string, d os.DirEntry, err error) error {
		if err != nil {
			return err
		}
		if d.IsDir() {
			return nil
		}
		info, err := d.Info()
		if err != nil {
			return err
		}
		total += info.Size()
		return nil
	})
	return total, err
}

func fatalf(format string, args ...any) {
	_, _ = fmt.Fprintf(os.Stderr, format+"\n", args...)
	os.Exit(1)
}
`
