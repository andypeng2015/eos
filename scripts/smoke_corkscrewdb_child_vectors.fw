package main

import (
	"encoding/json"
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"strconv"
	"strings"
	"time"
)

const defaultCorkScrewDBRepo = "/home/draco/work/corkscrewdb"
const defaultQuantizerSeed int64 = 5581486560434873699
const layoutSeparateChildVectors = "separate_child_vectors"
const layoutPackedParentMultivectors = "packed_parent_multivectors"
const layoutSingleParentVectors = "single_parent_vectors"
const packedMetadataFull = "full"
const packedMetadataMinimal = "minimal"
const packedMetadataNone = "none"
const packedChildIDSource = "source"
const packedChildIDOrdinal = "ordinal"

type latencyMetrics struct {
	P50MS float64 `json:"p50_ms"`
	P95MS float64 `json:"p95_ms"`
	P99MS float64 `json:"p99_ms"`
	MaxMS float64 `json:"max_ms"`
}

type qualityMetrics struct {
	NDCGAt10    float64 `json:"ndcg_at_10"`
	RecallAt100 float64 `json:"recall_at_100"`
}

type bitMetrics struct {
	Bits                         int            `json:"bits"`
	Dimension                    int            `json:"dimension"`
	InsertCount                  int            `json:"insert_count"`
	ParentInsertCount            int            `json:"parent_insert_count"`
	ParentCount                  int            `json:"parent_count"`
	QueryCount                   int            `json:"query_count"`
	RelevantPairs                int            `json:"relevant_pairs"`
	OverfetchChildren            int            `json:"overfetch_children"`
	TopKParents                  int            `json:"top_k_parents"`
	Collection                   string         `json:"collection"`
	Dataset                      string         `json:"dataset"`
	LoadSeconds                  float64        `json:"load_seconds"`
	SearchSeconds                float64        `json:"search_seconds"`
	DBBytesAfterClose            int64          `json:"db_bytes_after_close"`
	QuantizedVectorBytes         int64          `json:"quantized_vector_bytes"`
	QuantizedChildBytes          int64          `json:"quantized_child_bytes"`
	DenseParentBaselineBytes     int64          `json:"dense_parent_baseline_bytes"`
	VectorPayloadStorageMultiple float64        `json:"vector_payload_storage_multiple"`
	DBDirectoryStorageMultiple   float64        `json:"db_directory_storage_multiple"`
	SearchLatency                latencyMetrics `json:"search_latency"`
	Quality                      qualityMetrics `json:"quality"`
	QuantizerSeed                int64          `json:"quantizer_seed"`
	QuantizedOnly                bool           `json:"quantized_only"`
	IndexType                    string         `json:"index_type"`
	VectorStorage                string         `json:"vector_storage"`
	RebuildIndex                 bool           `json:"rebuild_index"`
	RebuildSeconds               float64        `json:"rebuild_seconds"`
	Layout                       string         `json:"layout"`
	SearchMode                   string         `json:"search_mode"`
	ParentSearchExact            bool           `json:"parent_search_exact"`
	PackedMetadataMode           string         `json:"packed_metadata_mode"`
	PackedChildIDMode            string         `json:"packed_child_id_mode"`
}

type summaryRow struct {
	Bits                         int
	OverfetchChildren            int
	ParentInsertCount            int
	IndexType                    string
	VectorStorage                string
	Layout                       string
	SearchMode                   string
	ParentSearchExact            bool
	PackedMetadataMode           string
	PackedChildIDMode            string
	NDCGAt10                     float64
	RecallAt100                  float64
	VectorPayloadStorageMultiple float64
	DBDirectoryStorageMultiple   float64
	QuantizedVectorBytes         int64
	QuantizedChildBytes          int64
	DBBytesAfterClose            int64
	LoadSeconds                  float64
	RebuildSeconds               float64
	SearchSeconds                float64
	P50MS                        float64
	P95MS                        float64
	P99MS                        float64
	MaxMS                        float64
}

type manifest struct {
	Schema              string       `json:"schema"`
	GeneratedAt         string       `json:"generated_at"`
	RunDir              string       `json:"run_dir"`
	RepoRoot            string       `json:"repo_root"`
	CorkScrewDBRepo     string       `json:"corkscrewdb_repo"`
	Dataset             string       `json:"dataset"`
	Collection          string       `json:"collection"`
	ChildVectors        string       `json:"child_vectors"`
	QueryVectors        string       `json:"query_vectors"`
	Qrels               string       `json:"qrels"`
	GeneratedInputs     bool         `json:"generated_inputs"`
	Bits                string       `json:"bits"`
	QuantizerSeed       int64        `json:"quantizer_seed"`
	QuantizedOnly       bool         `json:"quantized_only"`
	IndexType           string       `json:"index_type"`
	VectorStorage       string       `json:"vector_storage"`
	RebuildIndex        bool         `json:"rebuild_index"`
	Layout              string       `json:"layout"`
	SearchMode          string       `json:"search_mode"`
	ParentSearchExact   bool         `json:"parent_search_exact"`
	PackedMetadataMode  string       `json:"packed_metadata_mode"`
	PackedChildIDMode   string       `json:"packed_child_id_mode"`
	OverfetchChildren   string       `json:"overfetch_children"`
