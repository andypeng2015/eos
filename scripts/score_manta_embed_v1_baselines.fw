func usage() {
	fmt.Println(`Build a baseline scoreboard for eos-embed-v1.

Required:
  EOS_SCOREBOARD_ARTIFACT=/path/to/eos-embed-v1.sealed.mll

Run:
  EOS_REPO_ROOT=$PWD ferrous-wheel run scripts/score_manta_embed_v1_baselines.fw

Optional pairwise eval:
  EOS_SCOREBOARD_PAIRWISE_JSONL=/path/to/eval.jsonl
  EOS_SCOREBOARD_HARD_JSONL=/path/to/hard-eval.jsonl
  EOS_SCOREBOARD_PAIRWISE_ARTIFACT=/path/to/eos-embed-v1.mll
  EOS_SCOREBOARD_TOKENIZER=/path/to/tokenizer.mll
  EOS_SCOREBOARD_NO_TOKENIZER=1

Optional retrieval eval:
  EOS_SCOREBOARD_RETRIEVAL_ROOT=/data/manta/datasets/eos-embed-v1
  EOS_SCOREBOARD_RETRIEVAL_DATASETS=scifact,nfcorpus,fiqa
  EOS_SCOREBOARD_BASELINE_LABEL=eos
  EOS_SCOREBOARD_HYBRID_BASELINE_LABEL=eos-hybrid
  EOS_SCOREBOARD_TURBOQUANT=1
  EOS_SCOREBOARD_TURBOQUANT_BASELINE=eos-turboquant
  EOS_SCOREBOARD_TURBOQUANT_RERANK_BASELINE=eos-turboquant-rerank
  EOS_SCOREBOARD_TURBOQUANT_BITS=4
  EOS_SCOREBOARD_TURBOQUANT_RERANK_OVERFETCH=250
  EOS_SCOREBOARD_TURBOQUANT_RERANK_STORAGE=fp16
  EOS_SCOREBOARD_EXTERNAL_VECTOR_ROOT=/data/external-vector-caches
  EOS_SCOREBOARD_EXTERNAL_VECTOR_DATASETS=scifact,nfcorpus,fiqa
  EOS_SCOREBOARD_EXTERNAL_VECTOR_BASELINE=qwen3
  EOS_SCOREBOARD_EXTERNAL_VECTOR_BACKEND=qwen3
  EOS_SCOREBOARD_EXTERNAL_VECTOR_ARTIFACT=Qwen/Qwen3-Embedding-0.6B
  EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT=1
  EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_BITS=2,4,8
  EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_RERANK_OVERFETCH=200
  EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_RERANK_STORAGE=fp16
  EOS_SCOREBOARD_HYBRID_RETRIEVAL=1
  EOS_SCOREBOARD_HYBRID_METHOD=minmax
  EOS_SCOREBOARD_HYBRID_ALPHA=0.75
  EOS_SCOREBOARD_HYBRID_RRF_K=60
  EOS_SCOREBOARD_HYBRID_RRF_LAMBDA=1.0
  EOS_SCOREBOARD_LONG_ROOT=/data/manta/datasets/longembed
  EOS_SCOREBOARD_LONG_DATASETS=passkey,needle
  EOS_SCOREBOARD_BM25_BASELINE=1
  EOS_SCOREBOARD_SPLIT=test
  EOS_SCOREBOARD_BATCH_SIZE=512
  EOS_SCOREBOARD_TOP_K=100
  EOS_SCOREBOARD_MAX_DOCS=0
  EOS_SCOREBOARD_MAX_QUERIES=0`)
}

func getenv(name string, fallback string) string {
	value := os.Getenv(name)
	if value != "" {
		return value
	}
	return fallback
}

func firstExistingDir(paths []string, fallback string) string {
	for _, path := range paths {
		if info, err := os.Stat(path); err == nil && info.IsDir() {
			return path
		}
	}
	return fallback
}

func step(label string) {
	fmt.Println(f"\n== {label} ==")
}

func hasRepoRoot(dir string) bool {
	if dir == "" {
		return false
	}
	_, err := os.Stat(filepath.Join(dir, "go.mod"))
	if err != nil {
		return false
	}
	_, err = os.Stat(filepath.Join(dir, ".git"))
	return err == nil
}

func findRoot() (string, error) {
	explicit := os.Getenv("EOS_REPO_ROOT")
	if hasRepoRoot(explicit) {
		return filepath.Abs(explicit)
	}
	pwd := os.Getenv("PWD")
	if hasRepoRoot(pwd) {
		return filepath.Abs(pwd)
	}
	cwd, err := os.Getwd()
	guard err == nil else return "", err
	if hasRepoRoot(cwd) {
		return filepath.Abs(cwd)
	}
	return "", fmt.Errorf("could not find repo root; set EOS_REPO_ROOT")
}

func shellQuote(value string) string {
	if value == "" {
		return "''"
	}
	if strings.ContainsAny(value, " \t\n'\"\\$`!*?[]{}()<>|&;") {
		return "'" + strings.ReplaceAll(value, "'", "'\\''") + "'"
	}
	return value
}

func renderCommand(name string, args []string) string {
	parts := []string{shellQuote(name)}
	for arg in args {
		parts = append(parts, shellQuote(arg))
	}
	return strings.Join(parts, " ")
}

func runCmd(cfg scoreboardConfig, label string, logName string, name string, args []string) error {
	step(label)
	logPath := filepath.Join(cfg.LogDir, logName)
	rendered := renderCommand(name, args)
	fmt.Println(f"+ {rendered}")
	err := os.WriteFile(logPath+".cmd", []byte(rendered+"\n"), 0o644)
	guard err == nil else return err
	logFile, err := os.Create(logPath)
	guard err == nil else return err
	defer logFile.Close()
	cmd := exec.Command(name, args...)
	cmd.Dir = cfg.Root
	cmd.Stdout = io.MultiWriter(os.Stdout, logFile)
	cmd.Stderr = io.MultiWriter(os.Stderr, logFile)
	err = cmd.Run()
	guard err == nil else return fmt.Errorf("%s failed; see %s: %w", label, logPath, err)
	return nil
}

func splitList(value string) []string {
	out := []string{}
	for _, raw := range strings.Split(value, ",") {
		item := strings.TrimSpace(raw)
		if item != "" {
			out = append(out, item)
		}
	}
	return out
}

func absIfSet(value string) (string, error) {
	if value == "" {
		return "", nil
	}
	return filepath.Abs(value)
}

func requireExistingFile(label string, path string) error {
	if path == "" {
		return nil
	}
	info, err := os.Stat(path)
	guard err == nil else return fmt.Errorf("%s does not exist: %s", label, path)
	guard !info.IsDir() else return fmt.Errorf("%s must be a file: %s", label, path)
	return nil
}

func trainPackageSidecar(path string) string {
	if strings.HasSuffix(path, ".mll") {
		return strings.TrimSuffix(path, ".mll") + ".train.mll"
	}
	return path + ".train.mll"
}

func inferPairwiseArtifact(artifact string) string {
	if !strings.HasSuffix(artifact, ".sealed.mll") {
		return artifact
	}
	candidate := strings.TrimSuffix(artifact, ".sealed.mll") + ".mll"
	if _, err := os.Stat(trainPackageSidecar(candidate)); err == nil {
		return candidate
	}
	return artifact
}

func prepareConfig(root string) (scoreboardConfig, error) {
	artifact, err := absIfSet(os.Getenv("EOS_SCOREBOARD_ARTIFACT"))
	guard err == nil else return scoreboardConfig{}, err
	guard artifact != "" else return scoreboardConfig{}, fmt.Errorf("EOS_SCOREBOARD_ARTIFACT is required")
	err = requireExistingFile("EOS_SCOREBOARD_ARTIFACT", artifact)
	guard err == nil else return scoreboardConfig{}, err

	pairwiseArtifact, err := absIfSet(os.Getenv("EOS_SCOREBOARD_PAIRWISE_ARTIFACT"))
	guard err == nil else return scoreboardConfig{}, err
	if pairwiseArtifact == "" {
		pairwiseArtifact = inferPairwiseArtifact(artifact)
	}
	err = requireExistingFile("EOS_SCOREBOARD_PAIRWISE_ARTIFACT", pairwiseArtifact)
	guard err == nil else return scoreboardConfig{}, err

	tokenizer, err := absIfSet(os.Getenv("EOS_SCOREBOARD_TOKENIZER"))
	guard err == nil else return scoreboardConfig{}, err
	err = requireExistingFile("EOS_SCOREBOARD_TOKENIZER", tokenizer)
	guard err == nil else return scoreboardConfig{}, err

	pairwise, err := absIfSet(os.Getenv("EOS_SCOREBOARD_PAIRWISE_JSONL"))
	guard err == nil else return scoreboardConfig{}, err
	err = requireExistingFile("EOS_SCOREBOARD_PAIRWISE_JSONL", pairwise)
	guard err == nil else return scoreboardConfig{}, err

	hard, err := absIfSet(os.Getenv("EOS_SCOREBOARD_HARD_JSONL"))
	guard err == nil else return scoreboardConfig{}, err
	err = requireExistingFile("EOS_SCOREBOARD_HARD_JSONL", hard)
	guard err == nil else return scoreboardConfig{}, err

	runID := getenv("EOS_SCOREBOARD_RUN_ID", "eos-embed-v1-scoreboard-"+time.Now().UTC().Format("20060102T150405Z"))
	runRoot, err := filepath.Abs(getenv("EOS_SCOREBOARD_RUN_ROOT", filepath.Join(root, "runs")))
	guard err == nil else return scoreboardConfig{}, err
	runDir := filepath.Join(runRoot, runID)
	if entries, err := os.ReadDir(runDir); err == nil && len(entries) > 0 {
		return scoreboardConfig{}, fmt.Errorf("run directory already exists and is not empty: %s", runDir)
	}
	err = os.MkdirAll(filepath.Join(runDir, "bin"), 0o755)
	guard err == nil else return scoreboardConfig{}, err
	err = os.MkdirAll(filepath.Join(runDir, "logs"), 0o755)
	guard err == nil else return scoreboardConfig{}, err

	retrievalDatasets := splitList(os.Getenv("EOS_SCOREBOARD_RETRIEVAL_DATASETS"))
	externalVectorDatasets := splitList(os.Getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_DATASETS"))
	longDatasets := splitList(os.Getenv("EOS_SCOREBOARD_LONG_DATASETS"))
	guard pairwise != "" || hard != "" || len(retrievalDatasets) > 0 || len(externalVectorDatasets) > 0 || len(longDatasets) > 0 else {
		return scoreboardConfig{}, fmt.Errorf("provide at least one eval source: pairwise JSONL, hard JSONL, retrieval datasets, external vector datasets, or long datasets")
	}

	defaultRetrievalRoot := firstExistingDir([]string{
		filepath.Join(root, "datasets", "eos-embed-v1"),
		filepath.Join(root, "datasets", "manta-embed-v1"),
	}, filepath.Join(root, "datasets", "eos-embed-v1"))
	retrievalRoot, err := filepath.Abs(getenv("EOS_SCOREBOARD_RETRIEVAL_ROOT", defaultRetrievalRoot))
	guard err == nil else return scoreboardConfig{}, err
	externalVectorRoot, err := filepath.Abs(getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_ROOT", filepath.Join(root, "runs", "external-vector-caches")))
	guard err == nil else return scoreboardConfig{}, err
	longRoot, err := filepath.Abs(getenv("EOS_SCOREBOARD_LONG_ROOT", filepath.Join(root, "datasets", "longembed")))
	guard err == nil else return scoreboardConfig{}, err
	turboQuantRerankStorage := getenv("EOS_SCOREBOARD_TURBOQUANT_RERANK_STORAGE", "dense")

	return scoreboardConfig{
		Root:              root,
		RunID:             runID,
		RunRoot:           runRoot,
		RunDir:            runDir,
		LogDir:            filepath.Join(runDir, "logs"),
		MantaBin:          filepath.Join(runDir, "bin", "manta"),
		Artifact:          artifact,
		PairwiseArtifact:  pairwiseArtifact,
		Tokenizer:         tokenizer,
		NoTokenizer:       getenv("EOS_SCOREBOARD_NO_TOKENIZER", "0"),
		PairwiseEvalJSONL: pairwise,
		HardEvalJSONL:     hard,
		RetrievalRoot:     retrievalRoot,
		RetrievalDatasets: retrievalDatasets,
		BaselineLabel:     getenv("EOS_SCOREBOARD_BASELINE_LABEL", "eos"),
		HybridBaselineLabel: getenv("EOS_SCOREBOARD_HYBRID_BASELINE_LABEL", "eos-hybrid"),
		TurboQuant:        getenv("EOS_SCOREBOARD_TURBOQUANT", "0"),
		TurboQuantBaseline: getenv("EOS_SCOREBOARD_TURBOQUANT_BASELINE", "eos-turboquant"),
		TurboQuantRerankBaseline: getenv("EOS_SCOREBOARD_TURBOQUANT_RERANK_BASELINE", "eos-turboquant-rerank"),
		TurboQuantBits:    getenv("EOS_SCOREBOARD_TURBOQUANT_BITS", "8"),
		TurboQuantRerankOverfetch: getenv("EOS_SCOREBOARD_TURBOQUANT_RERANK_OVERFETCH", ""),
		TurboQuantRerankStorage: turboQuantRerankStorage,
		ExternalVectorRoot:     externalVectorRoot,
		ExternalVectorDatasets: externalVectorDatasets,
		ExternalVectorBaseline: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_BASELINE", "external-vectors"),
		ExternalVectorBackend:  getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_BACKEND", "external-vectors"),
		ExternalVectorArtifact: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_ARTIFACT", ""),
		ExternalVectorTurboQuant: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT", "0"),
		ExternalVectorTurboQuantBits: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_BITS", "2,4,8"),
		ExternalVectorTurboQuantRerankOverfetch: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_RERANK_OVERFETCH", ""),
		ExternalVectorTurboQuantRerankStorage: getenv("EOS_SCOREBOARD_EXTERNAL_VECTOR_TURBOQUANT_RERANK_STORAGE", turboQuantRerankStorage),
		HybridRetrieval: getenv("EOS_SCOREBOARD_HYBRID_RETRIEVAL", "0"),
		HybridMethod: getenv("EOS_SCOREBOARD_HYBRID_METHOD", "minmax"),
		HybridAlpha: getenv("EOS_SCOREBOARD_HYBRID_ALPHA", "0.75"),
		HybridRRFK: getenv("EOS_SCOREBOARD_HYBRID_RRF_K", "60"),
		HybridRRFLambda: getenv("EOS_SCOREBOARD_HYBRID_RRF_LAMBDA", "1.0"),
		LongRoot:          longRoot,
		LongDatasets:      longDatasets,
		Split:             getenv("EOS_SCOREBOARD_SPLIT", "test"),
		BatchSize:         getenv("EOS_SCOREBOARD_BATCH_SIZE", "512"),
		TopK:              getenv("EOS_SCOREBOARD_TOP_K", "100"),
		MaxDocs:           getenv("EOS_SCOREBOARD_MAX_DOCS", "0"),
		MaxQueries:        getenv("EOS_SCOREBOARD_MAX_QUERIES", "0"),
		BM25Baseline:      getenv("EOS_SCOREBOARD_BM25_BASELINE", "1"),
		ScoreboardTSV:     filepath.Join(runDir, "scoreboard.tsv"),
		ScoreboardJSON:    filepath.Join(runDir, "scoreboard.json"),
	}, nil
}

func metricsFileName(category string, dataset string, baseline string) string {
	name := strings.ReplaceAll(category+"."+dataset+"."+baseline, "/", "_")
	name = strings.ReplaceAll(name, " ", "_")
	name = strings.ReplaceAll(name, ",", "_")
	return name + ".metrics.json"
}

func readTrainMetrics(path string) (trainMetrics, error) {
	data, err := os.ReadFile(path)
	guard err == nil else return trainMetrics{}, err
	var metrics trainMetrics
	err = json.Unmarshal(data, &metrics)
	guard err == nil else return trainMetrics{}, err
	return metrics, nil
}

func readRetrievalMetrics(path string) (retrievalMetrics, error) {
	data, err := os.ReadFile(path)
	guard err == nil else return retrievalMetrics{}, err
	var metrics retrievalMetrics
	err = json.Unmarshal(data, &metrics)
	guard err == nil else return retrievalMetrics{}, err
	return metrics, nil
}

func readTurboQuantRetrievalMetrics(path string) (turboQuantRetrievalMetrics, error) {
	data, err := os.ReadFile(path)
	guard err == nil else return turboQuantRetrievalMetrics{}, err
	var metrics turboQuantRetrievalMetrics
	err = json.Unmarshal(data, &metrics)
	guard err == nil else return turboQuantRetrievalMetrics{}, err
	return metrics, nil
}

func rowFromTrainMetrics(category string, dataset string, baseline string, metricsPath string, metrics trainMetrics) scoreboardRow {
	row := scoreboardRow{
		Category:           category,
		Dataset:            dataset,
		Baseline:           baseline,
		Status:             "pass",
		MetricsPath:        metricsPath,
		ElapsedSeconds:     metrics.Throughput.ElapsedSeconds,
		EvalPairsPerSecond: metrics.Throughput.EvalPairsPerSecond,
		OptimizerUpdates:   metrics.ProfileDelta.OptimizerUpdates,
		ForwardBackend:     metrics.Accelerators.Forward,
	}
	if metrics.FinalEval != nil {
		row.Top1Accuracy = metrics.FinalEval.Top1Accuracy
		row.MeanReciprocalRank = metrics.FinalEval.MeanReciprocalRank
		row.ROCAUC = metrics.FinalEval.ROCAUC
		row.ScoreMargin = metrics.FinalEval.ScoreMargin
		row.Loss = metrics.FinalEval.Loss
		row.PairCount = metrics.FinalEval.PairCount
	}
	return row
}

func rowFromRetrievalMetrics(category string, baseline string, metricsPath string, metrics retrievalMetrics) scoreboardRow {
	return scoreboardRow{
		Category:           category,
		Dataset:            metrics.Dataset,
		Baseline:           baseline,
		Status:             "pass",
		MetricsPath:        metricsPath,
		NDCGAt10:           metrics.Quality.NDCGAt10,
		NDCGAt100:          metrics.Quality.NDCGAt100,
		MRRAt10:            metrics.Quality.MRRAt10,
		PrecisionAt1:       metrics.Quality.PrecisionAt1,
		PrecisionAt5:       metrics.Quality.PrecisionAt5,
		PrecisionAt10:      metrics.Quality.PrecisionAt10,
		HitAt1:             metrics.Quality.HitAt1,
		HitAt5:             metrics.Quality.HitAt5,
		HitAt10:            metrics.Quality.HitAt10,
		MAPAt10:            metrics.Quality.MAPAt10,
		MAPAt100:           metrics.Quality.MAPAt100,
		RecallAt10:         metrics.Quality.RecallAt10,
		RecallAt100:        metrics.Quality.RecallAt100,
		Documents:          metrics.Inputs.Documents,
		Queries:            metrics.Inputs.Queries,
		ElapsedSeconds:     metrics.Throughput.ElapsedSeconds,
		DocumentsPerSecond: metrics.Throughput.DocumentsPerSecond,
		QueriesPerSecond:   metrics.Throughput.QueriesPerSecond,
		ScoresPerSecond:    metrics.Throughput.ScoresPerSecond,
		ForwardBackend:     metrics.Backend,
	}
}

func rowsFromTurboQuantRetrievalMetrics(category string, baseline string, rerankBaseline string, metricsPath string, metrics turboQuantRetrievalMetrics) []scoreboardRow {
	rows := []scoreboardRow{}
	for _, bitRow := range metrics.Rows {
		rowBaseline := baseline
		if bitRow.RerankOverfetch > 0 && rerankBaseline != "" {
			rowBaseline = rerankBaseline
		}
		row := scoreboardRow{
			Category:           category,
			Dataset:            metrics.Dataset,
			Baseline:           rowBaseline,
			Status:             "pass",
			MetricsPath:        metricsPath,
			Method:             bitRow.Method,
			Bits:               bitRow.Bits,
			QuantizerSeed:      bitRow.QuantizerSeed,
			RerankOverfetch:    bitRow.RerankOverfetch,
			RerankStorage:      bitRow.RerankStorage,
			NDCGAt10:           bitRow.Quality.NDCGAt10,
			NDCGAt100:          bitRow.Quality.NDCGAt100,
			MRRAt10:            bitRow.Quality.MRRAt10,
			PrecisionAt1:       bitRow.Quality.PrecisionAt1,
			PrecisionAt5:       bitRow.Quality.PrecisionAt5,
			PrecisionAt10:      bitRow.Quality.PrecisionAt10,
			HitAt1:             bitRow.Quality.HitAt1,
			HitAt5:             bitRow.Quality.HitAt5,
			HitAt10:            bitRow.Quality.HitAt10,
			MAPAt10:            bitRow.Quality.MAPAt10,
			MAPAt100:           bitRow.Quality.MAPAt100,
			RecallAt10:         bitRow.Quality.RecallAt10,
			RecallAt100:        bitRow.Quality.RecallAt100,
			NDCGAt10Delta:      bitRow.NDCGAt10Delta,
			RecallAt100Delta:   bitRow.RecallAt100Delta,
			VectorBytes:        bitRow.VectorBytes,
			DenseVectorBytes:   bitRow.DenseVectorBytes,
			RerankSidecarBytes: bitRow.RerankSidecarBytes,
			TotalVectorBytes:   bitRow.TotalVectorBytes,
			CompressionRatio:   bitRow.CompressionRatio,
			TotalCompressionRatio: bitRow.TotalCompressionRatio,
			DocsPerSecond:      bitRow.DocsPerSecond,
			Documents:          metrics.Inputs.Documents,
			Queries:            metrics.Inputs.Queries,
			ScoresPerSecond:    bitRow.ScoresPerSecond,
			RerankScores:       bitRow.RerankScores,
			ForwardBackend:     metrics.Backend,
		}
		if row.TotalVectorBytes == 0 {
			row.TotalVectorBytes = row.VectorBytes
		}
		if row.TotalCompressionRatio == 0 {
			row.TotalCompressionRatio = row.CompressionRatio
		}
		if row.QuantizerSeed == 0 {
			row.QuantizerSeed = metrics.Config.QuantizerSeed
		}
		rows = append(rows, row)
	}
	return rows
}

func tsvHeader() string {
	return "category\tdataset\tbaseline\tstatus\tmetrics_path\tmethod\tbits\trerank_storage\tndcg_at_10\tndcg_at_100\tmrr_at_10\tprecision_at_1\tprecision_at_5\tprecision_at_10\thit_at_1\thit_at_5\thit_at_10\tmap_at_10\tmap_at_100\trecall_at_10\trecall_at_100\tndcg_at_10_delta\trecall_at_100_delta\tvector_bytes\tdense_vector_bytes\trerank_sidecar_bytes\ttotal_vector_bytes\tcompression_ratio\ttotal_compression_ratio\tdocs_per_second\ttop1_accuracy\tmean_reciprocal_rank\troc_auc\tscore_margin\tloss\tpair_count\tdocuments\tqueries\telapsed_seconds\teval_pairs_per_second\tdocuments_per_second\tqueries_per_second\tscores_per_second\toptimizer_updates\tforward_backend\trerank_overfetch\trerank_scores\n"
}

func formatRow(row scoreboardRow) string {
	return fmt.Sprintf("%s\t%s\t%s\t%s\t%s\t%s\t%d\t%s\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%+.6f\t%+.6f\t%d\t%d\t%d\t%d\t%.6f\t%.6f\t%.2f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%d\t%d\t%d\t%.3f\t%.2f\t%.2f\t%.2f\t%.2f\t%d\t%s\t%d\t%d\n",
		row.Category,
		row.Dataset,
		row.Baseline,
		row.Status,
		row.MetricsPath,
		row.Method,
		row.Bits,
		row.RerankStorage,
		row.NDCGAt10,
		row.NDCGAt100,
		row.MRRAt10,
		row.PrecisionAt1,
		row.PrecisionAt5,
		row.PrecisionAt10,
		row.HitAt1,
		row.HitAt5,
		row.HitAt10,
		row.MAPAt10,
		row.MAPAt100,
		row.RecallAt10,
		row.RecallAt100,
		row.NDCGAt10Delta,
		row.RecallAt100Delta,
		row.VectorBytes,
		row.DenseVectorBytes,
		row.RerankSidecarBytes,
		row.TotalVectorBytes,
		row.CompressionRatio,
		row.TotalCompressionRatio,
		row.DocsPerSecond,
		row.Top1Accuracy,
		row.MeanReciprocalRank,
		row.ROCAUC,
		row.ScoreMargin,
		row.Loss,
		row.PairCount,
		row.Documents,
		row.Queries,
		row.ElapsedSeconds,
		row.EvalPairsPerSecond,
		row.DocumentsPerSecond,
		row.QueriesPerSecond,
		row.ScoresPerSecond,
		row.OptimizerUpdates,
		row.ForwardBackend,
		row.RerankOverfetch,
		row.RerankScores)
}

func appendScoreboardRow(path string, row scoreboardRow) error {
	file, err := os.OpenFile(path, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)
	guard err == nil else return err
	defer file.Close()
	_, err = file.WriteString(formatRow(row))
	return err
}

func runPairwiseEval(cfg scoreboardConfig, dataset string, inputPath string, rows []scoreboardRow) ([]scoreboardRow, error) {
	if inputPath == "" {
		return rows, nil
	}
	metricsPath := filepath.Join(cfg.RunDir, metricsFileName("pairwise", dataset, cfg.BaselineLabel))
	args := []string{"train-embed", "--eval-only", "--metrics-json", metricsPath}
	if cfg.Tokenizer != "" {
		args = append(args, "--tokenizer", cfg.Tokenizer)
	}
	if cfg.NoTokenizer != "0" {
		args = append(args, "--no-tokenizer")
	}
	args = append(args, cfg.PairwiseArtifact, inputPath)
	err := runCmd(cfg, "Evaluate pairwise "+dataset, "pairwise-"+dataset+".log", cfg.MantaBin, args)
	guard err == nil else return rows, err
	metrics, err := readTrainMetrics(metricsPath)
	guard err == nil else return rows, err
	row := rowFromTrainMetrics("pairwise", dataset, cfg.BaselineLabel, metricsPath, metrics)
	err = appendScoreboardRow(cfg.ScoreboardTSV, row)
	guard err == nil else return rows, err
	return append(rows, row), nil
}

func retrievalDatasetDir(root string, dataset string) string {
	candidate := filepath.Join(root, "raw", dataset, dataset)
	if _, err := os.Stat(candidate); err == nil {
		return candidate
	}
	return filepath.Join(root, dataset)
}

func retrievalArgs(cfg scoreboardConfig, command string, dataset string, metricsPath string, dir string) []string {
	args := []string{
		command,
		"--dataset", dataset,
		"--split", cfg.Split,
		"--top-k", cfg.TopK,
		"--metrics-json", metricsPath,
	}
	if command == "eval-retrieval" {
		args = append(args, "--batch-size", cfg.BatchSize)
	}
	if command == "eval-retrieval-hybrid" {
		args = append(args, "--batch-size", cfg.BatchSize)
		args = appendHybridArgs(args, cfg)
	}
	if cfg.MaxDocs != "" && cfg.MaxDocs != "0" {
		args = append(args, "--max-docs", cfg.MaxDocs)
	}
	if cfg.MaxQueries != "" && cfg.MaxQueries != "0" {
		args = append(args, "--max-queries", cfg.MaxQueries)
	}
	if command == "eval-retrieval" || command == "eval-retrieval-hybrid" {
		args = append(args, cfg.Artifact)
	}
	return append(args, dir)
}

func appendHybridArgs(args []string, cfg scoreboardConfig) []string {
	args = append(args, "--method", cfg.HybridMethod)
	args = append(args, "--alpha", cfg.HybridAlpha)
	args = append(args, "--rrf-k", cfg.HybridRRFK)
	args = append(args, "--rrf-lambda", cfg.HybridRRFLambda)
	return args
}

func hybridMethodLabel(cfg scoreboardConfig) string {
	method := strings.ToLower(strings.TrimSpace(cfg.HybridMethod))
	if method == "" {
		method = "minmax"
	}
	if method == "rrf" {
		return "hybrid_rrf_k" + cfg.HybridRRFK + "_lambda" + cfg.HybridRRFLambda
	}
	if method == "minmax_blend" {
		method = "minmax"
	}
	if method == "zscore_blend" {
		method = "zscore"
	}
	return "hybrid_" + method + "_alpha" + cfg.HybridAlpha
}

func vectorCachePaths(root string, dataset string) (string, string) {
	dir := filepath.Join(root, dataset)
	return filepath.Join(dir, "doc-vectors.jsonl"), filepath.Join(dir, "query-vectors.jsonl")
}

func retrievalVectorArgs(cfg scoreboardConfig, dataset string, metricsPath string, dir string, docVectors string, queryVectors string) []string {
	args := []string{
		"eval-retrieval-vectors",
		"--dataset", dataset,
		"--split", cfg.Split,
		"--top-k", cfg.TopK,
		"--backend", cfg.ExternalVectorBackend,
		"--doc-vectors", docVectors,
		"--query-vectors", queryVectors,
		"--metrics-json", metricsPath,
	}
	if cfg.ExternalVectorArtifact != "" {
		args = append(args, "--artifact", cfg.ExternalVectorArtifact)
	}
	if cfg.MaxDocs != "" && cfg.MaxDocs != "0" {
		args = append(args, "--max-docs", cfg.MaxDocs)
	}
	if cfg.MaxQueries != "" && cfg.MaxQueries != "0" {
		args = append(args, "--max-queries", cfg.MaxQueries)
	}
	return append(args, dir)
}

func retrievalVectorHybridArgs(cfg scoreboardConfig, dataset string, metricsPath string, dir string, docVectors string, queryVectors string) []string {
	args := []string{
		"eval-retrieval-vectors-hybrid",
		"--dataset", dataset,
		"--split", cfg.Split,
		"--top-k", cfg.TopK,
		"--backend", cfg.ExternalVectorBackend+"-hybrid",
		"--doc-vectors", docVectors,
		"--query-vectors", queryVectors,
		"--metrics-json", metricsPath,
	}
	args = appendHybridArgs(args, cfg)
	if cfg.ExternalVectorArtifact != "" {
		args = append(args, "--artifact", cfg.ExternalVectorArtifact)
	}
	if cfg.MaxDocs != "" && cfg.MaxDocs != "0" {
		args = append(args, "--max-docs", cfg.MaxDocs)
	}
	if cfg.MaxQueries != "" && cfg.MaxQueries != "0" {
		args = append(args, "--max-queries", cfg.MaxQueries)
	}
	return append(args, dir)
}

func retrievalVectorTurboQuantArgs(cfg scoreboardConfig, dataset string, metricsPath string, metricsTSVPath string, dir string, docVectors string, queryVectors string) []string {
	args := []string{
		"eval-retrieval-vectors-turboquant",
		"--dataset", dataset,
		"--split", cfg.Split,
		"--top-k", cfg.TopK,
		"--backend", cfg.ExternalVectorBackend,
		"--bits", cfg.ExternalVectorTurboQuantBits,
		"--doc-vectors", docVectors,
		"--query-vectors", queryVectors,
		"--metrics-json", metricsPath,
		"--metrics-tsv", metricsTSVPath,
	}
	if cfg.ExternalVectorTurboQuantRerankOverfetch != "" {
		args = append(args, "--rerank-overfetch", cfg.ExternalVectorTurboQuantRerankOverfetch)
	}
	args = append(args, "--rerank-storage", cfg.ExternalVectorTurboQuantRerankStorage)
	if cfg.ExternalVectorArtifact != "" {
		args = append(args, "--artifact", cfg.ExternalVectorArtifact)
	}
	if cfg.MaxDocs != "" && cfg.MaxDocs != "0" {
		args = append(args, "--max-docs", cfg.MaxDocs)
	}
	if cfg.MaxQueries != "" && cfg.MaxQueries != "0" {
		args = append(args, "--max-queries", cfg.MaxQueries)
	}
	return append(args, dir)
}

func retrievalTurboQuantArgs(cfg scoreboardConfig, dataset string, metricsPath string, metricsTSVPath string, dir string) []string {
	args := []string{
		"eval-retrieval-turboquant",
		"--dataset", dataset,
		"--split", cfg.Split,
		"--top-k", cfg.TopK,
		"--bits", cfg.TurboQuantBits,
		"--metrics-json", metricsPath,
		"--metrics-tsv", metricsTSVPath,
	}
	if cfg.TurboQuantRerankOverfetch != "" {
		args = append(args, "--rerank-overfetch", cfg.TurboQuantRerankOverfetch)
	}
	args = append(args, "--rerank-storage", cfg.TurboQuantRerankStorage)
	if cfg.MaxDocs != "" && cfg.MaxDocs != "0" {
		args = append(args, "--max-docs", cfg.MaxDocs)
	}
	if cfg.MaxQueries != "" && cfg.MaxQueries != "0" {
		args = append(args, "--max-queries", cfg.MaxQueries)
	}
	args = append(args, cfg.Artifact)
	return append(args, dir)
}

func runExternalVectorRetrievalGroup(cfg scoreboardConfig, category string, dataRoot string, vectorRoot string, datasets []string, rows []scoreboardRow) ([]scoreboardRow, error) {
	for dataset in datasets {
		dir := retrievalDatasetDir(dataRoot, dataset)
		info, err := os.Stat(dir)
		guard err == nil && info.IsDir() else return rows, fmt.Errorf("%s dataset directory missing for %s: %s", category, dataset, dir)
		docVectors, queryVectors := vectorCachePaths(vectorRoot, dataset)
		err = requireExistingFile("external document vector cache", docVectors)
		guard err == nil else return rows, err
		err = requireExistingFile("external query vector cache", queryVectors)
		guard err == nil else return rows, err
		metricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, cfg.ExternalVectorBaseline))
		args := retrievalVectorArgs(cfg, dataset, metricsPath, dir, docVectors, queryVectors)
		err = runCmd(cfg, "Evaluate "+category+" "+cfg.ExternalVectorBaseline+" "+dataset, category+"-"+dataset+"-"+cfg.ExternalVectorBaseline+".log", cfg.MantaBin, args)
		guard err == nil else return rows, err
		metrics, err := readRetrievalMetrics(metricsPath)
		guard err == nil else return rows, err
		row := rowFromRetrievalMetrics(category, cfg.ExternalVectorBaseline, metricsPath, metrics)
		err = appendScoreboardRow(cfg.ScoreboardTSV, row)
		guard err == nil else return rows, err
		rows = append(rows, row)
		if cfg.HybridRetrieval != "0" {
			hybridBaseline := cfg.ExternalVectorBaseline + "-hybrid"
			hybridMetricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, hybridBaseline))
			hybridArgs := retrievalVectorHybridArgs(cfg, dataset, hybridMetricsPath, dir, docVectors, queryVectors)
			err = runCmd(cfg, "Evaluate "+category+" "+hybridBaseline+" "+dataset, category+"-"+dataset+"-"+hybridBaseline+".log", cfg.MantaBin, hybridArgs)
			guard err == nil else return rows, err
			hybridMetrics, err := readRetrievalMetrics(hybridMetricsPath)
			guard err == nil else return rows, err
			hybridRow := rowFromRetrievalMetrics(category, hybridBaseline, hybridMetricsPath, hybridMetrics)
			hybridRow.Method = hybridMethodLabel(cfg)
			err = appendScoreboardRow(cfg.ScoreboardTSV, hybridRow)
			guard err == nil else return rows, err
			rows = append(rows, hybridRow)
		}
		if cfg.ExternalVectorTurboQuant != "0" {
			turboQuantBaseline := cfg.ExternalVectorBaseline + "-turboquant"
			turboQuantMetricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, turboQuantBaseline))
			turboQuantTSVPath := filepath.Join(cfg.RunDir, strings.TrimSuffix(metricsFileName(category, dataset, turboQuantBaseline), ".json")+".tsv")
			turboQuantArgs := retrievalVectorTurboQuantArgs(cfg, dataset, turboQuantMetricsPath, turboQuantTSVPath, dir, docVectors, queryVectors)
			err = runCmd(cfg, "Evaluate "+category+" "+turboQuantBaseline+" "+dataset, category+"-"+dataset+"-"+turboQuantBaseline+".log", cfg.MantaBin, turboQuantArgs)
			guard err == nil else return rows, err
			turboQuantMetrics, err := readTurboQuantRetrievalMetrics(turboQuantMetricsPath)
			guard err == nil else return rows, err
			turboQuantRows := rowsFromTurboQuantRetrievalMetrics(category, turboQuantBaseline, "", turboQuantMetricsPath, turboQuantMetrics)
			for _, turboQuantRow := range turboQuantRows {
				err = appendScoreboardRow(cfg.ScoreboardTSV, turboQuantRow)
				guard err == nil else return rows, err
				rows = append(rows, turboQuantRow)
			}
		}
	}
	return rows, nil
}

func runRetrievalGroup(cfg scoreboardConfig, category string, root string, datasets []string, rows []scoreboardRow) ([]scoreboardRow, error) {
	for dataset in datasets {
		dir := retrievalDatasetDir(root, dataset)
		info, err := os.Stat(dir)
		guard err == nil && info.IsDir() else return rows, fmt.Errorf("%s dataset directory missing for %s: %s", category, dataset, dir)
		if cfg.BM25Baseline != "0" {
			bm25MetricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, "bm25"))
			bm25Args := retrievalArgs(cfg, "eval-retrieval-bm25", dataset, bm25MetricsPath, dir)
			err = runCmd(cfg, "Evaluate "+category+" BM25 "+dataset, category+"-"+dataset+"-bm25.log", cfg.MantaBin, bm25Args)
			guard err == nil else return rows, err
			bm25Metrics, err := readRetrievalMetrics(bm25MetricsPath)
			guard err == nil else return rows, err
			row := rowFromRetrievalMetrics(category, "bm25", bm25MetricsPath, bm25Metrics)
			err = appendScoreboardRow(cfg.ScoreboardTSV, row)
			guard err == nil else return rows, err
			rows = append(rows, row)
		}
		metricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, cfg.BaselineLabel))
		args := retrievalArgs(cfg, "eval-retrieval", dataset, metricsPath, dir)
		err = runCmd(cfg, "Evaluate "+category+" "+dataset, category+"-"+dataset+".log", cfg.MantaBin, args)
		guard err == nil else return rows, err
		metrics, err := readRetrievalMetrics(metricsPath)
		guard err == nil else return rows, err
		row := rowFromRetrievalMetrics(category, cfg.BaselineLabel, metricsPath, metrics)
		err = appendScoreboardRow(cfg.ScoreboardTSV, row)
		guard err == nil else return rows, err
		rows = append(rows, row)
		if cfg.HybridRetrieval != "0" {
			hybridMetricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, cfg.HybridBaselineLabel))
			hybridArgs := retrievalArgs(cfg, "eval-retrieval-hybrid", dataset, hybridMetricsPath, dir)
			err = runCmd(cfg, "Evaluate "+category+" "+cfg.HybridBaselineLabel+" "+dataset, category+"-"+dataset+"-"+cfg.HybridBaselineLabel+".log", cfg.MantaBin, hybridArgs)
			guard err == nil else return rows, err
			hybridMetrics, err := readRetrievalMetrics(hybridMetricsPath)
			guard err == nil else return rows, err
			hybridRow := rowFromRetrievalMetrics(category, cfg.HybridBaselineLabel, hybridMetricsPath, hybridMetrics)
			hybridRow.Method = hybridMethodLabel(cfg)
			err = appendScoreboardRow(cfg.ScoreboardTSV, hybridRow)
			guard err == nil else return rows, err
			rows = append(rows, hybridRow)
		}
		if cfg.TurboQuant != "0" {
			turboQuantMetricsPath := filepath.Join(cfg.RunDir, metricsFileName(category, dataset, cfg.TurboQuantBaseline))
			turboQuantTSVPath := filepath.Join(cfg.RunDir, strings.TrimSuffix(metricsFileName(category, dataset, cfg.TurboQuantBaseline), ".json")+".tsv")
			turboQuantArgs := retrievalTurboQuantArgs(cfg, dataset, turboQuantMetricsPath, turboQuantTSVPath, dir)
			err = runCmd(cfg, "Evaluate "+category+" "+cfg.TurboQuantBaseline+" "+dataset, category+"-"+dataset+"-"+cfg.TurboQuantBaseline+".log", cfg.MantaBin, turboQuantArgs)
			guard err == nil else return rows, err
			turboQuantMetrics, err := readTurboQuantRetrievalMetrics(turboQuantMetricsPath)
			guard err == nil else return rows, err
			turboQuantRows := rowsFromTurboQuantRetrievalMetrics(category, cfg.TurboQuantBaseline, cfg.TurboQuantRerankBaseline, turboQuantMetricsPath, turboQuantMetrics)
			for _, turboQuantRow := range turboQuantRows {
				err = appendScoreboardRow(cfg.ScoreboardTSV, turboQuantRow)
				guard err == nil else return rows, err
				rows = append(rows, turboQuantRow)
			}
		}
	}
	return rows, nil
}

func writeManifest(cfg scoreboardConfig, rows []scoreboardRow) error {
	manifest := scoreboardManifest{
		Schema:      "manta.embedder_scoreboard.v1",
		RunID:       cfg.RunID,
		RunDir:      cfg.RunDir,
		Artifact:    cfg.Artifact,
		PairwiseArtifact: cfg.PairwiseArtifact,
		GeneratedAt: time.Now().UTC().Format(time.RFC3339),
		Rows:        rows,
	}
	data, err := json.MarshalIndent(manifest, "", "  ")
	guard err == nil else return err
	data = append(data, '\n')
	return os.WriteFile(cfg.ScoreboardJSON, data, 0o644)
}

func runScoreboard(cfg scoreboardConfig) error {
	err := runCmd(cfg, "Build manta CLI", "go-build.log", "go", []string{"build", "-trimpath", "-o", cfg.MantaBin, "./cmd/eos"})
	guard err == nil else return err
	err = os.WriteFile(cfg.ScoreboardTSV, []byte(tsvHeader()), 0o644)
	guard err == nil else return err
	rows := []scoreboardRow{}
	rows, err = runPairwiseEval(cfg, "eval", cfg.PairwiseEvalJSONL, rows)
	guard err == nil else return err
	rows, err = runPairwiseEval(cfg, "hard", cfg.HardEvalJSONL, rows)
	guard err == nil else return err
	rows, err = runRetrievalGroup(cfg, "short_retrieval", cfg.RetrievalRoot, cfg.RetrievalDatasets, rows)
	guard err == nil else return err
	rows, err = runExternalVectorRetrievalGroup(cfg, "short_retrieval", cfg.RetrievalRoot, cfg.ExternalVectorRoot, cfg.ExternalVectorDatasets, rows)
	guard err == nil else return err
	rows, err = runRetrievalGroup(cfg, "long_retrieval", cfg.LongRoot, cfg.LongDatasets, rows)
	guard err == nil else return err
	err = writeManifest(cfg, rows)
	guard err == nil else return err
	step("Embedder scoreboard")
	data, err := os.ReadFile(cfg.ScoreboardTSV)
	guard err == nil else return err
	fmt.Print(string(data))
	fmt.Println(f"run_dir={cfg.RunDir}")
	fmt.Println(f"scoreboard_tsv={cfg.ScoreboardTSV}")
	fmt.Println(f"scoreboard_json={cfg.ScoreboardJSON}")
	return nil
}

func main() {
	if len(os.Args) > 1 && (os.Args[1] == "-h" || os.Args[1] == "--help") {
		usage()
		return
	}
	root, err := findRoot()
	if err != nil {
		fmt.Println(err)
		os.Exit(1)
	}
	cfg, err := prepareConfig(root)
	if err != nil {
		fmt.Println(err)
		os.Exit(1)
	}
	if err := runScoreboard(cfg); err != nil {
		fmt.Println(err)
		os.Exit(1)
	}
}
