func usage() {
	fmt.Println(`Eos CorkScrewDB budget-quality smoke.

Run:
  EOS_REPO_ROOT=$PWD ferrous-wheel run scripts/smoke_eos_corkscrewdb_budget_quality.fw

This wrapper feeds the existing Eos 128d SciFact child cache into the local flat
CorkScrewDB child-vector API smoke, then joins q4 API quality/storage/latency
metrics to the overhead-aware multivector storage planner.

Environment:
  EOS_CORKSCREW_BUDGET_QUALITY_RUN_ROOT=runs
  EOS_CORKSCREW_BUDGET_QUALITY_RUN_DIR=runs/eos-corkscrewdb-budget-quality-smoke-<timestamp>
  EOS_CORKSCREW_BUDGET_QUALITY_CORKSCREWDB_REPO=/home/draco/work/corkscrewdb
  EOS_CORKSCREW_BUDGET_QUALITY_DATASET_DIR=datasets/manta-embed-v1/raw/scifact/scifact
  EOS_CORKSCREW_BUDGET_QUALITY_QRELS=datasets/manta-embed-v1/raw/scifact/scifact/qrels/test.tsv
  EOS_CORKSCREW_BUDGET_QUALITY_CHILD_VECTORS=runs/eos-128d-child-cache-quality-20260615T000000Z/scifact/child-doc-vectors.jsonl
  EOS_CORKSCREW_BUDGET_QUALITY_QUERY_VECTORS=runs/eos-128d-child-cache-quality-20260615T000000Z/scifact/query-vectors.jsonl
  EOS_CORKSCREW_BUDGET_QUALITY_BITS=4
  EOS_CORKSCREW_BUDGET_QUALITY_OVERFETCH=100,12468
  EOS_CORKSCREW_BUDGET_QUALITY_BASELINE_DIM=3072
  EOS_CORKSCREW_BUDGET_QUALITY_TOP_PARENTS=100
  EOS_CORKSCREW_BUDGET_QUALITY_QUANTIZED_ONLY=1
  EOS_CORKSCREW_BUDGET_QUALITY_LAYOUT=separate_child_vectors # separate_child_vectors|packed_parent_multivectors
  EOS_CORKSCREW_BUDGET_QUALITY_TARGET_CHILDREN=100
  EOS_CORKSCREW_BUDGET_QUALITY_VECTOR_OVERHEAD_BYTES=32
  EOS_CORKSCREW_BUDGET_QUALITY_SIDECAR_STORAGE=none
  EOS_CORKSCREW_BUDGET_QUALITY_MIN_NDCG_AT_10=0.40
  EOS_CORKSCREW_BUDGET_QUALITY_MIN_RECALL_AT_100=0.72
