package main

// smoke_eos_sparse_long_context_retrieval codifies the evidence-only sparse
// long-context retrieval plumbing row. It creates a tiny BEIR-shaped fixture,
// retargets a run-local diagnostic max-seq package copy, exports
// sparse-token-pool vectors, scores dense and q4 TurboQuant retrieval over the
// vector cache, and asserts the claim boundary stays quality_claim=false.
//
// Usage:
//   EOS_REPO_ROOT=$PWD ferrous-wheel run scripts/smoke_eos_sparse_long_context_retrieval.fw
//
// Useful overrides:
//   EOS_SPARSE_LONG_CONTEXT_RETRIEVAL_SMOKE_RUN_ROOT=runs/eos-sparse-long-context-retrieval-smoke-<timestamp>
//   EOS_SPARSE_LONG_CONTEXT_RETRIEVAL_SMOKE_ARTIFACT=runs/current-release-qwen3-nf005-continuation-20260616T224102Z/candidate/eos-embed-v1.mll
//   EOS_SPARSE_LONG_CONTEXT_RETRIEVAL_SMOKE_MAX_SEQ=1024
//   EOS_SPARSE_LONG_CONTEXT_RETRIEVAL_SMOKE_MAX_TOKENS=1024
//   EOS_SPARSE_LONG_CONTEXT_RETRIEVAL_SMOKE_MIN_DOC_TOKENS=512

import (
	"bufio"
	"encoding/json"
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"strconv"
	"strings"
	"time"
)

const defaultArtifact = "runs/current-release-qwen3-nf005-continuation-20260616T224102Z/candidate/eos-embed-v1.mll"
const datasetName = "tiny-long-beir-sparse-token-pool-single-vector"
const evidenceLevel = "export_scoring_plumbing_only"
const claimBoundary = "Prototype sparse-token pooling retrieval cache. Not production dense embedder output, not trained sparse encoder evidence, and not LongEmbed proof."

type tokenStats struct {
	MaxObservedTokens int `json:"max_observed_tokens"`
}

type exportManifest struct {
	Method                  string     `json:"method"`
	Experimental            bool       `json:"experimental"`
	QualityClaim            bool       `json:"quality_claim"`
	ClaimBoundary           string     `json:"claim_boundary"`
	Dataset                 string     `json:"dataset"`
	Artifact                string     `json:"artifact"`
	Documents               int        `json:"documents"`
	Queries                 int        `json:"queries"`
	Dimension               int        `json:"dimension"`
	MaxTokens               int        `json:"max_tokens"`
	MinObservedDocTokens    int        `json:"min_observed_doc_tokens"`
	TopK                    int        `json:"top_k"`
	RouteBlockSize          int        `json:"route_block_size"`
	RouteTopBlocks          int        `json:"route_top_blocks"`
	Bits                    int        `json:"bits"`
	QuantizerSeed           int64      `json:"quantizer_seed"`
	AttentionMode           string     `json:"attention_mode"`
	TurboQuantKVApplied     bool       `json:"turboquant_kv_applied"`
	DenseKVMaterialized     bool       `json:"dense_kv_materialized"`
	KVDecode                string     `json:"kv_decode"`
	AttentionWeightsApplied bool       `json:"attention_weights_applied"`
	AttentionOutputApplied  bool       `json:"attention_output_applied"`
	HiddenProjectionApplied bool       `json:"hidden_projection_applied"`
	ProjectionApplied       bool       `json:"projection_applied"`
	DocumentTokenizerOutput tokenStats `json:"document_tokenizer_output"`
	Caveats                 []string   `json:"caveats"`
}

type quality struct {
	NDCGAt10    float64 `json:"ndcg_at_10"`
	MRRAt10     float64 `json:"mrr_at_10"`
	RecallAt100 float64 `json:"recall_at_100"`
	MAPAt10     float64 `json:"map_at_10"`
}

type evalMetrics struct {
	Backend string `json:"backend"`
	Inputs  struct {
		Documents     int   `json:"documents"`
		Queries       int   `json:"queries"`
		RelevantPairs int   `json:"relevant_pairs"`
		ScoredPairs   int64 `json:"scored_pairs"`
	} `json:"inputs"`
	Quality quality `json:"quality"`
}

type turboMetrics struct {
	Backend string `json:"backend"`
	Config  struct {
		QuantizerSeed int64 `json:"quantizer_seed"`
	} `json:"config"`
	Rows []struct {
		Bits             int     `json:"bits"`
		Method           string  `json:"method"`
		Quality          quality `json:"quality"`
		NDCGAt10Delta    float64 `json:"ndcg_at_10_delta"`
		RecallAt100Delta float64 `json:"recall_at_100_delta"`
	} `json:"rows"`
}

type fixtureManifest struct {
	Schema           string   `json:"schema"`
	CreatedAt        string   `json:"created_at"`
