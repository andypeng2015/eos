func usage() {
	fmt.Println(`Synthetic Eos time-series window CorkScrewDB API smoke.

Run:
  EOS_REPO_ROOT=$PWD ferrous-wheel run scripts/smoke_eos_corkscrewdb_timeseries_windows.fw

This wrapper generates synthetic Eos text-rendered time-series window vectors,
then joins local flat CorkScrewDB API metrics to the time-series storage planner
output. The default layout writes separate child vectors with PutVector and
SearchVector; packed mode writes parent multivectors and uses exact
SearchParentsVector.

Environment:
  EOS_CORKSCREW_TS_WINDOW_RUN_ROOT=runs
  EOS_CORKSCREW_TS_WINDOW_RUN_DIR=runs/eos-corkscrewdb-timeseries-window-smoke-<timestamp>
  EOS_CORKSCREW_TS_WINDOW_ARTIFACT=/path/to/manta-embed-v1.sealed.mll
  EOS_CORKSCREW_TS_WINDOW_CORKSCREWDB_REPO=/home/draco/work/corkscrewdb
  EOS_CORKSCREW_TS_WINDOW_BITS=4,8
  EOS_CORKSCREW_TS_WINDOW_OVERFETCH=100
  EOS_CORKSCREW_TS_WINDOW_OUTPUT_DIM=128
  EOS_CORKSCREW_TS_WINDOW_SERIES_LENGTH=12
  EOS_CORKSCREW_TS_WINDOW_SERIES_VARIANTS=1
  EOS_CORKSCREW_TS_WINDOW_WINDOW_SIZE=4
  EOS_CORKSCREW_TS_WINDOW_WINDOW_STRIDE=2
  EOS_CORKSCREW_TS_WINDOW_BATCH_SIZE=64
  EOS_CORKSCREW_TS_WINDOW_BASELINE_DIM=3072
  EOS_CORKSCREW_TS_WINDOW_TOP_PARENTS=100
  EOS_CORKSCREW_TS_WINDOW_LAYOUT=separate_child_vectors # separate_child_vectors|packed_parent_multivectors
  EOS_CORKSCREW_TS_WINDOW_TARGET_CHILDREN=5
  EOS_CORKSCREW_TS_WINDOW_VECTOR_OVERHEAD_BYTES=32
  EOS_CORKSCREW_TS_WINDOW_COLLECTION=eos_timeseries_window_smoke
  EOS_CORKSCREW_TS_WINDOW_DATASET=synthetic-timeseries-windows
  EOS_CORKSCREW_TS_WINDOW_MIN_Q4_NDCG_AT_10=0
  EOS_CORKSCREW_TS_WINDOW_MIN_Q4_RECALL_AT_100=0
  EOS_CORKSCREW_TS_WINDOW_MIN_Q8_NDCG_AT_10=0
  EOS_CORKSCREW_TS_WINDOW_MIN_Q8_RECALL_AT_100=0
  EOS_CORKSCREW_TS_WINDOW_MIN_PLANNER_FIT=<TARGET_CHILDREN>
  EOS_CORKSCREW_TS_WINDOW_MAX_VECTOR_PAYLOAD_MULTIPLE=0.10
  EOS_CORKSCREW_TS_WINDOW_MAX_DB_DIR_MULTIPLE=0
  EOS_CORKSCREW_TS_WINDOW_MAX_P95_MS=0`)
}

func getenv(name string, fallback string) string {
	value := os.Getenv(name)
	if value != "" {
		return value
	}
	return fallback
}

func hasRepoRoot(dir string) bool {
	if dir == "" {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, "go.mod")); err != nil {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, ".git")); err != nil {
		return false
	}
	return true
}

func findRoot() (string, error) {
	if explicit := os.Getenv("EOS_REPO_ROOT"); hasRepoRoot(explicit) {
		return filepath.Abs(explicit)
	}
	if pwd := os.Getenv("PWD"); hasRepoRoot(pwd) {
		return filepath.Abs(pwd)
	}
	cwd, err := os.Getwd()
	if err != nil {
		return "", err
	}
	if hasRepoRoot(cwd) {
		return filepath.Abs(cwd)
	}
	return "", fmt.Errorf("could not find repo root; set EOS_REPO_ROOT")
}

func resolvePath(root string, path string) (string, error) {
	if filepath.IsAbs(path) {
		return filepath.Abs(path)
	}
	return filepath.Abs(filepath.Join(root, path))
}

func parseIntEnv(name string, fallback int) (int, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.Atoi(value)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseInt64Env(name string, fallback int64) (int64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseInt(value, 10, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func parseFloatEnv(name string, fallback float64) (float64, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.ParseFloat(value, 64)
	if err != nil {
		return 0, fmt.Errorf("%s must be a float: %w", name, err)
	}
	return parsed, nil
}

func parsePositiveIntList(name string, value string) ([]int, error) {
	parts := strings.Split(value, ",")
	values := []int{}
	for _, part := range parts {
		part = strings.TrimSpace(part)
		if part == "" {
			continue
		}
		parsed, err := strconv.Atoi(part)
		if err != nil {
			return nil, fmt.Errorf("%s contains invalid integer %q: %w", name, part, err)
		}
		if parsed <= 0 {
			return nil, fmt.Errorf("%s values must be positive: %d", name, parsed)
		}
		values = append(values, parsed)
	}
	if len(values) == 0 {
		return nil, fmt.Errorf("%s must include at least one positive integer", name)
	}
	return values, nil
}

func hasInt(values []int, needle int) bool {
	for _, value := range values {
		if value == needle {
			return true
		}
	}
	return false
}

func shellQuote(value string) string {
	if value == "" {
		return "''"
	}
	if strings.ContainsAny(value, " \t\n'\"\\$`!*?[]{}()<>|&;") {
		return "'" + strings.ReplaceAll(value, "'", "'\\''") + "'"
	}
	return value
}

func renderCommand(args []string) string {
	parts := []string{}
	for _, arg := range args {
		parts = append(parts, shellQuote(arg))
	}
	return strings.Join(parts, " ")
}

func runCommand(root string, logDir string, label string, args []string, env []string) (commandRecord, error) {
	fmt.Println("\n== " + label + " ==")
	fmt.Println("+ " + renderCommand(args))
	logPath := filepath.Join(logDir, label+".log")
	cmd := exec.Command(args[0], args[1:]...)
	cmd.Dir = root
	cmd.Env = env
	output, err := cmd.CombinedOutput()
	if writeErr := os.WriteFile(logPath, append([]byte(renderCommand(args)+"\n\n"), output...), 0o644); writeErr != nil {
		return commandRecord{}, writeErr
	}
	fmt.Print(string(output))
	record := commandRecord{Label: label, Args: args, Log: logPath}
	if err != nil {
		return record, fmt.Errorf("%s failed: %w", label, err)
	}
	return record, nil
}

func readJSON(path string, target any) error {
	data, err := os.ReadFile(path)
	if err != nil {
		return err
	}
	return json.Unmarshal(data, target)
}

func findPlanRow(rows []planRow, bits int, windows int) *planRow {
	for i := range rows {
		rowWindows := rows[i].DerivedWindowCount
		if rowWindows == 0 {
			rowWindows = rows[i].VectorsPerObject
		}
		if rows[i].Bits == bits && rowWindows == windows {
			return &rows[i]
		}
	}
	return nil
}

func makeSummaryRows(metrics []corkMetric, plan storagePlan, exported exportManifest, derivedWindowsPerParent int) []summaryRow {
	rows := []summaryRow{}
	for _, metric := range metrics {
		row := summaryRow{
			Bits:                         metric.Bits,
			OverfetchChildren:            metric.OverfetchChildren,
			ParentInsertCount:            metric.ParentInsertCount,
			IndexType:                    metric.IndexType,
			VectorStorage:                metric.VectorStorage,
			Layout:                       metric.Layout,
			SearchMode:                   metric.SearchMode,
			ParentSearchExact:            metric.ParentSearchExact,
			ParentCount:                  exported.Series,
			ChildWindowCount:             exported.ChildVectors,
			DerivedWindowsPerParent:      derivedWindowsPerParent,
			QueryCount:                   metric.QueryCount,
			RelevantPairs:                metric.RelevantPairs,
			NDCGAt10:                     metric.Quality.NDCGAt10,
			RecallAt100:                  metric.Quality.RecallAt100,
			VectorPayloadStorageMultiple: metric.VectorPayloadStorageMultiple,
			DBDirectoryStorageMultiple:   metric.DBDirectoryStorageMultiple,
			DBBytesAfterClose:            metric.DBBytesAfterClose,
			QuantizedVectorBytes:         metric.QuantizedVectorBytes,
			QuantizedChildBytes:          metric.QuantizedChildBytes,
			LoadSeconds:                  metric.LoadSeconds,
			SearchSeconds:                metric.SearchSeconds,
			P95MS:                        metric.SearchLatency.P95MS,
		}
		if planRow := findPlanRow(plan.Rows, metric.Bits, derivedWindowsPerParent); planRow != nil {
			row.PlannerQuantizedVectorStorageBytes = planRow.QuantizedVectorStorageBytes
			row.PlannerVectorsFitOneDenseVector = planRow.VectorsThatFitInOneDenseVector
			row.PlannerFit = planRow.FitsInOneDenseVectorStorage
			row.PlannerStorageMultiple = planRow.StorageMultipleOfDenseParentCost
		}
		rows = append(rows, row)
	}
	return rows
}

func writeSummaryTSV(path string, rows []summaryRow) error {
	var b strings.Builder
	b.WriteString("bits\toverfetch_children\tparent_insert_count\tlayout\tsearch_mode\tparent_search_exact\tindex_type\tvector_storage\tparent_count\tchild_window_count\tderived_windows_per_parent\tquery_count\trelevant_pairs\tndcg_at_10\trecall_at_100\tvector_payload_storage_multiple\tdb_directory_storage_multiple\tdb_bytes_after_close\tquantized_vector_bytes\tquantized_child_bytes\tload_seconds\tsearch_seconds\tp95_ms\tplanner_quantized_vector_storage_bytes\tplanner_vectors_fit_one_dense_vector\tplanner_fit\tplanner_storage_multiple_at_derived_windows\n")
	for _, row := range rows {
		fmt.Fprintf(&b, "%d\t%d\t%d\t%s\t%s\t%t\t%s\t%s\t%d\t%d\t%d\t%d\t%d\t%.6f\t%.6f\t%.6f\t%.6f\t%d\t%d\t%d\t%.6f\t%.6f\t%.6f\t%d\t%d\t%t\t%.6f\n",
			row.Bits,
			row.OverfetchChildren,
			row.ParentInsertCount,
			row.Layout,
			row.SearchMode,
			row.ParentSearchExact,
			row.IndexType,
			row.VectorStorage,
			row.ParentCount,
			row.ChildWindowCount,
			row.DerivedWindowsPerParent,
			row.QueryCount,
			row.RelevantPairs,
			row.NDCGAt10,
			row.RecallAt100,
			row.VectorPayloadStorageMultiple,
			row.DBDirectoryStorageMultiple,
			row.DBBytesAfterClose,
			row.QuantizedVectorBytes,
			row.QuantizedChildBytes,
			row.LoadSeconds,
			row.SearchSeconds,
			row.P95MS,
			row.PlannerQuantizedVectorStorageBytes,
			row.PlannerVectorsFitOneDenseVector,
			row.PlannerFit,
			row.PlannerStorageMultiple)
	}
	return os.WriteFile(path, []byte(b.String()), 0o644)
}

func findSummaryRow(rows []summaryRow, bits int) *summaryRow {
	for i := range rows {
		if rows[i].Bits == bits {
			return &rows[i]
		}
	}
	return nil
}

func checkGates(rows []summaryRow, cfg config) error {
	q4 := findSummaryRow(rows, 4)
	if q4 == nil {
		return fmt.Errorf("q4 row is missing; EOS_CORKSCREW_TS_WINDOW_BITS must include 4")
	}
	q8 := findSummaryRow(rows, 8)
	if cfg.MinQ4NDCG > 0 && q4.NDCGAt10 < cfg.MinQ4NDCG {
		return fmt.Errorf("q4 ndcg@10 %.6f is below %.6f", q4.NDCGAt10, cfg.MinQ4NDCG)
	}
	if cfg.MinQ4Recall > 0 && q4.RecallAt100 < cfg.MinQ4Recall {
		return fmt.Errorf("q4 recall@100 %.6f is below %.6f", q4.RecallAt100, cfg.MinQ4Recall)
	}
	if q8 != nil && cfg.MinQ8NDCG > 0 && q8.NDCGAt10 < cfg.MinQ8NDCG {
		return fmt.Errorf("q8 ndcg@10 %.6f is below %.6f", q8.NDCGAt10, cfg.MinQ8NDCG)
	}
	if q8 != nil && cfg.MinQ8Recall > 0 && q8.RecallAt100 < cfg.MinQ8Recall {
		return fmt.Errorf("q8 recall@100 %.6f is below %.6f", q8.RecallAt100, cfg.MinQ8Recall)
	}
	for _, row := range rows {
		if cfg.MinPlannerFit > 0 && row.PlannerVectorsFitOneDenseVector < cfg.MinPlannerFit {
			return fmt.Errorf("q%d planner fits %d child vectors, below %d", row.Bits, row.PlannerVectorsFitOneDenseVector, cfg.MinPlannerFit)
		}
		if !row.PlannerFit {
			return fmt.Errorf("q%d derived window count %d does not fit in one dense-vector budget", row.Bits, row.DerivedWindowsPerParent)
		}
		if cfg.MaxVectorPayloadMult > 0 && row.VectorPayloadStorageMultiple > cfg.MaxVectorPayloadMult {
			return fmt.Errorf("q%d vector payload multiple %.6f exceeds %.6f", row.Bits, row.VectorPayloadStorageMultiple, cfg.MaxVectorPayloadMult)
		}
		if cfg.MaxDBDirMultiple > 0 && row.DBDirectoryStorageMultiple > cfg.MaxDBDirMultiple {
			return fmt.Errorf("q%d DB directory multiple %.6f exceeds %.6f", row.Bits, row.DBDirectoryStorageMultiple, cfg.MaxDBDirMultiple)
		}
		if cfg.MaxP95MS > 0 && row.P95MS > cfg.MaxP95MS {
			return fmt.Errorf("q%d p95 %.6fms exceeds %.6fms", row.Bits, row.P95MS, cfg.MaxP95MS)
		}
	}
	return nil
}

func main() {
	if len(os.Args) > 1 && (os.Args[1] == "-h" || os.Args[1] == "--help") {
		usage()
		return
	}
	root, err := findRoot()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	runRoot := getenv("EOS_CORKSCREW_TS_WINDOW_RUN_ROOT", filepath.Join(root, "runs"))
	runDir := getenv("EOS_CORKSCREW_TS_WINDOW_RUN_DIR", filepath.Join(runRoot, "eos-corkscrewdb-timeseries-window-smoke-"+time.Now().UTC().Format("20060102T150405Z")))
	runDir, err = resolvePath(root, runDir)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	logDir := filepath.Join(runDir, "logs")
	if err := os.MkdirAll(logDir, 0o755); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	corkscrewRepo, err := resolvePath(root, getenv("EOS_CORKSCREW_TS_WINDOW_CORKSCREWDB_REPO", defaultCorkScrewDBRepo))
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	bitsValue := getenv("EOS_CORKSCREW_TS_WINDOW_BITS", "4,8")
	bits, err := parsePositiveIntList("EOS_CORKSCREW_TS_WINDOW_BITS", bitsValue)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if !hasInt(bits, 4) {
		fmt.Fprintln(os.Stderr, "EOS_CORKSCREW_TS_WINDOW_BITS must include 4")
		os.Exit(1)
	}
	overfetchValue := getenv("EOS_CORKSCREW_TS_WINDOW_OVERFETCH", "100")
	outputDim, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_OUTPUT_DIM", 128)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	windowSize, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_WINDOW_SIZE", 4)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	windowStride, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_WINDOW_STRIDE", 2)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	seriesLength, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_SERIES_LENGTH", 12)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if seriesLength <= 0 {
		fmt.Fprintf(os.Stderr, "EOS_CORKSCREW_TS_WINDOW_SERIES_LENGTH must be a positive integer, got %d\n", seriesLength)
		os.Exit(1)
	}
	seriesVariants, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_SERIES_VARIANTS", 1)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if seriesVariants <= 0 {
		fmt.Fprintf(os.Stderr, "EOS_CORKSCREW_TS_WINDOW_SERIES_VARIANTS must be a positive integer, got %d\n", seriesVariants)
		os.Exit(1)
	}
	batchSize := getenv("EOS_CORKSCREW_TS_WINDOW_BATCH_SIZE", "64")
	baselineDim, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_BASELINE_DIM", 3072)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	topParents, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_TOP_PARENTS", 100)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	targetChildren, err := parseIntEnv("EOS_CORKSCREW_TS_WINDOW_TARGET_CHILDREN", 5)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	vectorOverheadBytes, err := parseInt64Env("EOS_CORKSCREW_TS_WINDOW_VECTOR_OVERHEAD_BYTES", 32)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minQ4NDCG, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MIN_Q4_NDCG_AT_10", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minQ4Recall, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MIN_Q4_RECALL_AT_100", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minQ8NDCG, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MIN_Q8_NDCG_AT_10", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minQ8Recall, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MIN_Q8_RECALL_AT_100", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	minPlannerFit, err := parseInt64Env("EOS_CORKSCREW_TS_WINDOW_MIN_PLANNER_FIT", int64(targetChildren))
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	maxVectorPayloadMultiple, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MAX_VECTOR_PAYLOAD_MULTIPLE", 0.10)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	maxDBDirMultiple, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MAX_DB_DIR_MULTIPLE", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	maxP95MS, err := parseFloatEnv("EOS_CORKSCREW_TS_WINDOW_MAX_P95_MS", 0)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	collectionLabel := getenv("EOS_CORKSCREW_TS_WINDOW_COLLECTION", "eos_timeseries_window_smoke")
	datasetLabel := getenv("EOS_CORKSCREW_TS_WINDOW_DATASET", "synthetic-timeseries-windows")
	artifact := strings.TrimSpace(os.Getenv("EOS_CORKSCREW_TS_WINDOW_ARTIFACT"))
	indexType := "flat"
	vectorStorage := "quantized_only"
	layout := getenv("EOS_CORKSCREW_TS_WINDOW_LAYOUT", "separate_child_vectors")
	cfg := config{
		RunRoot:             runRoot,
		RunDir:              runDir,
		Artifact:            artifact,
		CorkScrewDBRepo:     corkscrewRepo,
		Bits:                bitsValue,
		OverfetchChildren:   overfetchValue,
		OutputDim:           outputDim,
		WindowSize:          windowSize,
		WindowStride:        windowStride,
		SeriesLength:        seriesLength,
		SeriesVariants:      seriesVariants,
		BatchSize:           batchSize,
		BaselineDim:         baselineDim,
		TopParents:          topParents,
		TargetChildren:      targetChildren,
		VectorOverheadBytes: vectorOverheadBytes,
		CollectionLabel:      collectionLabel,
		DatasetLabel:         datasetLabel,
		IndexType:           indexType,
		VectorStorage:        vectorStorage,
		Layout:               layout,
		MinQ4NDCG:            minQ4NDCG,
		MinQ4Recall:          minQ4Recall,
		MinQ8NDCG:            minQ8NDCG,
		MinQ8Recall:          minQ8Recall,
		MinPlannerFit:        minPlannerFit,
		MaxVectorPayloadMult: maxVectorPayloadMultiple,
		MaxDBDirMultiple:     maxDBDirMultiple,
		MaxP95MS:             maxP95MS,
	}

	timeseriesRunDir := filepath.Join(runDir, "timeseries")
	timeseriesEnv := append(os.Environ(),
		"EOS_REPO_ROOT="+root,
		"EOS_TS_WINDOW_SMOKE_RUN_DIR="+timeseriesRunDir,
		"EOS_TS_WINDOW_SMOKE_BITS="+bitsValue,
		"EOS_TS_WINDOW_SMOKE_OUTPUT_DIM="+strconv.Itoa(outputDim),
		"EOS_TS_WINDOW_SMOKE_WINDOW_SIZE="+strconv.Itoa(windowSize),
		"EOS_TS_WINDOW_SMOKE_WINDOW_STRIDE="+strconv.Itoa(windowStride),
		"EOS_TS_WINDOW_SMOKE_SERIES_LENGTH="+strconv.Itoa(seriesLength),
		"EOS_TS_WINDOW_SMOKE_SERIES_VARIANTS="+strconv.Itoa(seriesVariants),
		"EOS_TS_WINDOW_SMOKE_BATCH_SIZE="+batchSize,
		"EOS_TS_WINDOW_SMOKE_BASELINE_DIM="+strconv.Itoa(baselineDim),
		"EOS_TS_WINDOW_SMOKE_VECTOR_OVERHEAD_BYTES="+strconv.FormatInt(vectorOverheadBytes, 10),
	)
	if artifact != "" {
		timeseriesEnv = append(timeseriesEnv, "EOS_TS_WINDOW_SMOKE_ARTIFACT="+artifact)
	}
	commands := []commandRecord{}
	record, err := runCommand(root, logDir, "timeseries-window-vectors", []string{"ferrous-wheel", "run", "scripts/smoke_eos_timeseries_window_vectors.fw"}, timeseriesEnv)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	commands = append(commands, record)

	timeseriesManifestPath := filepath.Join(timeseriesRunDir, "window-cache.manifest.json")
	timeseriesSummary := filepath.Join(timeseriesRunDir, "summary.tsv")
	timeseriesStoragePlan := filepath.Join(timeseriesRunDir, "storage-plan.json")
	childVectors := filepath.Join(timeseriesRunDir, "window-cache", "child-doc-vectors.jsonl")
	queryVectors := filepath.Join(timeseriesRunDir, "window-cache", "query-vectors.jsonl")
	qrels := filepath.Join(timeseriesRunDir, "qrels.tsv")
	var exported exportManifest
	if err := readJSON(timeseriesManifestPath, &exported); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if exported.Series <= 0 {
		fmt.Fprintf(os.Stderr, "time-series export manifest has invalid series_count %d; cannot derive windows per parent\n", exported.Series)
		os.Exit(1)
	}
	if exported.ChildVectors%exported.Series != 0 {
		fmt.Fprintf(os.Stderr, "time-series export manifest child_window_vectors %d is not divisible by series_count %d\n", exported.ChildVectors, exported.Series)
		os.Exit(1)
	}
	derivedWindowsPerParent := exported.ChildVectors / exported.Series
	var plan storagePlan
	if err := readJSON(timeseriesStoragePlan, &plan); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	corkscrewRunDir := filepath.Join(runDir, "corkscrewdb")
	corkEnv := append(os.Environ(),
		"EOS_REPO_ROOT="+root,
		"EOS_CORKSCREW_SMOKE_RUN_DIR="+corkscrewRunDir,
		"EOS_CORKSCREW_SMOKE_CORKSCREWDB_REPO="+corkscrewRepo,
		"EOS_CORKSCREW_SMOKE_CHILD_VECTORS="+childVectors,
		"EOS_CORKSCREW_SMOKE_QUERY_VECTORS="+queryVectors,
		"EOS_CORKSCREW_SMOKE_QRELS="+qrels,
		"EOS_CORKSCREW_SMOKE_BITS="+bitsValue,
		"EOS_CORKSCREW_SMOKE_OVERFETCH="+overfetchValue,
		"EOS_CORKSCREW_SMOKE_BASELINE_DIM="+strconv.Itoa(baselineDim),
		"EOS_CORKSCREW_SMOKE_TOP_PARENTS="+strconv.Itoa(topParents),
		"EOS_CORKSCREW_SMOKE_COLLECTION="+collectionLabel,
		"EOS_CORKSCREW_SMOKE_DATASET="+datasetLabel,
		"EOS_CORKSCREW_SMOKE_INDEX_TYPE="+indexType,
		"EOS_CORKSCREW_SMOKE_VECTOR_STORAGE="+vectorStorage,
		"EOS_CORKSCREW_SMOKE_LAYOUT="+layout,
		"EOS_CORKSCREW_SMOKE_QUANTIZED_ONLY=1",
		"EOS_CORKSCREW_SMOKE_REBUILD_INDEX=0",
		"EOS_CORKSCREW_SMOKE_MIN_NDCG_AT_10=0",
		"EOS_CORKSCREW_SMOKE_MIN_RECALL_AT_100=0",
	)
	record, err = runCommand(root, logDir, "corkscrewdb-child-vector-smoke", []string{"ferrous-wheel", "run", "scripts/smoke_corkscrewdb_child_vectors.fw"}, corkEnv)
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	commands = append(commands, record)

	corkManifestPath := filepath.Join(corkscrewRunDir, "manifest.json")
	var corkOut corkManifest
	if err := readJSON(corkManifestPath, &corkOut); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	metrics := []corkMetric{}
	for _, metricPath := range corkOut.MetricFiles {
		var metric corkMetric
		if err := readJSON(metricPath, &metric); err != nil {
			fmt.Fprintln(os.Stderr, err)
			os.Exit(1)
		}
		metrics = append(metrics, metric)
	}
	if len(metrics) == 0 {
		fmt.Fprintln(os.Stderr, "CorkScrewDB smoke wrote no metric files")
		os.Exit(1)
	}

	rows := makeSummaryRows(metrics, plan, exported, derivedWindowsPerParent)
	if err := checkGates(rows, cfg); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	summaryTSV := filepath.Join(runDir, "summary.tsv")
	if err := writeSummaryTSV(summaryTSV, rows); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	manifestJSON := filepath.Join(runDir, "manifest.json")
	out := manifest{
		Schema:                 "eos.corkscrewdb_timeseries_window_smoke.v1",
		GeneratedAt:            time.Now().UTC().Format(time.RFC3339),
		RepoRoot:               root,
		RunDir:                 runDir,
		Config:                 cfg,
		Inputs: map[string]string{
			"child_vectors": childVectors,
			"query_vectors": queryVectors,
			"qrels": qrels,
			"corkscrewdb_repo": corkscrewRepo,
			"series_length": strconv.Itoa(seriesLength),
			"series_variants": strconv.Itoa(seriesVariants),
			"window_size": strconv.Itoa(windowSize),
			"window_stride": strconv.Itoa(windowStride),
			"output_dim": strconv.Itoa(outputDim),
			"batch_size": batchSize,
		},
		Commands:               commands,
		TimeseriesRunDir:        timeseriesRunDir,
		TimeseriesManifest:      timeseriesManifestPath,
		TimeseriesSummary:       timeseriesSummary,
		TimeseriesStoragePlan:   timeseriesStoragePlan,
		CorkScrewDBRunDir:       corkscrewRunDir,
		CorkScrewDBManifest:     corkManifestPath,
		CorkScrewDBSummary:      corkOut.SummaryTSV,
		CorkScrewDBMetricFiles:  corkOut.MetricFiles,
		SummaryTSV:             summaryTSV,
		ParentCount:            exported.Series,
		ChildWindowCount:       exported.ChildVectors,
		DerivedWindowsPerParent: derivedWindowsPerParent,
		Rows:                   rows,
		Gates: []string{
			fmt.Sprintf("q4 ndcg@10 >= %.6f and recall@100 >= %.6f when positive", minQ4NDCG, minQ4Recall),
			fmt.Sprintf("q8 ndcg@10 >= %.6f and recall@100 >= %.6f when q8 is present and thresholds are positive", minQ8NDCG, minQ8Recall),
			fmt.Sprintf("planner fit >= %d child windows in one dense-vector budget", minPlannerFit),
			fmt.Sprintf("vector payload storage multiple <= %.6f when positive", maxVectorPayloadMultiple),
			fmt.Sprintf("DB directory storage multiple <= %.6f when positive", maxDBDirMultiple),
			fmt.Sprintf("p95 latency <= %.6fms when positive", maxP95MS),
		},
		Caveats: []string{
			"Synthetic smoke only: text-rendered numeric windows, not a trained numeric time-series encoder.",
			"Local CorkScrewDB API smoke only: separate layout uses PutVector/SearchVector child overfetch rollup; packed layout uses PutMultiVector/SearchParentsVector exact flat parent rollup.",
			"Default CorkScrewDB mode is separate child vectors with flat + quantized_only persistence; packed parent multivectors must be requested explicitly.",
			"DB directory size is measured separately from vector-payload and planner accounting; keep DB directory multiple distinct from vector payload multiple.",
			"The joined planner output comes from the nested time-series smoke storage-plan.json.",
		},
	}
	data, err := json.MarshalIndent(out, "", "  ")
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	if err := os.WriteFile(manifestJSON, append(data, '\n'), 0o644); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}

	fmt.Printf("\nsummary_tsv: %s\n", summaryTSV)
	fmt.Printf("manifest: %s\n", manifestJSON)
	fmt.Printf("windows: parents=%d child_windows=%d derived_windows_per_parent=%d dim=%d window_size=%d stride=%d\n",
		exported.Series,
		exported.ChildVectors,
		derivedWindowsPerParent,
		exported.Dimension,
		exported.WindowSize,
		exported.WindowStride)
	for _, row := range rows {
		fmt.Printf("q%d overfetch%d %s %s/%s: ndcg@10=%.6f recall@100=%.6f planner_fit=%d planner_multiple=%.6fx db_dir_multiple=%.6fx vector_payload_multiple=%.6fx p95=%.6fms\n",
			row.Bits,
			row.OverfetchChildren,
			row.Layout,
			row.IndexType,
			row.VectorStorage,
			row.NDCGAt10,
			row.RecallAt100,
			row.PlannerVectorsFitOneDenseVector,
			row.PlannerStorageMultiple,
			row.DBDirectoryStorageMultiple,
			row.VectorPayloadStorageMultiple,
			row.P95MS)
	}
}
