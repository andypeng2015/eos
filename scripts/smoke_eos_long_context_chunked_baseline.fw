package main

import (
	"encoding/json"
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"strconv"
	"strings"
	"time"
)

type quality struct {
	NDCGAt10    float64 `json:"ndcg_at_10"`
	RecallAt100 float64 `json:"recall_at_100"`
}

type retrievalMetrics struct {
	Dataset string `json:"dataset"`
	Backend string `json:"backend"`
	Inputs struct {
		Documents int `json:"documents"`
		Queries   int `json:"queries"`
	} `json:"inputs"`
	Quality quality `json:"quality"`
}

type exportManifest struct {
	Dimension          int     `json:"dimension"`
	ModelDimension     int     `json:"model_dimension"`
	OutputDimension    int     `json:"output_dimension"`
	Documents          int     `json:"documents"`
	Queries            int     `json:"queries"`
	ChildVectors       int     `json:"child_vectors"`
	DocumentChunkWords int     `json:"document_chunk_words"`
	ElapsedSeconds     float64 `json:"elapsed_seconds"`
}

type mvMetrics struct {
	Dataset string `json:"dataset"`
	Backend string `json:"backend"`
	Inputs struct {
		ParentCount          int     `json:"parent_count"`
		ChildCount           int     `json:"child_count"`
		AvgChildrenPerParent float64 `json:"avg_children_per_parent"`
		MaxChildrenPerParent int     `json:"max_children_per_parent"`
		Queries              int     `json:"queries"`
	} `json:"inputs"`
	Config struct {
		QuantizerSeed int64 `json:"quantizer_seed"`
		BaselineDim   int   `json:"baseline_dim"`
	} `json:"config"`
	Dense struct {
		Quality                        quality `json:"quality"`
		ChildVectorBytes               int64   `json:"child_vector_bytes"`
		DenseChildBytes                int64   `json:"dense_child_bytes"`
		DenseBaselineBytes             int64   `json:"dense_baseline_bytes"`
		StorageMultipleOfDenseBaseline float64 `json:"storage_multiple_of_dense_baseline"`
	} `json:"dense"`
	Rows []struct {
		Bits                             int     `json:"bits"`
		Method                           string  `json:"method"`
		Quality                          quality `json:"quality"`
		NDCGAt10Delta                    float64 `json:"ndcg_at_10_delta"`
		RecallAt100Delta                 float64 `json:"recall_at_100_delta"`
		QuantizedVectorBytes             int64   `json:"quantized_vector_bytes"`
		QuantizedChildBytes              int64   `json:"quantized_child_bytes"`
		StorageMultipleOfDenseBaseline   float64 `json:"storage_multiple_of_dense_baseline"`
		VectorsThatFitInOneDenseBaseline int64   `json:"vectors_that_fit_in_one_dense_baseline"`
	} `json:"rows"`
}

type commandRecord struct {
	Label string   `json:"label"`
	Args  []string `json:"args"`
	Log   string   `json:"log"`
}

type summaryRow struct {
	Row                      string  `json:"row"`
	Bits                     int     `json:"bits,omitempty"`
	Method                   string  `json:"method"`
	NDCGAt10                 float64 `json:"ndcg_at_10"`
	RecallAt100              float64 `json:"recall_at_100"`
	Parents                  int     `json:"parents"`
	Children                 int     `json:"children"`
	AvgChildrenPerParent     float64 `json:"avg_children_per_parent"`
	VectorDim                int     `json:"vector_dim"`
	BaselineDim              int     `json:"baseline_dim,omitempty"`
	CompressionRatio         float64 `json:"compression_ratio,omitempty"`
	StorageMultiple          float64 `json:"storage_multiple_of_dense_baseline,omitempty"`
	QuantizedVectorBytes     int64   `json:"quantized_vector_bytes,omitempty"`
	VectorsFitOneDenseParent int64   `json:"vectors_that_fit_in_one_dense_parent,omitempty"`
	MetricsPath              string  `json:"metrics_path"`
}

type manifest struct {
	Schema      string            `json:"schema"`
	GeneratedAt string            `json:"generated_at"`
	RepoRoot    string            `json:"repo_root"`
	RunDir      string            `json:"run_dir"`
	Inputs      map[string]string `json:"inputs"`
	Commands    []commandRecord   `json:"commands"`
	Rows        []summaryRow      `json:"rows"`
	Caveats     []string          `json:"caveats"`
}

func getenv(name string, fallback string) string {
	value := strings.TrimSpace(os.Getenv(name))
	if value != "" {
		return value
	}
	return fallback
}

func hasRepoRoot(dir string) bool {
	if dir == "" {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, "go.mod")); err != nil {
		return false
	}
	if _, err := os.Stat(filepath.Join(dir, ".git")); err != nil {
		return false
	}
	return true
}

func findRoot() (string, error) {
	if explicit := os.Getenv("EOS_REPO_ROOT"); hasRepoRoot(explicit) {
		return filepath.Abs(explicit)
	}
	cwd, err := os.Getwd()
	if err != nil {
		return "", err
	}
	if hasRepoRoot(cwd) {
		return filepath.Abs(cwd)
	}
	return "", fmt.Errorf("could not find repo root; set EOS_REPO_ROOT")
}

func parseIntEnv(name string, fallback int) (int, error) {
	value := strings.TrimSpace(os.Getenv(name))
	if value == "" {
		return fallback, nil
	}
	parsed, err := strconv.Atoi(value)
	if err != nil {
		return 0, fmt.Errorf("%s must be an integer: %w", name, err)
	}
	return parsed, nil
}

func runCmd(root string, label string, logPath string, name string, args []string) (commandRecord, error) {
	cmd := exec.Command(name, args...)
	cmd.Dir = root
	out, err := cmd.CombinedOutput()
	_ = os.WriteFile(logPath, out, 0o644)
	record := commandRecord{Label: label, Args: append([]string{name}, args...), Log: logPath}
	if err != nil {
		return record, fmt.Errorf("%s failed: %w; see %s", label, err, logPath)
	}
	return record, nil
}

func writeJSONL(path string, rows []map[string]interface{}) error {
	var b strings.Builder
	for _, row := range rows {
		data, err := json.Marshal(row)
		if err != nil {
			return err
		}
		b.Write(data)
		b.WriteByte('\n')
	}
	return os.WriteFile(path, []byte(b.String()), 0o644)
}

func generateLateNeedleDataset(datasetDir string, docs int, queries int, prefixWords int) error {
	if err := os.MkdirAll(filepath.Join(datasetDir, "qrels"), 0o755); err != nil {
		return err
	}
	topics := []string{
		"alpine insulin cedar moonstone",
		"bronze library sodium harbor",
		"crimson telescope velvet enzyme",
		"delta orchard ceramic photon",
		"ember archive nickel compass",
		"frost canal amber protein",
		"granite museum cobalt lantern",
		"hazel observatory quartz peptide",
		"ivory station copper prism",
		"juniper clinic silver turbine",
		"kelp gallery oxygen spindle",
		"lunar depot violet catalyst",
	}
	if queries > len(topics) {
		queries = len(topics)
	}
	common := strings.Repeat("general background paragraph about local retrieval systems storage budgets embeddings compression evaluation documents and ordinary context ", prefixWords/12+1)
	commonWords := strings.Fields(common)
	if len(commonWords) > prefixWords {
		commonWords = commonWords[:prefixWords]
	}
	prefix := strings.Join(commonWords, " ")
	corpusRows := []map[string]interface{}{}
	queryRows := []map[string]interface{}{}
	var qrels strings.Builder
	qrels.WriteString("query-id\tcorpus-id\tscore\n")
	for i := 0; i < docs; i++ {
		topic := topics[i%len(topics)]
		id := fmt.Sprintf("doc-%02d", i)
		late := fmt.Sprintf("Late evidence marker. The archive answer is %s. This sentence is intentionally near the end of the long document.", topic)
		text := prefix + " " + late
		corpusRows = append(corpusRows, map[string]interface{}{
			"_id":   id,
			"title": fmt.Sprintf("Synthetic long document %02d", i),
			"text":  text,
		})
		if i < queries {
			qid := fmt.Sprintf("q-%02d", i)
			queryRows = append(queryRows, map[string]interface{}{
				"_id":  qid,
				"text": fmt.Sprintf("Which document says the archive answer is %s?", topic),
			})
			qrels.WriteString(fmt.Sprintf("%s\t%s\t1\n", qid, id))
		}
	}
	if err := writeJSONL(filepath.Join(datasetDir, "corpus.jsonl"), corpusRows); err != nil {
		return err
	}
	if err := writeJSONL(filepath.Join(datasetDir, "queries.jsonl"), queryRows); err != nil {
		return err
	}
	return os.WriteFile(filepath.Join(datasetDir, "qrels", "test.tsv"), []byte(qrels.String()), 0o644)
}

type semanticTopic struct {
	Doc    string
	Query  string
	Decoy  string
	Anchor string
}

